        // ─── Finance helpers ───
        'Where the money goes': 'Hová megy a pénz',
        'What-if simulator': 'Mi-történne szimulátor',
        'Cashflow · 14d back / 14d projection': 'Pénzforgalom · 14 nap vissza / 14 nap előre',
