    const SUPPORTED = ['en', 'hu', 'de'];
    function resolveLocale() {
      try {
        const url = new URL(window.location.href);
        const q = url.searchParams.get('lang');
        if (q && SUPPORTED.includes(q)) return q;
        const saved = localStorage.getItem('hs_lang');
        if (saved && SUPPORTED.includes(saved)) return saved;
      } catch { /* sandboxed */ }
      const nav = (navigator.language || 'en').slice(0, 2).toLowerCase();
      if (SUPPORTED.includes(nav)) return nav;
      return 'en';
    }
    const locale = resolveLocale();

    // ───── 1) data-i18n attribute swap ─────────────────────────────────
    function applyI18nAttrs() {
      const dict = DASH_TRANSLATIONS[locale] || DASH_TRANSLATIONS.en;
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const val = dict[key] || DASH_TRANSLATIONS.en[key];
        if (typeof val === 'string') el.textContent = val;
      });
      document.documentElement.setAttribute('lang', locale);
    }

