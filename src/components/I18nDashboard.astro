---
// Shared dashboard i18n bootstrap. Drop this into ANY /play/*.astro
// page (anywhere in the body) to enable HU/DE locale-switching for:
//   1) elements with `data-i18n="key"` attributes (per-page semantic keys)
//   2) globally-known dashboard copy (panel titles, common labels) via
//      a static EN→HU/DE text dictionary that walks every text node
// Reads `localStorage.hs_lang` (persisted by the landing's lang switcher)
// or ?lang=… query.
//
// Also renders <SidebarUser />, which wires the hardcoded "promnet · log out"
// row + "Shortcuts ⌘K" link in the sidebar foot into a real profile menu +
// keyboard-shortcut modal + animated logout transition.
import { TRANSLATIONS } from '../lib/i18n';
import SidebarUser from './SidebarUser.astro';
---
<SidebarUser />
<script is:inline define:vars={{ DASH_TRANSLATIONS: TRANSLATIONS }}>
  (function () {
    const SUPPORTED = ['en', 'hu', 'de'];
    function resolveLocale() {
      try {
        const url = new URL(window.location.href);
        const q = url.searchParams.get('lang');
        if (q && SUPPORTED.includes(q)) return q;
        const saved = localStorage.getItem('hs_lang');
        if (saved && SUPPORTED.includes(saved)) return saved;
      } catch { /* sandboxed */ }
      const nav = (navigator.language || 'en').slice(0, 2).toLowerCase();
      if (SUPPORTED.includes(nav)) return nav;
      return 'en';
    }
    const locale = resolveLocale();

    // ───── 0) Lang sync: cookie + DB ─────────────────────────────────
    // The server-side render (marketplace.astro, community.astro,
    // shift.astro, …) can't read localStorage — it can only see the
    // ?lang= URL param, the player.preferred_lang in D1, or a cookie.
    // So we mirror the client-side choice into both:
    //   (a) hs_lang cookie (1y) so the next server-render uses it
    //   (b) POST /api/game/settings if the DB row disagrees, so future
    //       sessions and cron-tick LLM prompts use the right locale
    try {
      const m = document.cookie.match(/(?:^|; )hs_lang=([^;]+)/);
      const cookieLang = m ? m[1] : null;
      if (cookieLang !== locale) {
        document.cookie = 'hs_lang=' + locale + '; path=/; max-age=' + (60 * 60 * 24 * 365) + '; samesite=lax';
      }
      // Best-effort DB sync. Silent on auth failure (landing page).
      // 5s debounce via session-storage so we don't spam the endpoint
      // on every page load.
      const lastSync = sessionStorage.getItem('hs_lang_last_sync');
      if (lastSync !== locale) {
        sessionStorage.setItem('hs_lang_last_sync', locale);
        fetch('/api/game/settings', {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ preferred_lang: locale }),
        }).catch(() => { /* silent */ });
      }
    } catch { /* sandboxed */ }

    // ───── 1) data-i18n attribute swap ─────────────────────────────────
    function applyI18nAttrs() {
      const dict = DASH_TRANSLATIONS[locale] || DASH_TRANSLATIONS.en;
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const val = dict[key] || DASH_TRANSLATIONS.en[key];
        if (typeof val === 'string') el.textContent = val;
      });
      document.documentElement.setAttribute('lang', locale);
    }

    // ───── 2) Static EN→HU/DE text walker for cross-page mock copy ─────
