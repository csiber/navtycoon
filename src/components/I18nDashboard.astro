      },
      de: {
        'Live event feed': 'Live-Event-Feed',
        'Open tickets': 'Offene Tickets',
        'Customer mood': 'Kundenstimmung',
        'Quick actions': 'Schnellaktionen',
        'Weekly goals': 'Wochenziele',
        'Era progress': 'Ära-Fortschritt',
