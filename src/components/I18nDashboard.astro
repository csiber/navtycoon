        'Welcome to Hyperscaler': 'Üdv a Hyperscaler-ben',
        'Customers are AI': 'Az ügyfeleid AI-k',
        'Tickets + Shift Mode': 'Ticketek + Műszak-mód',
        'Servers + Upgrades': 'Szerverek + Fejlesztések',
        'Your goal': 'A célod',
        'Next': 'Tovább',
        'Back': 'Vissza',
