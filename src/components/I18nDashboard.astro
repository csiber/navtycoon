        // ─── Common buttons ───
        'Buy server': 'Szerver vétel',
        'List on Marketplace': 'Hirdetés a Piactéren',
        'Hire support agent': 'Support-ügynök felvétele',
        'Start support shift': 'Műszak indítása',
