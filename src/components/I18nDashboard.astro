        'Settings': 'Einstellungen',
        'Dashboard': 'Dashboard',
        'Cash on hand': 'Verfügbares Geld',
        'Burn rate': 'Verbrennungsrate',
        'Runway': 'Laufzeit',
        'Buy server': 'Server kaufen',
        'Start support shift': 'Schicht starten',
        'Start a shift': 'Schicht starten',
        '▶ Start Shift': '▶ Schicht starten',
        'Close ticket': 'Ticket schließen',
        'Send': 'Senden',
        'Queue': 'Warteschlange',
        'Open': 'Offen',
        'Closed': 'Geschlossen',
        'Mine': 'Meine',
        'No activity yet': 'Noch keine Aktivität',
        'Marketplace v0.8 — coming soon': 'Marktplatz v0.8 — bald verfügbar',
        'Next': 'Weiter',
        'Back': 'Zurück',
        "Let's go": 'Los geht\'s',
      },
    };

    function walkText(node, dict) {
      if (node.nodeType === 3) {
        const raw = node.nodeValue;
        if (!raw) return;
        const trimmed = raw.trim();
        if (!trimmed) return;
        if (dict[trimmed]) {
          node.nodeValue = raw.replace(trimmed, dict[trimmed]);
        }
        return;
      }
      if (node.nodeType !== 1) return;
      const el = node;
      const tag = el.tagName;
      if (tag === 'SCRIPT' || tag === 'STYLE') return;
      if (el.hasAttribute && el.hasAttribute('data-i18n')) return;
      if (tag === 'OPTION') {
        const t = (el.textContent || '').trim();
        if (dict[t]) el.textContent = dict[t];
      }
      for (let i = 0; i < el.childNodes.length; i++) walkText(el.childNodes[i], dict);
    }

    function applyStatic() {
      if (locale === 'en') return;
      const dict = STATIC[locale];
      if (!dict) return;
      walkText(document.body, dict);
    }

    // Run attrs first, then static walker (so any data-i18n-resolved keys
    // are already in place and the walker skips them).
    applyI18nAttrs();
    applyStatic();
  })();
</script>
