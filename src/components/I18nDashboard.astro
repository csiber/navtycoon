        'REQUIREMENTS FOR ERA 3 (0/4)': 'VORAUSSETZUNGEN FÜR ÄRA 3 (0/4)',
        '0% to unlock': '0% bis zum Freischalten',
        'to unlock': 'bis zum Freischalten',
        'Burn': 'Verbrauch',
        'Burn rate': 'Verbrennungsrate',
        'Runway': 'Laufzeit',
        'Last review': 'Letzte Bewertung',
        'Used': 'Verwendet',
        'Temp': 'Temp.',
        'Power': 'Strom',
        'cooldown': 'Abklingzeit',
        'in stock': 'auf Lager',
        'Days lived': 'Gelebte Tage',
        'Forum mentions': 'Forum-Erwähnungen',
        'Era 1 · current': 'Ära 1 · aktuell',
        // ─── Quick action card labels ───
        'Buy server': 'Server kaufen',
        'List on Marketplace': 'Auf Marktplatz listen',
        'Hire support agent': 'Support-Mitarbeiter einstellen',
        'Auto-triage P3 tickets': 'Auto-Triage P3-Tickets',
        'Get 1-2 trial customers': '1-2 Trial-Kunden gewinnen',
        '24h cooldown': '24h Abklingzeit',
        '+1 slot': '+1 Slot',
        'per week': 'pro Woche',
        '30-min live ticket triage': '30-Min Live-Ticket-Triage',
        'per ticket': 'pro Ticket',
        '+rep': '+Ruf',
        // ─── Toast / notification labels ───
        'Achievement unlocked': 'Erfolg freigeschaltet',
        'Next era': 'Nächste Ära',
        'new tickets': 'neue Tickets',
        'new events': 'neue Events',
        'customers': 'Kunden',
        'churned': 'abgesprungen',
        'players': 'Spieler',
        'h away': 'h weg gewesen',
        '🎉 unlocked Era': '🎉 freigeschaltet: Ära',
        // ─── Sidebar user menu + shortcuts modal (SidebarUser.astro) ───
        'Profile & settings': 'Profil & Einstellungen',
        'Toggle theme': 'Theme umschalten',
        'Log out': 'Abmelden',
        'Close': 'Schließen',
        'Keyboard shortcuts': 'Tastenkürzel',
        'Command palette': 'Befehlspalette',
        'Close modal': 'Modal schließen',
        'Logging out…': 'Abmelden…',
        'goodbye': 'auf Wiedersehen',
      },
    };

    // Dynamic patterns that exact-match can't cover because they embed
    // numbers (era N, current progress X/Y). `exact` patterns anchor to
    // the entire trimmed textNode; `substring` patterns replace anywhere
    // inside the raw textNode (used when a number sits inside a longer
    // composite string like "2026 · Day 1").
    const PATTERNS = {
      hu: {
        exact: [
          [/^Requirements for Era (\d+) \((\d+)\/(\d+)\)$/i, 'KÖV. KORSZAK ($1) FELTÉTELEI ($2/$3)'],
          [/^(\d+)% to unlock$/i, '$1% feloldásig'],
          [/^Welcome back \((\d+)h away\)$/i, 'Üdv vissza ($1 órája voltál el)'],
          [/^Achievement unlocked: (.+)$/, 'Kitűző feloldva: $1'],
          [/^🎉 Achievement unlocked: (.+)$/, '🎉 Kitűző feloldva: $1'],
        ],
        substring: [
          [/\bDay (\d+) \/ 365\b/g, '$1. nap / 365'],
          [/\bDay (\d+)\b/g, '$1. nap'],
          [/\+(\d+) customers · /g, '+$1 ügyfél · '],
          [/(\d+) new tickets/g, '$1 új ticket'],
          [/(\d+) new events/g, '$1 új esemény'],
          [/(\d+) churned/g, '$1 churn'],
          [/(\d+) players · /g, '$1 játékos · '],
          [/🎉 unlocked Era (\d+)/g, '🎉 feloldva: $1. korszak'],
          [/\bEra (\d+) · /g, '$1. korszak · '],
          // Generic plural form for "N open tickets waiting" so the
          // sticky CTA stays in HU for any N (not just 1-4).
          [/^(\d+) open tickets? waiting$/g, '$1 nyitott ticket várakozik'],
          // Ticket detail / forum / activity time-ago tokens
          [/(\d+)h ago\b/g, '$1ó'],
          [/(\d+)d ago\b/g, '$1n'],
          [/(\d+)m ago\b/g, '$1p'],
          // Ticket thread-head triple "From X · Persona: y · Age: 18h"
          [/^From /g, 'Feladó: '],
          [/^Persona: /g, 'Persona: '],
          [/^Age: /g, 'Kor: '],
          // Composite variants (older templates use ` · ` separators)
          [/ · Persona: /g, ' · persona: '],
          [/ · Age: /g, ' · kor: '],
          // Finance card units
          [/Runway (\d+) days?\b/g, 'Futamidő $1 nap'],
          [/\$(\d+(?:\.\d+)?)\/day\b/g, '$$$1/nap'],
          [/(\d+) RECENT TICKETS?\b/gi, '$1 LEGUTÓBBI TICKET'],
          [/(\d+) days?\b/g, '$1 nap'],
        ],
      },
      de: {
        exact: [
          [/^Requirements for Era (\d+) \((\d+)\/(\d+)\)$/i, 'VORAUSSETZUNGEN FÜR ÄRA $1 ($2/$3)'],
          [/^(\d+)% to unlock$/i, '$1% bis zum Freischalten'],
          [/^Welcome back \((\d+)h away\)$/i, 'Willkommen zurück ($1h weg gewesen)'],
          [/^Achievement unlocked: (.+)$/, 'Erfolg freigeschaltet: $1'],
          [/^🎉 Achievement unlocked: (.+)$/, '🎉 Erfolg freigeschaltet: $1'],
        ],
        substring: [
          [/\bDay (\d+) \/ 365\b/g, 'Tag $1 / 365'],
          [/\bDay (\d+)\b/g, 'Tag $1'],
          [/\+(\d+) customers · /g, '+$1 Kunden · '],
          [/(\d+) new tickets/g, '$1 neue Tickets'],
          [/(\d+) new events/g, '$1 neue Events'],
          [/(\d+) churned/g, '$1 abgesprungen'],
          [/(\d+) players · /g, '$1 Spieler · '],
          [/🎉 unlocked Era (\d+)/g, '🎉 freigeschaltet: Ära $1'],
          [/\bEra (\d+) · /g, 'Ära $1 · '],
          [/^(\d+) open tickets? waiting$/g, '$1 offene Tickets warten'],
          [/(\d+)h ago\b/g, 'vor $1h'],
          [/(\d+)d ago\b/g, 'vor $1d'],
          [/(\d+)m ago\b/g, 'vor $1m'],
          [/^From /g, 'Von: '],
          [/^Persona: /g, 'Persona: '],
          [/^Age: /g, 'Alter: '],
          [/ · Persona: /g, ' · Persona: '],
          [/ · Age: /g, ' · Alter: '],
          [/Runway (\d+) days?\b/g, 'Laufzeit $1 Tage'],
          [/\$(\d+(?:\.\d+)?)\/day\b/g, '$$$1/Tag'],
          [/(\d+) RECENT TICKETS?\b/gi, '$1 NEUE TICKETS'],
          [/(\d+) days?\b/g, '$1 Tage'],
        ],
      },
    };

    function walkText(node, dict, patterns) {
      if (node.nodeType === 3) {
        const raw = node.nodeValue;
        if (!raw) return;
        const trimmed = raw.trim();
        if (!trimmed) return;
        if (dict[trimmed]) {
          node.nodeValue = raw.replace(trimmed, dict[trimmed]);
          return;
        }
        if (patterns && patterns.exact) {
          for (const [re, repl] of patterns.exact) {
            if (re.test(trimmed)) {
              node.nodeValue = raw.replace(trimmed, trimmed.replace(re, repl));
              return;
            }
          }
        }
        if (patterns && patterns.substring) {
          let value = raw;
          let changed = false;
          for (const [re, repl] of patterns.substring) {
            const next = value.replace(re, repl);
            if (next !== value) { value = next; changed = true; }
          }
          if (changed) node.nodeValue = value;
        }
        return;
      }
      if (node.nodeType !== 1) return;
      const el = node;
      const tag = el.tagName;
      if (tag === 'SCRIPT' || tag === 'STYLE') return;
      if (el.hasAttribute && el.hasAttribute('data-i18n')) return;
      if (tag === 'OPTION') {
        const t = (el.textContent || '').trim();
        if (dict[t]) el.textContent = dict[t];
      }
      for (let i = 0; i < el.childNodes.length; i++) walkText(el.childNodes[i], dict, patterns);
    }

    function applyStatic() {
      if (locale === 'en') return;
      const dict = STATIC[locale];
      if (!dict) return;
      walkText(document.body, dict, PATTERNS[locale]);
    }

    // Run attrs first, then static walker (so any data-i18n-resolved keys
    // are already in place and the walker skips them).
    applyI18nAttrs();
    applyStatic();

    // ─── Re-translate async-injected DOM (event modals, toasts, …) ───
    // The events-overlay div is filled by a fetch-then-DOM-inject script
    // that runs AFTER applyStatic, so the first pass misses the event-
    // modal labels ("Pay $300 for Cloudflare mitigation", "Tough it out",
    // etc.). A MutationObserver re-walks any new subtree once. Debounced
    // with a microtask so a burst of inserts only triggers one pass.
    if (locale !== 'en') {
      const dict = STATIC[locale];
      const pat = PATTERNS[locale];
      let queued = false;
      const pending = [];
      function flush() {
        queued = false;
        const batch = pending.splice(0);
        for (const node of batch) walkText(node, dict, pat);
      }
      const obs = new MutationObserver((records) => {
        for (const rec of records) {
          for (const added of rec.addedNodes) {
            if (added.nodeType === 1 || added.nodeType === 3) pending.push(added);
          }
        }
        if (!queued && pending.length) {
          queued = true;
          queueMicrotask(flush);
        }
      });
      obs.observe(document.body, { childList: true, subtree: true });
    }

    // ─── Topbar notification bell ────────────────────────────────────
    // Every dashboard template ships <button class="bell" data-count="…">
    // with no click handler. Wire it to a lightweight popover with
    // recent in-game events: NEW open tickets + UNSEEN forum threads.
    //
    // Read-state lives in localStorage per-browser:
    //   hs_bell_seen_tickets_count → last open-ticket count the user
    //     dismissed; only ticket-count > this surfaces a notification.
    //   hs_bell_seen_threads → array of thread ids already viewed.
    // Click on an item marks it seen; "Mark all read" header button
    // marks everything currently shown.
    (function wireBell() {
      const bells = document.querySelectorAll('button.bell');
      if (!bells.length) return;

      // Per-locale labels for the popover chrome.
      const L = (() => {
        if (locale === 'hu') return {
          inbox: 'Postaláda', empty: 'Nincs új esemény.', loading: 'Betöltés…',
          markAll: 'Mind olvasottnak',
          ticketsTitle: function (n) { return n + ' nyitott ticket'; },
          ticketsNew: function (n) { return '+' + n + ' új ticket'; },
          ticketsSub: 'Triage egy shift-tel',
          threadFrom: function (name) { return 'tőle: ' + name; },
          unknownAuthor: 'ismeretlen',
        };
        if (locale === 'de') return {
          inbox: 'Posteingang', empty: 'Keine neuen Ereignisse.', loading: 'Lädt…',
          markAll: 'Alle als gelesen markieren',
          ticketsTitle: function (n) { return n + ' offene Tickets'; },
          ticketsNew: function (n) { return '+' + n + ' neue Tickets'; },
          ticketsSub: 'Mit einer Schicht abarbeiten',
          threadFrom: function (name) { return 'von: ' + name; },
          unknownAuthor: 'unbekannt',
        };
        return {
          inbox: 'Inbox', empty: 'No new activity.', loading: 'Loading…',
          markAll: 'Mark all read',
          ticketsTitle: function (n) { return n + ' open tickets'; },
          ticketsNew: function (n) { return '+' + n + ' new tickets'; },
          ticketsSub: 'Clear them with a shift',
          threadFrom: function (name) { return 'from: ' + name; },
          unknownAuthor: 'unknown',
        };
      })();

      function getSeenThreads() {
        try { return JSON.parse(localStorage.getItem('hs_bell_seen_threads') || '[]'); }
        catch { return []; }
      }
      function setSeenThreads(ids) {
        try { localStorage.setItem('hs_bell_seen_threads', JSON.stringify(ids.slice(-200))); }
        catch {}
      }
      function markThreadSeen(id) {
        const arr = getSeenThreads();
        if (!arr.includes(id)) { arr.push(id); setSeenThreads(arr); }
      }
      function getSeenTicketCount() {
        try { return parseInt(localStorage.getItem('hs_bell_seen_tickets_count') || '0', 10) || 0; }
        catch { return 0; }
      }
      function setSeenTicketCount(n) {
        try { localStorage.setItem('hs_bell_seen_tickets_count', String(n)); } catch {}
      }

      // The template CSS unconditionally renders a pink badge via
      // .bell::after { content: attr(data-count); }. Without this rule
      // a missing/empty data-count would still draw an empty pink dot
      // (padding+bg from the ::after rule). Suppress it when there's
      // nothing to show.
      if (!document.getElementById('bell-empty-style')) {
        const st = document.createElement('style');
        st.id = 'bell-empty-style';
        st.textContent = '.bell:not([data-count])::after,.bell[data-count=""]::after,.bell[data-count="0"]::after{display:none!important;}';
        document.head.appendChild(st);
      }

      function updateBadges(n) {
        bells.forEach((bell) => {
          if (n > 0) bell.setAttribute('data-count', String(n));
          else bell.removeAttribute('data-count');
        });
      }

      let popover = null;
      let listEl = null;
      let headRight = null;
      let lastItems = []; // snapshot for "Mark all read"

      function build() {
        if (popover) return popover;
        popover = document.createElement('div');
        popover.id = 'bell-popover';
        popover.style.cssText = 'position:fixed;top:64px;right:18px;width:320px;max-height:70vh;overflow-y:auto;background:var(--panel,#121626);border:1px solid var(--line-2,#262c46);border-radius:12px;box-shadow:0 18px 40px -10px rgba(0,0,0,.6);z-index:60;padding:8px;font-family:var(--body,sans-serif);font-size:13px;display:none;';
        const head = document.createElement('div');
        head.style.cssText = 'display:flex;align-items:center;gap:8px;padding:10px 12px;font-family:var(--mono,monospace);font-size:11px;color:var(--muted,#8b92ad);text-transform:uppercase;letter-spacing:0.08em;';
        const headTitle = document.createElement('span');
        headTitle.textContent = L.inbox;
        headTitle.style.cssText = 'flex:1;';
        headRight = document.createElement('button');
        headRight.type = 'button';
        headRight.textContent = L.markAll;
        headRight.style.cssText = 'background:transparent;border:0;color:var(--indigo,#818cf8);font-family:var(--mono,monospace);font-size:10px;letter-spacing:0.06em;cursor:pointer;padding:2px 4px;text-transform:uppercase;';
        headRight.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          // Mark every currently-listed item as seen.
          for (const it of lastItems) {
            if (it.onMark) it.onMark();
          }
          // Re-render to reflect the new empty state.
          void load();
        });
        head.appendChild(headTitle);
        head.appendChild(headRight);
        listEl = document.createElement('div');
        listEl.id = 'bell-list';
        listEl.style.cssText = 'padding:0 4px 4px;';
        const placeholder = document.createElement('div');
        placeholder.style.cssText = 'padding:14px 12px;color:var(--muted,#8b92ad);font-size:12px;';
        placeholder.textContent = L.loading;
        listEl.appendChild(placeholder);
        popover.appendChild(head);
        popover.appendChild(listEl);
        document.body.appendChild(popover);
        document.addEventListener('click', (e) => {
          const t = e.target;
          if (!popover.contains(t) && !Array.from(bells).some((b) => b.contains(t))) {
            popover.style.display = 'none';
          }
        });
        return popover;
      }

      async function load() {
        while (listEl.firstChild) listEl.removeChild(listEl.firstChild);
        const items = [];
        const seenTickets = getSeenTicketCount();
        const seenThreads = getSeenThreads();

        // ── Tickets: only surface if count grew past last-seen ──
        let currentOpen = 0;
        try {
          const r = await fetch('/api/game/state', { cache: 'no-store' });
          if (r.ok) {
            const j = await r.json();
            currentOpen = (j && j.counts && j.counts.openTickets) || 0;
          }
        } catch {}
        if (currentOpen > seenTickets) {
          const delta = currentOpen - seenTickets;
          // First-ever view: show full count. Subsequent: show delta.
          const title = seenTickets === 0 ? L.ticketsTitle(currentOpen) : L.ticketsNew(delta);
          const snapshotOpen = currentOpen;
          items.push({
            icon: '✉', title, sub: L.ticketsSub, href: '/play/tickets',
            onMark: () => setSeenTicketCount(snapshotOpen),
          });
        }

        // ── Threads: only un-seen ids ──
        try {
          const r = await fetch('/api/forum/threads?limit=10', { cache: 'no-store' });
          if (r.ok) {
            const j = await r.json();
            const threads = (j && j.threads) || [];
            for (const t of threads) {
              if (seenThreads.includes(t.id)) continue;
              items.push({
                icon: '💬',
                title: String(t.title || '').slice(0, 50),
                sub: L.threadFrom(t.author_name || L.unknownAuthor),
                href: '/play/community/' + t.id,
                onMark: ((id) => () => markThreadSeen(id))(t.id),
              });
              if (items.length >= 6) break;
            }
          }
        } catch {}

        lastItems = items;
        updateBadges(items.length);

        if (!items.length) {
          const empty = document.createElement('div');
          empty.style.cssText = 'padding:14px 12px;color:var(--muted,#8b92ad);font-size:12px;';
          empty.textContent = L.empty;
          listEl.appendChild(empty);
          return;
        }
        for (const it of items) {
          const a = document.createElement('a');
          a.href = it.href;
          a.style.cssText = 'display:flex;gap:10px;padding:10px 12px;border-radius:8px;text-decoration:none;color:var(--text,#e9ecf5);align-items:flex-start;';
          a.onmouseenter = () => { a.style.background = 'var(--panel-2,#161a2c)'; };
          a.onmouseleave = () => { a.style.background = ''; };
          // Click marks seen + closes popover. The browser navigation
          // still fires from the <a href>, no need to preventDefault.
          a.addEventListener('click', () => {
            if (it.onMark) it.onMark();
            if (popover) popover.style.display = 'none';
          });
          const icon = document.createElement('span');
          icon.style.cssText = 'font-size:16px;line-height:1.1;flex:none;';
          icon.textContent = it.icon;
          const txtWrap = document.createElement('span');
          txtWrap.style.cssText = 'flex:1;min-width:0;';
          const title = document.createElement('span');
          title.style.cssText = 'display:block;font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
          title.textContent = it.title;
          const sub = document.createElement('span');
          sub.style.cssText = 'display:block;color:var(--muted,#8b92ad);font-size:11px;margin-top:2px;';
          sub.textContent = it.sub;
          txtWrap.appendChild(title);
          txtWrap.appendChild(sub);
          a.appendChild(icon);
          a.appendChild(txtWrap);
          listEl.appendChild(a);
        }
      }

      bells.forEach((bell) => {
        bell.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const pop = build();
          if (pop.style.display === 'block') { pop.style.display = 'none'; return; }
          pop.style.display = 'block';
          void load();
        });
      });

      // Initial badge: silently fetch counts so the bell shows N right
      // away without waiting for a click. build() pre-initializes the
      // popover DOM (hidden) so load() has a valid listEl to clear.
      // Failure stays silent — badge just remains 0 / hidden.
      build();
      void load();
    })();
  })();
</script>
