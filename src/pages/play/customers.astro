d { display: flex; align-items: center; gap: 8px; }\n  .mem .head .tag {\n    font-family: var(--mono); font-size: 9px;\n    padding: 1px 6px; border-radius: 4px;\n    background: rgba(245,158,11,.15); color: var(--amber);\n    border: 1px solid rgba(245,158,11,.3);\n    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .mem .head .tag.pos { background: rgba(52,211,153,.12); color: var(--mint); border-color: rgba(52,211,153,.25); }\n  .mem .head .ago { margin-left: auto; font-family: var(--mono); font-size: 10px; color: var(--dim); }\n  .mem .text { margin-top: 6px; color: var(--text); line-height: 1.45; }\n  .mem .text em { font-style: normal; color: var(--amber); font-family: var(--mono); font-size: 11px; }\n\n  @media (max-width: 1100px) {\n    .layout { grid-template-columns: 1fr; }\n    .stats-row { grid-template-columns: repeat(2, 1fr); }\n    .twocol { grid-template-columns: 1fr; }\n    .col + .col { border-left: 0; border-top: 1px solid var(--line); }\n  }\n";
