n            <div class=\"pstat\"><div class=\"k\">Mood</div><div class=\"v bad\">−42</div><div class=\"meta\">3rd P1 ticket</div></div>\n            <div class=\"pstat\"><div class=\"k\">Churn risk</div><div class=\"v bad\">81%</div><div class=\"meta\">Forum risk: high</div></div>\n            <div class=\"pstat\"><div class=\"k\">Tickets</div><div class=\"v\">7</div><div class=\"meta\">5 closed · 2 open</div></div>\n          </div>\n\n          <div class=\"twocol\">\n            <!-- Chat -->\n            <div class=\"col\">\n              <h4 class=\"sec\">Conversation · last 24h</h4>\n              <div class=\"chat\">\n                <div class=\"msg\">\n                  <div class=\"av-mini av-K\">K</div>\n                  <div>\n                    <div class=\"bubble\">This is the THIRD time my checkout has 500'd this week. I have receipts and screenshots. I pay $19/mo. NINETEEN.</div>\n                    <div class=\"ts\">03:31 AM · Day 12</div>\n                  </div>\n                </div>\n                <div class=\"msg\">\n                  <div class=\"av-mini av-K\">K</div>\n                  <div>\n                    <div class=\"bubble recall\">⚲ persona memory recalled · \"you bumped my price Day 7 without notice\"</div>\n                    <div class=\"ts\">03:31 AM · auto-injected</div>\n                  </div>\n                </div>\n                <div class=\"msg me\">\n                  <div>\n                    <div class=\"bubble\">Karen, looking into U22 latency right now. I'll waive your invoice this month and patch the route. Sorry.</div>\n                    <div class=\"ts\">03:33 AM · you</div>\n                  </div>\n                  <div class=\"av-mini\">P</div>\n                </div>\n                <div class=\"msg\">\n                  <div class=\"av-mini av-K\">K</div>\n                  <div>\n                    <div class=\"bubble\">Patching the \"route\" doesn't bring back the 4 leads I lost. But fine. Waive this month and next, and I'll consider not posting on /r/budgethosting.</div>\n                    <div class=\"ts\">03:37 AM · Day 12</div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"reply\">\n                <textarea placeholder=\"Reply to Karen... (the LLM reads everything you say, forever)\"></textarea>\n                <div class=\"row\">\n                  <span class=\"ai\">✨ Lin-1 suggests: \"Two months waived, sincere apology, no spin.\"</span>\n                  <button class=\"btn sm\">Refund $19</button>\n                  <button class=\"btn sm primary send\">Send →</button>\n                </div>\n              </div>\n            </div>\n\n            <!-- Timeline + memory -->\n            <div class=\"col\">\n              <h4 class=\"sec\">Relationship timeline</h4>\n              <div class=\"tl\">\n                <div class=\"tl-ev good\">\n                  <div class=\"day\">Day 4</div>\n                  <div class=\"dot\"></div>\n                  <div>\n                    <div class=\"body\">Signed up via Marketplace listing</div>\n                    <small>Picked $19 Starter plan · auto-billed</small>\n                  </div>\n                </div>\n                <div class=\"tl-ev good\">\n                  <div class=\"day\">Day 5</div>\n                  <div class=\"dot\"></div>\n                  <div><div class=\"body\">First positive feedback</div><small>\"setup was actually easy, surprised\"</small></div>\n                </div>\n                <div class=\"tl-ev warn\">\n                  <div class=\"day\">Day 7</div>\n                  <div class=\"dot\"></div>\n                  <div><div class=\"body\">Price bump from $15→$19</div><small>Didn't email her first · she noticed</small></div>\n                </div>\n                <div class=\"tl-ev bad\">\n                  <div class=\"day\">Day 9</div>\n                  <div class=\"dot\"></div>\n                  <div><div class=\"body\">P1 ticket #018 · checkout 500</div><small>Resolved in 2h · she said \"noted\"</small></div>\n                </div>\n                <div class=\"tl-ev bad\">\n                  <div class=\"day\">Day 11</div>\n                  <div class=\"dot\"></div>\n                  <div><div class=\"body\">P1 ticket #029 · checkout 500 again</div><small>Resolved in 6h · cold reply</small></div>\n                </div>\n                <div class=\"tl-ev bad\">\n                  <div class=\"day\">Day 12</div>\n                  <div class=\"dot\"></div>\n                  <div><div class=\"body\">P1 ticket #042 · open now</div><small>Mentioned forum publicly · ⚠</small></div>\n                </div>\n              </div>\n\n              <h4 class=\"sec\" style=\"margin-top: 20px;\">Persona memory (LLM context)</h4>\n              <div class=\"mem-list\">\n                <div class=\"mem\">\n                  <div class=\"head\"><span class=\"tag\">grudge</span><span class=\"ago\">Day 7</span></div>\n                  <div class=\"text\">You bumped her plan from $15 to <em>$19/mo</em> without an email. She found out from the invoice.</div>\n                </div>\n                <div class=\"mem\">\n                  <div class=\"head\"><span class=\"tag\">pattern</span><span class=\"ago\">Day 9–12</span></div>\n                  <div class=\"text\">Three checkout 500s in 4 days. All on <em>U22</em>. She tracks errors in a spreadsheet.</div>\n                </div>\n                <div class=\"mem\">\n                  <div class=\"head\"><span class=\"tag pos\">leverage</span><span class=\"ago\">Day 12</span></div>\n                  <div class=\"text\">She has <em>4,200 followers</em> on a small SaaS newsletter. Forum thread risk is real.</div>\n                </div>\n                <div class=\"mem\">\n                  <div class=\"head\"><span class=\"tag pos\">soft spot</span><span class=\"ago\">Day 5</span></div>\n                  <div class=\"text\">She liked your setup flow. Lead with that if you apologize.</div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n        </section>\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscales — Customers</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
{customerCount === 0 && (
  <div id="customers-empty-cta" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--panel);border:1px solid var(--line-2);border-radius:16px;padding:32px;max-width:480px;text-align:center;z-index:50;">
    <div style="font-size:56px;margin-bottom:12px;">🌱</div>
    <h2 style="font-family:var(--display);font-size:22px;font-weight:700;margin:0 0 12px;">No customers yet</h2>
    <p style="color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:20px;">
      Customers come automatically as your servers attract traffic. Make sure you have at least one server
      and your marketing-mix is non-zero. Set your pricing to attract the type of customer you want.
    </p>
    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
      <a href="/play/servers" style="padding:8px 16px;background:var(--indigo);color:#fff;border-radius:8px;text-decoration:none;font-size:13px;font-weight:600;">Manage servers</a>
      <a href="/play/marketing" style="padding:8px 16px;background:var(--panel-2);color:var(--text);border:1px solid var(--line);border-radius:8px;text-decoration:none;font-size:13px;">Marketing mix</a>
    </div>
  </div>
)}
<script type="application/json" id="state" set:html={JSON.stringify({
    company: companyName, initials, founded, day: dayNum, era: player.current_era,
    cashUsd, mrrUsd, rep: player.reputation, customers: customerData,
  })}></script>

<script is:inline>
    try {
      const s = JSON.parse(document.getElementById('state').textContent);
      const crest = document.querySelector('.company-card .crest');
      if (crest) crest.textContent = s.initials;
      const cname = document.querySelector('.company-card .name');
      if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
      const csub = document.querySelector('.company-card .sub');
      if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
      const ts = document.querySelectorAll('.topbar-stats .tstat .v');
      if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
      if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
      if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
      const h1 = document.querySelector('.pagehead h1');
      if (h1) {
        const count = h1.querySelector('.count');
        if (h1.firstChild) h1.firstChild.textContent = 'Customers ';
        if (count) count.textContent = s.customers.length + ' active';
      }
      const PORTRAITS = {
        karen: '/img/persona-karen.webp',
        newbie: '/img/persona-loyalist.webp',
        pro: '/img/persona-pro.webp',
        cheapskate: '/img/persona-cheapskate.webp',
        ghost: '/img/persona-ghost.webp',
        loyalist: '/img/persona-loyalist.webp',
        drama: '/img/persona-drama.webp',
        crypto: '/img/persona-crypto.webp',
      };
      const planPriceCents = { hobby: 500, starter: 1900, standard: 2900, pro: 9900, enterprise: 49900 };

      // Re-render the profile panel for whichever customer is selected.
      // Called once on initial paint, then again on every row click — fixes
      // the "díísz?" bug where the cust-rows had cursor:pointer but no
      // click handler.
      function renderProfile(c) {
        const crumbs = document.querySelector('.crumbs span:last-child');
        if (crumbs) crumbs.textContent = c ? c.name : 'customers';
        if (!c) return;
        const profHead = document.querySelector('.prof-head');
        if (profHead) {
          const initial = (c.name[0] || '?').toUpperCase();
          const av = profHead.querySelector('.av');
          if (av) {
            av.textContent = initial;
            av.className = 'av av-' + initial;
            const portrait = PORTRAITS[c.persona] || '/img/persona-anon.webp';
            av.style.backgroundImage = 'url(' + portrait + ')';
            av.style.backgroundSize = 'cover';
            av.style.backgroundPosition = 'center';
            av.style.color = 'transparent';
          }
          const h2 = profHead.querySelector('h2');
          if (h2) {
            const pill = h2.querySelector('.pill');
            h2.textContent = c.name + ' ';
            if (pill) {
              pill.textContent = c.satisfaction < 30 ? '⚠ Churn risk' : c.satisfaction < 60 ? 'Watch' : 'Healthy';
              h2.appendChild(pill);
            }
          }
          const org = profHead.querySelector('.org');
          if (org) {
            org.replaceChildren();
            org.appendChild(document.createTextNode(c.plan + ' plan · LLM persona: '));
            const b = document.createElement('b');
            b.textContent = c.persona;
            org.appendChild(b);
          }
        }
        const stats = document.querySelectorAll('.stats-row .pstat');
        if (stats.length >= 5) {
          const mrrCents = planPriceCents[c.plan] || 0;
          stats[0].querySelector('.v').textContent = '$' + (mrrCents/100).toFixed(0);
          stats[0].querySelector('.meta').textContent = 'Plan: ' + c.plan;
          stats[1].querySelector('.v').textContent = '$' + c.ltv.toFixed(0);
          stats[1].querySelector('.v').className = 'v' + (c.ltv >= 50 ? ' good' : ' warn');
          stats[1].querySelector('.meta').textContent = 'Lifetime revenue';
          const moodDelta = c.satisfaction - 50;
          stats[2].querySelector('.v').textContent = (moodDelta > 0 ? '+' : '') + moodDelta;
          stats[2].querySelector('.v').className = 'v' + (moodDelta >= 20 ? ' good' : moodDelta < -10 ? ' bad' : ' warn');
          stats[2].querySelector('.meta').textContent = 'Satisfaction ' + c.satisfaction + '/100';
          const churn = Math.max(0, Math.min(100, 100 - c.satisfaction));
          stats[3].querySelector('.v').textContent = churn + '%';
          stats[3].querySelector('.v').className = 'v' + (churn >= 60 ? ' bad' : churn >= 30 ? ' warn' : ' good');
          stats[3].querySelector('.meta').textContent = c.satisfaction < 30 ? 'Forum risk' : 'Stable';
          stats[4].querySelector('.v').textContent = '—';
          stats[4].querySelector('.meta').textContent = 'See Tickets';
        }
        document.querySelectorAll('.twocol .col').forEach((col) => {
          col.replaceChildren();
          const note = document.createElement('div');
          note.style.cssText = 'padding:18px;color:var(--dim);font-family:var(--mono);font-size:11px;text-align:center;';
          note.textContent = 'Per-customer chat history + persona-memory comes online after first cron-tick LLM run.';
          col.appendChild(note);
        });
      }

      const list = document.querySelector('.cust-list');
      if (list && s.customers.length >= 0) {
        list.querySelectorAll('.cust-row').forEach(r => r.remove());
        if (s.customers.length === 0) {
          const empty = document.createElement('div');
          empty.style.padding = '24px';
          empty.style.color = 'var(--muted)';
          empty.textContent = 'No customers yet. Buy a server to attract them.';
          list.appendChild(empty);
        }
        s.customers.forEach((c, i) => {
          const initial = (c.name[0] || '?').toUpperCase();
          const row = document.createElement('div');
          row.className = 'cust-row' + (i === 0 ? ' selected' : '');
          const av = document.createElement('div');
          av.className = 'av av-' + initial;
          const portrait = PORTRAITS[c.persona] || '/img/persona-anon.webp';
          av.style.backgroundImage = 'url(' + portrait + ')';
          av.style.backgroundSize = 'cover';
          av.style.backgroundPosition = 'center';
          av.style.color = 'transparent';
          av.textContent = initial;
          const mid = document.createElement('div');
          const mname = document.createElement('div');
          mname.className = 'name';
          mname.textContent = c.name;
          const mmeta = document.createElement('div');
          mmeta.className = 'meta';
          mmeta.textContent = c.plan.toUpperCase() + ' · joined ' + c.joined;
          mid.appendChild(mname);
          mid.appendChild(mmeta);
          const right = document.createElement('div');
          right.className = 'right';
          const mrr = document.createElement('div');
          mrr.className = 'mrr';
          mrr.textContent = '$' + c.ltv.toFixed(0) + ' LTV';
          const mood = document.createElement('div');
          mood.className = 'mood ' + (c.satisfaction >= 60 ? 'good' : c.satisfaction >= 30 ? 'warn' : 'bad');
          mood.textContent = c.satisfaction + ' · ' + c.persona;
          right.appendChild(mrr);
          right.appendChild(mood);
          row.appendChild(av);
          row.appendChild(mid);
          row.appendChild(right);
          // Click to select — fixes "díísz?" bug.
          row.addEventListener('click', () => {
            list.querySelectorAll('.cust-row').forEach(r => r.classList.remove('selected'));
            row.classList.add('selected');
            renderProfile(c);
          });
          list.appendChild(row);
        });
      }

      renderProfile(s.customers[0]);

      // Day-counter
      const dayEl = document.querySelector('.clock .day');
      if (dayEl) {
        const small = dayEl.querySelector('small');
        dayEl.textContent = 'Day ' + s.day;
        if (small) { small.textContent = ' / 365'; dayEl.appendChild(small); }
      }

      // ─── DROP mock buttons ──────────────────────────────────────────
      // Profile-head action buttons (Refund $19 / Offer discount /
      // Reply to ticket #042) are hardcoded per-ticket-ID actions; not
      // wired to current customer state.
      document.querySelectorAll('.prof-actions .btn').forEach((b) => b.remove());
      // Pagehead "Export CSV" + "Invite customer" — not implemented.
      document.querySelectorAll('.pagehead .h-right .btn').forEach((b) => b.remove());
    } catch (e) { console.error('hydrate', e); }
  </script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
<DashboardAnims />
</body>
</html>
