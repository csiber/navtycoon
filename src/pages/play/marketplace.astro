---
// /play/marketplace — easy-v0.8: passive board of NPC + player listings.
// Phase 2 will add real transactions; this is read + post-your-own.
import Base from '../../layouts/Base.astro';
import { getCurrentUser, getDB } from '../../lib/auth';
import { listListings } from '../../lib/marketplace/db';

const user = await getCurrentUser(Astro);
if (!user) return Astro.redirect('/login?next=/play/marketplace');
const db = getDB(Astro);
const url = new URL(Astro.request.url);
const cat = url.searchParams.get('category');
const validCats = ['peering', 'hardware', 'service', 'leads'] as const;
const filter = (validCats as readonly string[]).includes(cat ?? '')
  ? (cat as typeof validCats[number])
  : undefined;
const listings = db ? await listListings(db, { category: filter, limit: 50 }) : [];

const CAT_LABELS_HU: Record<string, string> = {
  peering: 'Peering',
  hardware: 'Hardver',
  service: 'Szolgáltatás',
  leads: 'Keresett',
};
const UNIT_LABELS: Record<string, string> = {
  one_time: '',
  monthly: '/hó',
  per_gb: '/GB',
};

function timeAgo(ts: number): string {
  const sec = Math.floor(Date.now() / 1000) - ts;
  if (sec < 60) return 'most';
  if (sec < 3600) return `${Math.floor(sec / 60)}m`;
  if (sec < 86400) return `${Math.floor(sec / 3600)}ó`;
  return `${Math.floor(sec / 86400)}n`;
}
function formatPrice(cents: number, unit: string): string {
  if (cents === 0 && unit === 'one_time') return 'megegyezés szerint';
  if (unit === 'per_gb') return `$${(cents / 100).toFixed(4)}/GB`;
  const usd = cents / 100;
  const fmt = usd >= 100 ? usd.toFixed(0) : usd.toFixed(2);
  return `$${fmt}${UNIT_LABELS[unit] ?? ''}`;
}
function initial(name: string | null): string {
  return (name?.trim()[0] ?? '?').toUpperCase();
}
---
<Base title="Piactér">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-baseline justify-between mb-2">
      <div>
        <h1 class="text-3xl font-bold">Piactér</h1>
        <p class="text-nt-text-dim text-sm mt-1">
          Hirdetések NPC-ktől és valódi alapítóktól · {listings.length} aktív
        </p>
      </div>
      <button id="new-listing-btn"
              class="px-4 py-2 bg-nt-accent rounded font-semibold text-sm hover:opacity-90 transition">
        + Új hirdetés
      </button>
    </div>

    {/* Category filter */}
    <div class="flex flex-wrap gap-2 mt-4 mb-6">
      <a href="/play/marketplace"
         class={`px-3 py-1 rounded text-sm border transition ${!filter ? 'bg-nt-accent border-nt-accent text-white' : 'border-nt-border text-nt-text-dim hover:text-nt-text'}`}>
        Mind
      </a>
      {(['peering', 'hardware', 'service', 'leads'] as const).map((c) => (
        <a href={`/play/marketplace?category=${c}`}
           class={`px-3 py-1 rounded text-sm border transition ${filter === c ? 'bg-nt-accent border-nt-accent text-white' : 'border-nt-border text-nt-text-dim hover:text-nt-text'}`}>
          {CAT_LABELS_HU[c]}
        </a>
      ))}
    </div>

    {/* New-listing form (hidden by default) */}
    <form id="new-listing-form" class="hidden mt-4 mb-6 p-4 bg-nt-bg-2 border border-nt-border rounded-lg space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">Kategória</label>
          <select name="category" required
                  class="w-full px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none">
            <option value="peering">Peering</option>
            <option value="hardware">Hardver</option>
            <option value="service">Szolgáltatás</option>
            <option value="leads">Keresett</option>
          </select>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">Ár</label>
          <div class="flex gap-2">
            <input type="number" name="price_cents" min="0" max="99999999" placeholder="0"
                   class="flex-1 px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none" />
            <select name="price_unit"
                    class="px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none">
              <option value="one_time">egyszeri</option>
              <option value="monthly">havi</option>
              <option value="per_gb">/GB</option>
            </select>
          </div>
          <p class="text-xs text-nt-text-dim mt-1">cent-ben (pl. 9900 = $99). 0 = megegyezés szerint.</p>
        </div>
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">Cím</label>
        <input type="text" name="title" required minlength="4" maxlength="140"
               placeholder="pl. 1U Pentium 4 + 4GB RAM bérelhető"
               class="w-full px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none" />
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">Leírás</label>
        <textarea name="body" required minlength="4" maxlength="8000" rows="5"
                  placeholder="Specs, feltételek, kapcsolatfelvétel..."
                  class="w-full px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none resize-y"></textarea>
      </div>
      <div class="flex items-center gap-2">
        <button type="submit" class="px-4 py-2 bg-nt-accent rounded font-semibold text-sm hover:opacity-90 transition">
          Hirdetés posztolása
        </button>
        <button type="button" id="new-listing-cancel" class="px-4 py-2 text-nt-text-dim hover:text-nt-text text-sm transition">
          Mégse
        </button>
        <p id="new-listing-status" class="text-sm ml-auto" aria-live="polite"></p>
      </div>
    </form>

    {listings.length === 0 ? (
      <p class="mt-12 text-center text-nt-text-dim">
        Nincs hirdetés ebben a kategóriában. Tedd közzé az elsőt.
      </p>
    ) : (
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
        {listings.map((l) => (
          <article class="p-4 bg-nt-bg-2 border border-nt-border rounded-lg hover:border-nt-accent transition">
            <div class="flex items-start gap-3">
              <div class={`w-10 h-10 rounded-full flex-shrink-0 grid place-items-center text-sm font-bold ${l.is_npc ? 'bg-nt-bg' : 'bg-nt-accent text-white'}`}>
                {initial(l.author_name)}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-2 text-xs text-nt-text-dim mb-1 flex-wrap">
                  <span class="font-semibold text-nt-text">{l.author_name ?? 'unknown'}</span>
                  {l.author_city && <span>· {l.author_city}</span>}
                  {l.is_npc === 1 && l.npc_archetype && (
                    <span class="px-1.5 py-0.5 bg-nt-bg rounded text-[10px] uppercase tracking-wide">{l.npc_archetype.replace(/_/g, ' ')}</span>
                  )}
                  <span class="ml-auto">{timeAgo(l.posted_at)}</span>
                </div>
                <div class="flex items-baseline justify-between gap-2 mb-1">
                  <h3 class="font-semibold flex-1 min-w-0 truncate">{l.title}</h3>
                  <span class="text-nt-accent font-mono text-sm whitespace-nowrap">{formatPrice(l.price_cents, l.price_unit)}</span>
                </div>
                <p class="text-sm text-nt-text-dim line-clamp-3 whitespace-pre-wrap">{l.body}</p>
                <div class="mt-2 flex items-center gap-2 text-xs">
                  <span class="px-1.5 py-0.5 bg-nt-bg rounded text-nt-text-dim">{CAT_LABELS_HU[l.category]}</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>

  <script>
    const btn = document.getElementById('new-listing-btn');
    const form = document.getElementById('new-listing-form') as HTMLFormElement;
    const cancel = document.getElementById('new-listing-cancel');
    const status = document.getElementById('new-listing-status');

    btn?.addEventListener('click', () => {
      form.classList.remove('hidden');
      btn.classList.add('hidden');
    });
    cancel?.addEventListener('click', () => {
      form.classList.add('hidden');
      btn?.classList.remove('hidden');
      form.reset();
      if (status) status.textContent = '';
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      if (status) {
        status.textContent = 'Posztolás...';
        status.className = 'text-sm text-nt-text-dim ml-auto';
      }
      const r = await fetch('/api/marketplace/listings', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          category: fd.get('category'),
          title: fd.get('title'),
          body: fd.get('body'),
          price_cents: parseInt(String(fd.get('price_cents') ?? '0'), 10) || 0,
          price_unit: fd.get('price_unit'),
        }),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({} as { error?: string }));
        if (status) {
          status.textContent = 'Hiba: ' + ((j as { error?: string }).error ?? 'ismeretlen');
          status.className = 'text-sm text-red-400 ml-auto';
        }
        return;
      }
      location.reload();
    });
  </script>
</Base>
