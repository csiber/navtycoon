<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Marketplace</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Common: sidebar / topbar
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // Pagehead: real run stats instead of Plan-4 placeholder
    const phCount = document.querySelector('.pagehead .count');
    if (phCount) {
      const dayLabel = 'Day ' + s.day;
      const proPart = s.isPro
        ? (' · Pro' + (s.proUntil ? ' until ' + s.proUntil : ''))
        : '';
      phCount.textContent = s.company + ' · ' + dayLabel + ' · $' + s.mrrUsd + ' MRR' + proPart;
    }
    const phSub = document.querySelector('.pagehead .sub');
    if (phSub) {
      phSub.textContent = s.isPro
        ? 'Your run is live. Storefront-style listings + Stripe payments roll out in v0.8.'
        : 'Your storefront preview. Upgrade to Pro for boosted ranking + payment integration.';
    }

    // Compare bar — replace with player's MRR/cash
    const compareBar = document.querySelector('.compare-bar');
    if (compareBar) {
      const spans = compareBar.querySelectorAll('span');
      // The 5th span is "SyncNode $19/mo @ 99.61%" — point at real player
      spans.forEach(sp => {
        const t = sp.textContent || '';
        if (t.includes('SyncNode') || t.includes('@ 99.6')) {
          sp.textContent = s.company + ' · MRR $' + s.mrrUsd + ' · Day ' + s.day;
        }
      });
    }

    // Day-counter
    const dayEl = document.querySelector('.clock .day');
    if (dayEl) {
      const small = dayEl.querySelector('small');
      dayEl.textContent = 'Day ' + s.day;
      if (small) { small.textContent = ' / 365'; dayEl.appendChild(small); }
    }

    // The body of /play/marketplace (listings, leads-pipeline, forum-posts)
    // is 100% hardcoded mock referencing Karen/Devon/Mira and listings the
    // player has never created. Replace the .layout block with a single
    // "Marketplace v0.8" placeholder until real listings + leads ship.
    const layout = document.querySelector('.layout');
    if (layout) {
      layout.replaceChildren();
      const card = document.createElement('div');
      card.style.cssText = 'grid-column: span 12; padding: 60px 24px; text-align: center; background: var(--panel); border: 1px dashed var(--line-2); border-radius: 14px;';
      const icon = document.createElement('div');
      icon.style.cssText = 'font-size: 36px; opacity: 0.5; margin-bottom: 12px;';
      icon.textContent = '◈';
      const title = document.createElement('h3');
      title.style.cssText = 'margin: 0; font-family: var(--display); font-size: 18px; font-weight: 600;';
      title.textContent = 'Marketplace v0.8 — coming soon';
      const sub = document.createElement('p');
      sub.style.cssText = 'margin: 8px auto 0; max-width: 540px; color: var(--muted); font-size: 13px;';
      sub.textContent = 'Listings, lead-pipeline, and public-forum reactions ship in v0.8. For now the storefront pulls customers via the cron-tick + shift loop.';
      card.append(icon, title, sub);
      layout.appendChild(card);
    }
  } catch (e) { console.error('hydrate', e); }
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
<DashboardAnims />
</body>
</html>
