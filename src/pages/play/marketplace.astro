n  .post p { margin: 0; font-size: 13px; color: var(--muted); line-height: 1.55; }\n  .post p em { font-style: normal; color: var(--text); font-family: var(--mono); font-size: 12px;}\n  .post .react { margin-top: 8px; display: flex; gap: 12px; font-family: var(--mono); font-size: 11px; color: var(--dim); }\n  .post .react b { color: var(--text); }\n\n  /* Compare bar */\n  .compare-bar {\n    display: flex; align-items: center; gap: 10px;\n    padding: 10px 18px;\n    background: rgba(34,211,238,.06); border-bottom: 1px solid rgba(34,211,238,.2);\n    font-family: var(--mono); font-size: 11px; color: var(--cyan);\n  }\n  .compare-bar .v { color: var(--text); font-weight: 700; }\n  .compare-bar .arr { color: var(--mint); font-weight: 700; }\n  .compare-bar .actions { margin-left: auto; display: flex; gap: 6px; }\n\n  @media (max-width: 1100px) {\n    .layout { grid-template-columns: 1fr; }\n    .pipeline-grid { grid-template-columns: 1fr 1fr; }\n  }\n";
