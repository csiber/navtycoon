---
// /play/network -- TODO Plan 3: wire backend.
// Auth-gate only; static content from design template.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/network');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');
const pageCss = "\n  .lockwrap { grid-column: span 12; position: relative; }\n  .blur { filter: blur(3px) saturate(0.7); opacity: 0.5; pointer-events: none; user-select: none; }\n  .lock-overlay {\n    position: absolute; inset: 0; display: grid; place-items: center;\n    background: radial-gradient(ellipse at center, rgba(10,13,24,.7) 30%, rgba(10,13,24,.95) 80%); z-index: 10;\n  }\n  .lock-card {\n    width: min(560px, 90%);\n    background: var(--panel); border: 1px solid var(--line-2);\n    border-radius: 16px; padding: 32px; text-align: center;\n    box-shadow: 0 20px 60px rgba(0,0,0,.5);\n  }\n  .lock-card .badge {\n    display: inline-block; font-family: var(--mono); font-size: 11px;\n    padding: 5px 12px; border-radius: 999px;\n    background: rgba(34,211,238,.10); color: var(--cyan);\n    border: 1px solid rgba(34,211,238,.3);\n    text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700;\n    margin-bottom: 16px;\n  }\n  .lock-card h1 {\n    margin: 0 0 8px;\n    font-family: var(--display); font-size: 32px; font-weight: 700;\n    background: linear-gradient(135deg, var(--text), var(--cyan));\n    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;\n  }\n  .lock-card .sub { font-size: 15px; color: var(--muted); line-height: 1.55; max-width: 420px; margin: 0 auto 24px; }\n  .lock-card .requirements {\n    text-align: left; background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 10px; padding: 14px 16px; margin-bottom: 20px;\n  }\n  .lock-card .req {\n    display: grid; grid-template-columns: 24px 1fr auto;\n    align-items: center; gap: 10px; padding: 8px 0; font-size: 13px;\n  }\n  .lock-card .req + .req { border-top: 1px dashed var(--line); }\n  .lock-card .req .ck {\n    width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid var(--line-2);\n    display: grid; place-items: center; font-size: 11px; color: transparent;\n  }\n  .lock-card .req.done .ck { background: var(--mint); border-color: var(--mint); color: #07120c; }\n  .lock-card .req.done .lbl { color: var(--dim); text-decoration: line-through; }\n  .lock-card .req .progress { font-family: var(--mono); font-size: 11px; color: var(--cyan); font-weight: 700; }\n  .lock-card .cta-row { display: flex; gap: 10px; justify-content: center; }\n\n  /* Network preview */\n  .map-panel {\n    padding: 0; overflow: hidden;\n    background:\n      radial-gradient(circle at 50% 50%, rgba(34,211,238,.06), transparent 60%),\n      var(--panel);\n  }\n  .map-svg { width: 100%; height: 460px; display: block; }\n\n  .city-dot circle { fill: var(--mint); stroke: rgba(52,211,153,.3); }\n  .city-dot.lock circle { fill: var(--dim); stroke: var(--line-2); }\n  .city-dot.target circle { fill: var(--amber); stroke: rgba(245,158,11,.4); }\n  .city-dot text { fill: var(--text); font-family: var(--mono); font-size: 11px; font-weight: 700; }\n  .city-dot.lock text { fill: var(--dim); }\n  .city-dot.target text { fill: var(--amber); }\n\n  /* Peering & latency table */\n  .latency-grid {\n    display: grid; grid-template-columns: repeat(4, 1fr);\n    gap: 0;\n  }\n  .lat-cell {\n    padding: 14px 16px;\n    border-right: 1px solid var(--line);\n    border-bottom: 1px solid var(--line);\n  }\n  .lat-cell:last-child { border-right: 0; }\n  .lat-cell .city {\n    font-family: var(--display); font-size: 15px; font-weight: 600;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .lat-cell .city .flag {\n    font-family: var(--mono); font-size: 10px;\n    padding: 2px 6px; border-radius: 4px;\n    background: var(--panel-3); color: var(--muted);\n  }\n  .lat-cell .lat {\n    font-family: var(--display); font-size: 22px; font-weight: 700;\n    margin-top: 8px;\n  }\n  .lat-cell .lat.good { color: var(--mint); }\n  .lat-cell .lat.warn { color: var(--amber); }\n  .lat-cell .lat.bad { color: var(--pink); }\n  .lat-cell .lat small { font-size: 11px; color: var(--dim); font-family: var(--mono); font-weight: 400; }\n  .lat-cell .stats { margin-top: 8px; display: flex; gap: 10px; font-family: var(--mono); font-size: 11px; color: var(--dim); }\n  .lat-cell .stats b { color: var(--text); }\n\n  /* Peers table */\n  .peer-row {\n    display: grid; grid-template-columns: 1fr 100px 100px 80px 100px;\n    gap: 12px; padding: 12px 18px;\n    border-bottom: 1px solid var(--line);\n    font-size: 13px; align-items: center;\n  }\n  .peer-row.head {\n    background: var(--panel-2);\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;\n  }\n  .peer-row .name { font-weight: 600; }\n  .peer-row .asn { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-top: 2px; }\n  .peer-row .status {\n    font-family: var(--mono); font-size: 10px;\n    padding: 3px 8px; border-radius: 999px; text-align: center;\n    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .peer-row .status.up { background: rgba(52,211,153,.12); color: var(--mint); border: 1px solid rgba(52,211,153,.3); }\n  .peer-row .status.flap { background: rgba(245,158,11,.12); color: var(--amber); border: 1px solid rgba(245,158,11,.3); }\n  .peer-row .v { font-family: var(--mono); font-weight: 700; text-align: right; }\n";
const pageHtml = "\n<div class=\"app\">\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscaler</a>\n    <div class=\"company-card\">\n      <div class=\"row\"><div class=\"crest\">SN</div><div><div class=\"name\">SyncNode <span class=\"edit\">✎</span></div><div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div></div></div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> Dashboard</a>\n      <a class=\"nav-item\" href=\"/play/servers\"><span class=\"ico\">▤</span> Servers <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> Customers <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> Tickets <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> Finance</a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Grow</div>\n      <a class=\"nav-item\" href=\"/play/research\"><span class=\"ico\">⚙</span> Research <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> Marketplace</a>\n      <a class=\"nav-item locked\" href=\"/play/staff\"><span class=\"ico\">☰</span> Staff <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item active locked\"><span class=\"ico\">◴</span> Network <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> Leaderboard</a>\n      <a class=\"nav-item\" href=\"/play/devlog\"><span class=\"ico\">▶</span> Devlog</a>\n      <a class=\"nav-item\" href=\"/play/settings\"><span class=\"ico\">⚒</span> Settings</a>\n    </div>\n    <div class=\"side-foot\"><div>v0.7.2 · build 18,402</div><a href=\"#\">⌨ Shortcuts ⌘K</a><div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div></div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Play</span><span class=\"sep\">›</span><b>Network</b><span class=\"sep\">›</span><span style=\"color:var(--cyan)\">🔒 Era 2 required</span></div>\n      <div class=\"clock\"><div class=\"day\">Day 12<small> / 365</small></div><div class=\"time\">03:42 AM</div><div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div></div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Network <span class=\"count\">🔒 unlocks in Era 2 — Colocation</span></h1>\n          <div class=\"sub\">Peering, transit, regions, edge cache. Negotiate with other AS operators.</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">Read peering 101 →</button>\n        </div>\n      </div>\n\n      <div class=\"lockwrap\">\n\n        <div class=\"lock-overlay\">\n          <div class=\"lock-card\">\n            <div class=\"badge\">🔒 Era 2 — Colocation</div>\n            <h1>Build a real network</h1>\n            <p class=\"sub\">Buy IP space, get an ASN, negotiate peering with crusty IX operators (NPCs with grudges), and route traffic across regions.</p>\n            <div class=\"requirements\">\n              <div class=\"req\"><div class=\"ck\"></div><div class=\"lbl\">Lease colo cabinet</div><div class=\"progress\">0 / 1</div></div>\n              <div class=\"req\"><div class=\"ck\"></div><div class=\"lbl\">Buy /24 IPv4 block</div><div class=\"progress\">$220</div></div>\n              <div class=\"req\"><div class=\"ck\"></div><div class=\"lbl\">Get ASN through Era 2 quest</div><div class=\"progress\">locked</div></div>\n              <div class=\"req done\"><div class=\"ck\">✓</div><div class=\"lbl\">First customer signed</div><div class=\"progress\" style=\"color:var(--mint)\">3 / 1</div></div>\n            </div>\n            <div class=\"cta-row\">\n              <a class=\"btn\" href=\"/play/research\">Era 2 tech →</a>\n              <a class=\"btn primary\" href=\"/play\">Back to dashboard</a>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"blur\">\n          <section class=\"panel map-panel\" style=\"margin-bottom: 18px;\">\n            <div class=\"ph\">\n              <h3>Fleet map · global</h3>\n              <span class=\"ph-sub\">// 1 PoP live · 5 cities targeted</span>\n              <div class=\"ph-right\">\n                <span class=\"live\"><i></i>BUD · primary</span>\n              </div>\n            </div>\n            <svg class=\"map-svg\" viewBox=\"0 0 880 460\" preserveAspectRatio=\"xMidYMid meet\">\n              <!-- abstract world dot grid -->\n              <defs>\n                <pattern id=\"dots\" x=\"0\" y=\"0\" width=\"14\" height=\"14\" patternUnits=\"userSpaceOnUse\">\n                  <circle cx=\"2\" cy=\"2\" r=\"1\" fill=\"#1a1f33\"/>\n                </pattern>\n              </defs>\n              <rect x=\"0\" y=\"0\" width=\"880\" height=\"460\" fill=\"url(#dots)\"/>\n\n              <!-- continent silhouettes (simplified) -->\n              <g fill=\"#131726\" opacity=\"0.7\">\n                <!-- Europe -->\n                <path d=\"M 380 130 Q 410 110 440 120 Q 470 115 490 130 Q 510 145 500 170 Q 510 200 480 215 Q 450 230 420 220 Q 390 210 380 180 Z\"/>\n                <!-- N. America -->\n                <path d=\"M 90 130 Q 130 100 200 110 Q 260 105 290 140 Q 310 180 280 220 Q 230 250 170 230 Q 110 210 90 180 Z\"/>\n                <!-- Asia -->\n                <path d=\"M 550 110 Q 620 95 700 110 Q 760 130 770 170 Q 760 220 700 230 Q 620 245 560 220 Q 530 180 550 110 Z\"/>\n                <!-- S. America -->\n                <path d=\"M 240 280 Q 280 270 290 320 Q 300 380 260 400 Q 230 405 220 360 Q 215 310 240 280 Z\"/>\n                <!-- Africa -->\n                <path d=\"M 440 240 Q 490 235 500 290 Q 510 360 470 390 Q 430 395 425 340 Q 425 280 440 240 Z\"/>\n                <!-- Australia -->\n                <path d=\"M 700 320 Q 750 310 760 340 Q 755 370 720 375 Q 690 370 700 320 Z\"/>\n              </g>\n\n              <!-- Lines from BUD -->\n              <g stroke=\"#22d3ee\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" opacity=\"0.7\" fill=\"none\">\n                <path d=\"M 460 180 Q 350 130 200 160\"/>\n                <path d=\"M 460 180 Q 600 140 700 170\"/>\n                <path d=\"M 460 180 Q 430 110 410 80\"/>\n                <path d=\"M 460 180 Q 420 280 270 340\"/>\n              </g>\n\n              <!-- BUD live -->\n              <g class=\"city-dot\" transform=\"translate(460, 180)\">\n                <circle r=\"14\" fill=\"rgba(52,211,153,.15)\" stroke=\"none\"/>\n                <circle r=\"6\" stroke-width=\"2\"/>\n                <text x=\"12\" y=\"4\">BUD <tspan fill=\"#34d399\">· LIVE</tspan></text>\n                <text x=\"12\" y=\"18\" font-size=\"9\" fill=\"#7d869c\">1 rack · 2 srv</text>\n              </g>\n\n              <!-- Targets -->\n              <g class=\"city-dot target\" transform=\"translate(200, 160)\">\n                <circle r=\"6\" stroke-width=\"2\"/>\n                <text x=\"12\" y=\"4\">NYC</text>\n                <text x=\"12\" y=\"18\" font-size=\"9\" fill=\"#7d869c\">Era 2 target</text>\n              </g>\n              <g class=\"city-dot target\" transform=\"translate(410, 130)\">\n                <circle r=\"6\" stroke-width=\"2\"/>\n                <text x=\"12\" y=\"4\">FRA</text>\n                <text x=\"12\" y=\"18\" font-size=\"9\" fill=\"#7d869c\">peering ready</text>\n              </g>\n              <g class=\"city-dot lock\" transform=\"translate(700, 170)\">\n                <circle r=\"5\" stroke-width=\"2\"/>\n                <text x=\"10\" y=\"3\">SIN</text>\n              </g>\n              <g class=\"city-dot lock\" transform=\"translate(270, 340)\">\n                <circle r=\"5\" stroke-width=\"2\"/>\n                <text x=\"10\" y=\"3\">GRU</text>\n              </g>\n              <g class=\"city-dot lock\" transform=\"translate(470, 360)\">\n                <circle r=\"5\" stroke-width=\"2\"/>\n                <text x=\"10\" y=\"3\">JNB</text>\n              </g>\n              <g class=\"city-dot lock\" transform=\"translate(750, 350)\">\n                <circle r=\"5\" stroke-width=\"2\"/>\n                <text x=\"10\" y=\"3\">SYD</text>\n              </g>\n            </svg>\n          </section>\n\n          <section class=\"panel\" style=\"margin-bottom: 18px;\">\n            <div class=\"ph\"><h3>Latency map</h3><span class=\"ph-sub\">// p50 from your fleet</span></div>\n            <div class=\"latency-grid\">\n              <div class=\"lat-cell\">\n                <div class=\"city\">Budapest <span class=\"flag\">HU · primary</span></div>\n                <div class=\"lat good\">2.4 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>6.1</b></span><span>loss <b>0.0%</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">Frankfurt <span class=\"flag\">DE</span></div>\n                <div class=\"lat good\">14 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>22</b></span><span>via <b>DE-CIX</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">London <span class=\"flag\">UK</span></div>\n                <div class=\"lat warn\">38 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>61</b></span><span>via <b>transit</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">New York <span class=\"flag\">US</span></div>\n                <div class=\"lat warn\">94 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>120</b></span><span>via <b>Lumen</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">São Paulo <span class=\"flag\">BR</span></div>\n                <div class=\"lat bad\">210 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>260</b></span><span>loss <b>1.2%</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">Singapore <span class=\"flag\">SG</span></div>\n                <div class=\"lat bad\">182 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>240</b></span><span>via <b>Tata</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">Tokyo <span class=\"flag\">JP</span></div>\n                <div class=\"lat bad\">220 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>290</b></span><span>via <b>HE</b></span></div>\n              </div>\n              <div class=\"lat-cell\">\n                <div class=\"city\">Sydney <span class=\"flag\">AU</span></div>\n                <div class=\"lat bad\">298 ms<small> p50</small></div>\n                <div class=\"stats\"><span>p95 <b>360</b></span><span>via <b>Telstra</b></span></div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>Peering &amp; transit</h3>\n              <span class=\"ph-sub\">// AS-SYNCNODE · 4 active sessions</span>\n              <div class=\"ph-right\"><button class=\"btn sm primary\">＋ Open new BGP session</button></div>\n            </div>\n            <div class=\"peer-row head\">\n              <div>Peer</div><div>Type</div><div>Status</div><div>p95</div><div>Cost / 95th</div>\n            </div>\n            <div class=\"peer-row\">\n              <div><div class=\"name\">DE-CIX Frankfurt</div><div class=\"asn\">AS6695 · multilateral RS</div></div>\n              <div>Settlement-free</div>\n              <div class=\"status up\">UP</div>\n              <div class=\"v\">14 ms</div>\n              <div class=\"v\" style=\"color:var(--mint)\">$0</div>\n            </div>\n            <div class=\"peer-row\">\n              <div><div class=\"name\">Lumen (Level3)</div><div class=\"asn\">AS3356 · transit</div></div>\n              <div>Transit</div>\n              <div class=\"status up\">UP</div>\n              <div class=\"v\">62 ms</div>\n              <div class=\"v\">$1.40/Mbps</div>\n            </div>\n            <div class=\"peer-row\">\n              <div><div class=\"name\">Hurricane Electric</div><div class=\"asn\">AS6939 · transit (free for v6)</div></div>\n              <div>Transit · v6</div>\n              <div class=\"status flap\">FLAPPING</div>\n              <div class=\"v\" style=\"color:var(--amber)\">88 ms</div>\n              <div class=\"v\">$0.90/Mbps</div>\n            </div>\n            <div class=\"peer-row\">\n              <div><div class=\"name\">Cloudflare Anycast</div><div class=\"asn\">AS13335 · private peering</div></div>\n              <div>Private peer</div>\n              <div class=\"status up\">UP</div>\n              <div class=\"v\">2 ms</div>\n              <div class=\"v\" style=\"color:var(--mint)\">$0</div>\n            </div>\n          </section>\n        </div>\n      </div>\n\n    </div>\n  </main>\n</div>\n";
