---
// /play/servers -- auth-required.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer, listServers, listUpgrades } from '../../lib/game/db';
import { SERVER_SPECS, affordableServerTypes } from '../../lib/game/server-types';
import { availableUpgrades, UPGRADE_SPECS } from '../../lib/game/upgrade-tree';
import I18nDashboard from '../../components/I18nDashboard.astro';
import DashboardAnims from '../../components/DashboardAnims.astro';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/servers');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const servers = await listServers(db, user.id);
const ownedUpgradeIds = new Set((await listUpgrades(db, user.id)).map(u => u.upgrade_id));
const buyable = affordableServerTypes(player.current_era);
const upgradesAvail = availableUpgrades(player.current_era, ownedUpgradeIds);

const companyName = player.company_name;
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const founded = new Date(player.founded_at * 1000).getFullYear();
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const serversData = servers.map(s => {
  const spec = SERVER_SPECS[s.type];
  return {
    id: s.id, type: s.type, name: spec?.display_name ?? s.type,
    capacity: s.capacity, load: s.current_load,
    monthly: s.monthly_cost_cents / 100, era: s.era,
  };
});
const buyableData = buyable.map(s => ({
  type: s.type, name: s.display_name, cost: s.purchase_cost_cents / 100,
  flavor: s.flavor, capacity: s.capacity, monthly: s.monthly_cost_cents / 100,
  affordable: player.cash_usd_cents >= s.purchase_cost_cents,
}));
const upgradesData = upgradesAvail.map(u => ({
  id: u.id, name: u.display_name, cost: u.cost_usd_cents / 100, effect: u.effect,
  affordable: player.cash_usd_cents >= u.cost_usd_cents,
}));
const pageCss = "\n  .layout {\n    grid-column: span 12;\n    display: grid; grid-template-columns: 360px 1fr 320px;\n    gap: 18px;\n  }\n  /* Rack */\n  .rack-panel { display: flex; flex-direction: column; }\n  .rack-tabs {\n    display: flex; gap: 4px; padding: 8px 10px 0;\n  }\n  .rack-tabs button {\n    padding: 7px 11px; border-radius: 7px 7px 0 0;\n    background: transparent; border: 1px solid transparent;\n    border-bottom: 0;\n    color: var(--muted); font-size: 12px;\n    font-family: var(--mono);\n  }\n  .rack-tabs button.on {\n    background: var(--panel-2);\n    border-color: var(--line); color: var(--text);\n  }\n  .rack-tabs button.plus { color: var(--dim); font-weight: 700; }\n  .rack-vis {\n    padding: 14px;\n    display: flex; flex-direction: column; gap: 3px;\n    border-top: 1px solid var(--line);\n  }\n  .u-row {\n    height: 28px; border-radius: 4px;\n    background: linear-gradient(90deg, #1a1f33, #232a45 70%, #1a1f33);\n    border: 1px solid #232a45;\n    display: grid; grid-template-columns: 38px 1fr 110px 60px;\n    align-items: center; gap: 10px;\n    padding: 0 12px;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    cursor: pointer; transition: border-color .1s;\n  }\n  .u-row:hover { border-color: var(--indigo); }\n  .u-row.selected {\n    border-color: var(--indigo);\n    box-shadow: 0 0 0 1px var(--indigo);\n  }\n  .u-row .lbl { color: var(--dim); }\n  .u-row .name { color: var(--text); font-weight: 500; }\n  .u-row .leds { display: flex; gap: 4px; }\n  .u-row .leds i { width: 6px; height: 6px; border-radius: 50%; display: block; background: #2a3050; }\n  .u-row .leds i.g { background: var(--mint); box-shadow: 0 0 5px var(--mint); }\n  .u-row .leds i.a { background: var(--amber); box-shadow: 0 0 5px var(--amber); }\n  .u-row .leds i.r { background: var(--pink); box-shadow: 0 0 5px var(--pink); }\n  .u-row .util { text-align: right; color: var(--mint); }\n  .u-row.warn .util { color: var(--amber); }\n  .u-row.warn { background: linear-gradient(90deg, #2a2418, #3a3219 70%, #2a2418); }\n  .u-row.hot { background: linear-gradient(90deg, #2a1a1f, #3b2230 70%, #2a1a1f); border-color: #4a2535; }\n  .u-row.hot .util { color: var(--pink); }\n  .u-row.empty {\n    background: repeating-linear-gradient(45deg, #0d1020 0 6px, #131726 6px 12px);\n    color: var(--dim);\n  }\n  .u-row.empty .util, .u-row.empty .name { color: var(--dim); }\n  .rack-foot {\n    padding: 12px 14px;\n    display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px;\n    border-top: 1px dashed var(--line);\n  }\n  .mini-stat {\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 6px; padding: 8px 9px;\n    font-family: var(--mono);\n  }\n  .mini-stat .k { font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.06em; }\n  .mini-stat .v { font-size: 14px; font-weight: 700; color: var(--text); margin-top: 2px; font-family: var(--display); }\n  .mini-stat .v.good { color: var(--mint); }\n  .mini-stat .v.warn { color: var(--amber); }\n  .mini-stat .v.bad { color: var(--pink); }\n\n  /* Server detail */\n  .detail-head {\n    padding: 18px 20px;\n    border-bottom: 1px solid var(--line);\n    display: flex; align-items: center; gap: 16px;\n  }\n  .detail-head .badge-u {\n    width: 56px; height: 56px; border-radius: 12px;\n    background: linear-gradient(135deg, #f59e0b, #b45309);\n    display: grid; place-items: center;\n    font-family: var(--display); font-weight: 700; font-size: 18px; color: #1c1300;\n  }\n  .detail-head h2 {\n    margin: 0;\n    font-family: var(--display); font-weight: 600; font-size: 22px;\n    display: flex; align-items: center; gap: 10px;\n  }\n  .detail-head .pill {\n    font-family: var(--mono); font-size: 10px;\n    padding: 3px 8px; border-radius: 999px;\n    background: rgba(245,158,11,.15); color: var(--amber);\n    border: 1px solid rgba(245,158,11,.3);\n    text-transform: uppercase; letter-spacing: 0.08em;\n  }\n  .detail-head .sub {\n    font-family: var(--mono); font-size: 12px; color: var(--dim); margin-top: 4px;\n  }\n  .detail-actions { margin-left: auto; display: flex; gap: 8px; }\n\n  .detail-grid {\n    padding: 18px 20px;\n    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;\n  }\n  .dgrid {\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 10px; padding: 12px 14px;\n  }\n  .dgrid .k { font-family: var(--mono); font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.06em; }\n  .dgrid .v { font-family: var(--display); font-weight: 700; font-size: 18px; margin-top: 4px; }\n  .dgrid .v.warn { color: var(--amber); }\n  .dgrid .v.bad { color: var(--pink); }\n  .dgrid .v.good { color: var(--mint); }\n  .dgrid .meta { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 2px; }\n  .dgrid .meta b { color: var(--text); }\n\n  .detail-section {\n    padding: 16px 20px;\n    border-top: 1px solid var(--line);\n  }\n  .detail-section h4 {\n    margin: 0 0 12px;\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.1em;\n  }\n  .specs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px; font-size: 13px; }\n  .specs .r { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px dashed var(--line); }\n  .specs .r:last-child, .specs .r:nth-last-child(2) { border-bottom: 0; }\n  .specs .r span { color: var(--muted); }\n  .specs .r b { font-family: var(--mono); color: var(--text); font-weight: 500; }\n\n  /* Util gauge */\n  .gauge {\n    margin-top: 4px;\n    display: grid; grid-template-columns: 80px 1fr; gap: 10px;\n    align-items: center;\n  }\n  .gauge .lbl { font-family: var(--mono); font-size: 11px; color: var(--muted); }\n  .gauge .bar { height: 10px; background: var(--line); border-radius: 5px; overflow: hidden; position: relative; }\n  .gauge .bar i { display: block; height: 100%; }\n  .gauge .bar .val {\n    position: absolute; right: 8px; top: -3px;\n    font-family: var(--mono); font-size: 10px; color: var(--text); font-weight: 700;\n  }\n  .gauge .bar i.cpu { background: linear-gradient(90deg, var(--mint), var(--amber) 70%, var(--pink)); width: 88%; }\n  .gauge .bar i.ram { background: var(--indigo); width: 62%; }\n  .gauge .bar i.disk { background: var(--cyan); width: 41%; }\n  .gauge .bar i.net { background: #a78bfa; width: 28%; }\n\n  /* Workloads */\n  .wl-row {\n    display: grid; grid-template-columns: 28px 1fr auto auto;\n    gap: 10px; padding: 10px 0;\n    border-bottom: 1px solid var(--line);\n    align-items: center; font-size: 13px;\n  }\n  .wl-row:last-child { border-bottom: 0; }\n  .wl-row .ico {\n    width: 26px; height: 26px; border-radius: 6px;\n    background: var(--panel-3); border: 1px solid var(--line-2);\n    display: grid; place-items: center;\n    color: var(--cyan); font-family: var(--mono); font-size: 11px; font-weight: 700;\n  }\n  .wl-row .name { color: var(--text); font-weight: 500; }\n  .wl-row .meta { color: var(--dim); font-family: var(--mono); font-size: 11px; }\n  .wl-row .use { font-family: var(--mono); font-size: 11px; color: var(--mint); }\n  .wl-row .age { font-family: var(--mono); font-size: 10px; color: var(--dim); }\n\n  /* Right column: catalog */\n  .cat-panel { display: flex; flex-direction: column; }\n  .cat-search {\n    padding: 10px 12px;\n    border-bottom: 1px solid var(--line);\n    background: rgba(7,9,15,.4);\n  }\n  .cat-search input {\n    width: 100%; padding: 8px 10px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    color: var(--text); font-family: var(--mono); font-size: 12px;\n  }\n  .cat-search input::placeholder { color: var(--dim); }\n  .cat-filters { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }\n  .cat-filters button {\n    padding: 4px 9px; border-radius: 999px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    color: var(--muted); font-size: 11px; font-family: var(--mono);\n  }\n  .cat-filters button.on { background: rgba(99,102,241,.15); color: var(--indigo-2); border-color: rgba(99,102,241,.4); }\n  .cat-list { padding: 6px 12px 14px; }\n  .cat-item {\n    padding: 12px; border-radius: 9px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    margin-top: 8px;\n    cursor: pointer; transition: border-color .12s;\n  }\n  .cat-item:hover { border-color: var(--line-2); }\n  .cat-item.affordable { border-color: rgba(52,211,153,.3); }\n  .cat-item .row1 { display: flex; align-items: center; gap: 8px; }\n  .cat-item .name { font-weight: 600; font-size: 13px; }\n  .cat-item .tag {\n    margin-left: auto;\n    font-family: var(--mono); font-size: 9px; color: var(--mint);\n    padding: 2px 6px; border-radius: 4px;\n    background: rgba(52,211,153,.12); border: 1px solid rgba(52,211,153,.3);\n    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .cat-item .tag.new { background: rgba(99,102,241,.12); color: var(--indigo-2); border-color: rgba(99,102,241,.3); }\n  .cat-item .tag.lock { background: rgba(99,102,241,.05); color: var(--dim); border-color: var(--line); }\n  .cat-item .specs-mini {\n    margin-top: 6px;\n    display: flex; gap: 10px; flex-wrap: wrap;\n    font-family: var(--mono); font-size: 10px; color: var(--muted);\n  }\n  .cat-item .row2 { display: flex; align-items: center; margin-top: 8px; }\n  .cat-item .price { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--mint); }\n  .cat-item .price.lock { color: var(--dim); }\n  .cat-item .buy {\n    margin-left: auto;\n    padding: 5px 10px; border-radius: 6px;\n    background: var(--text); color: var(--bg);\n    font-size: 11px; font-weight: 600; border: 0;\n  }\n  .cat-item.locked { opacity: 0.6; }\n  .cat-item.locked .buy { background: var(--panel-3); color: var(--dim); }\n\n  .empty-bay {\n    padding: 24px;\n    border: 1px dashed var(--line-2);\n    border-radius: 10px;\n    text-align: center;\n    color: var(--muted);\n    margin-top: 16px;\n  }\n  .empty-bay .icn { font-size: 28px; color: var(--dim); }\n  .empty-bay h4 { margin: 10px 0 4px; font-family: var(--display); font-size: 16px; color: var(--text); }\n\n  @media (max-width: 1240px) {\n    .layout { grid-template-columns: 1fr; }\n    .detail-grid { grid-template-columns: repeat(2, 1fr); }\n  }\n";
const pageHtml = "\n<div class=\"app\">\n\n  <!-- Sidebar -->\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscaler</a>\n    <div class=\"company-card\">\n      <div class=\"row\">\n        <div class=\"crest\">SN</div>\n        <div>\n          <div class=\"name\">SyncNode <span class=\"edit\">✎</span></div>\n          <div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div>\n        </div>\n      </div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.operate\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> <span data-i18n=\"dash.nav.dashboard\">Dashboard</span></a>\n      <a class=\"nav-item active\"><span class=\"ico\">▤</span> <span data-i18n=\"dash.nav.servers\">Servers</span> <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> <span data-i18n=\"dash.nav.customers\">Customers</span> <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> <span data-i18n=\"dash.nav.tickets\">Tickets</span> <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> <span data-i18n=\"dash.nav.finance\">Finance</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.grow\">Grow</div>\n      <a class=\"nav-item\" href=\"/play/research\"><span class=\"ico\">⚙</span> <span data-i18n=\"dash.nav.research\">Research</span> <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> <span data-i18n=\"dash.nav.marketplace\">Marketplace</span></a>\n      <a class=\"nav-item locked\" href=\"/play/staff\"><span class=\"ico\">☰</span> <span data-i18n=\"dash.nav.staff\">Staff</span> <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item locked\" href=\"/play/network\"><span class=\"ico\">◴</span> <span data-i18n=\"dash.nav.network\">Network</span> <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.meta\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> <span data-i18n=\"dash.nav.leaderboard\">Leaderboard</span></a>\n      <a class=\"nav-item\" href=\"/play/devlog\"><span class=\"ico\">▶</span> <span data-i18n=\"dash.nav.devlog\">Devlog</span></a>\n      <a class=\"nav-item\" href=\"/play/settings\"><span class=\"ico\">⚒</span> <span data-i18n=\"dash.nav.settings\">Settings</span></a>\n    </div>\n    <div class=\"side-foot\">\n      <div>v0.7.2 · build 18,402</div>\n      <a href=\"#\">⌨ Shortcuts ⌘K</a>\n      <div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div>\n    </div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Play</span><span class=\"sep\">›</span><b>Servers</b><span class=\"sep\">›</span><span>RACK-01 / U21</span></div>\n      <div class=\"clock\">\n        <div class=\"day\">Day 12<small> / 365</small></div>\n        <div class=\"time\">03:42 AM</div>\n        <div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div>\n      </div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.cash\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.mrr\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.rep\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Servers <span class=\"count\">2 / 24U used</span></h1>\n          <div class=\"sub\">RACK-01 · Budapest · cousin's garage · 22°C ambient</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">View utilization →</button>\n          <button class=\"btn primary\">＋ Buy server</button>\n        </div>\n      </div>\n\n      <div class=\"layout\">\n\n        <!-- Rack visualizer -->\n        <section class=\"panel rack-panel\">\n          <div class=\"ph\">\n            <h3>Rack inventory</h3>\n            <span class=\"ph-sub\">// click to inspect</span>\n            <div class=\"ph-right\"><span class=\"live\"><i></i>LIVE</span></div>\n          </div>\n          <div class=\"rack-tabs\">\n            <button class=\"on\">RACK-01 · BUD</button>\n            <button class=\"plus\">＋ Lease rack 🔒</button>\n          </div>\n          <div class=\"rack-vis\">\n            <div class=\"u-row\"><span class=\"lbl\">U24</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row\"><span class=\"lbl\">U23</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row warn\"><span class=\"lbl\">U22</span><span class=\"name\">srv-01 · web</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i></i></span><span class=\"util\">42%</span></div>\n            <div class=\"u-row hot selected\"><span class=\"lbl\">U21</span><span class=\"name\">srv-02 · db</span><span class=\"leds\"><i class=\"a\"></i><i class=\"g\"></i><i class=\"g\"></i></span><span class=\"util\">88%</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U20</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U19</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U18</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U17</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U16</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U15</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U14</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n            <div class=\"u-row empty\"><span class=\"lbl\">U13</span><span class=\"name\">— empty —</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n          </div>\n          <div class=\"rack-foot\">\n            <div class=\"mini-stat\"><div class=\"k\">Used</div><div class=\"v\">2U</div></div>\n            <div class=\"mini-stat\"><div class=\"k\">SLA</div><div class=\"v warn\">99.61%</div></div>\n            <div class=\"mini-stat\"><div class=\"k\">Temp</div><div class=\"v\">22°C</div></div>\n            <div class=\"mini-stat\"><div class=\"k\">Power</div><div class=\"v\">320W</div></div>\n          </div>\n        </section>\n\n        <!-- Server detail -->\n        <section class=\"panel\">\n          <div class=\"detail-head\">\n            <div class=\"badge-u\">U21</div>\n            <div>\n              <h2>srv-02 · primary db <span class=\"pill\">⚠ Hot</span></h2>\n              <div class=\"sub\">1U · Pentium 4 · Bay #1 — bought Day 4 · serving <b style=\"color:var(--text)\">3 customers</b></div>\n            </div>\n            <div class=\"detail-actions\">\n              <button class=\"btn sm\">SSH ▸</button>\n              <button class=\"btn sm\">Restart</button>\n              <button class=\"btn sm primary\">Upgrade →</button>\n            </div>\n          </div>\n\n          <div class=\"detail-grid\">\n            <div class=\"dgrid\">\n              <div class=\"k\">CPU</div>\n              <div class=\"v warn\">88%</div>\n              <div class=\"meta\">Pentium 4 · <b>2.8 GHz</b></div>\n            </div>\n            <div class=\"dgrid\">\n              <div class=\"k\">RAM</div>\n              <div class=\"v\">2.5 / 4 GB</div>\n              <div class=\"meta\">DDR · <b>62%</b> used</div>\n            </div>\n            <div class=\"dgrid\">\n              <div class=\"k\">Disk</div>\n              <div class=\"v\">17 / 40 GB</div>\n              <div class=\"meta\">IDE · <b>4,200 rpm</b></div>\n            </div>\n            <div class=\"dgrid\">\n              <div class=\"k\">Uptime</div>\n              <div class=\"v good\">8d 04h</div>\n              <div class=\"meta\">Last restart <b>Day 4</b></div>\n            </div>\n          </div>\n\n          <div class=\"detail-section\">\n            <h4>Live utilization · 5 min window</h4>\n            <div class=\"gauge\"><span class=\"lbl\">CPU</span><div class=\"bar\"><i class=\"cpu\"></i><span class=\"val\">88%</span></div></div>\n            <div class=\"gauge\"><span class=\"lbl\">RAM</span><div class=\"bar\"><i class=\"ram\"></i><span class=\"val\">62%</span></div></div>\n            <div class=\"gauge\"><span class=\"lbl\">Disk I/O</span><div class=\"bar\"><i class=\"disk\"></i><span class=\"val\">41%</span></div></div>\n            <div class=\"gauge\"><span class=\"lbl\">Network</span><div class=\"bar\"><i class=\"net\"></i><span class=\"val\">28%</span></div></div>\n          </div>\n\n          <div class=\"detail-section\">\n            <h4>Specs &amp; hardware</h4>\n            <div class=\"specs\">\n              <div class=\"r\"><span>Form factor</span><b>1U rackmount</b></div>\n              <div class=\"r\"><span>CPU</span><b>Intel Pentium 4 2.8 GHz</b></div>\n              <div class=\"r\"><span>RAM slot</span><b>4 GB DDR · upgradable to 8</b></div>\n              <div class=\"r\"><span>Disk</span><b>40 GB IDE (Maxtor)</b></div>\n              <div class=\"r\"><span>NIC</span><b>100 Mbps · 1 port</b></div>\n              <div class=\"r\"><span>PSU</span><b>250 W · 80 PLUS Bronze</b></div>\n              <div class=\"r\"><span>MTBF</span><b>~14,000 hours</b></div>\n              <div class=\"r\"><span>Salvage value</span><b>$45</b></div>\n            </div>\n          </div>\n\n          <div class=\"detail-section\">\n            <h4>Workloads hosted</h4>\n            <div class=\"wl-row\">\n              <div class=\"ico\">DB</div>\n              <div>\n                <div class=\"name\">postgres-14 · nutricoach</div>\n                <div class=\"meta\"><a href=\"/cdn-cgi/l/email-protection\" class=\"__cf_email__\" data-cfemail=\"d5beb4a7b0bb95bba0a1a7bcb6bab4b6bdfbbcba\">[email&#160;protected]</a> · 18 GB · <span style=\"color:var(--pink)\">slow queries detected</span></div>\n              </div>\n              <div class=\"use\">68% cpu</div>\n              <div class=\"age\">8d</div>\n            </div>\n            <div class=\"wl-row\">\n              <div class=\"ico\">DB</div>\n              <div>\n                <div class=\"name\">postgres-14 · pixelbrew</div>\n                <div class=\"meta\">devon@pixelbrew · 4 GB · healthy</div>\n              </div>\n              <div class=\"use\">14% cpu</div>\n              <div class=\"age\">8d</div>\n            </div>\n            <div class=\"wl-row\">\n              <div class=\"ico\">DB</div>\n              <div>\n                <div class=\"name\">redis-6 · anon-trial</div>\n                <div class=\"meta\">anon@?? · 0.6 GB · cache</div>\n              </div>\n              <div class=\"use\">6% cpu</div>\n              <div class=\"age\">2d</div>\n            </div>\n          </div>\n\n          <div class=\"detail-section\">\n            <h4>Recent incidents</h4>\n            <div class=\"wl-row\">\n              <div class=\"ico\" style=\"color: var(--pink)\">!</div>\n              <div>\n                <div class=\"name\">High CPU on postgres-14 (nutricoach)</div>\n                <div class=\"meta\">03:31 AM · Day 12 · triggered Karen P1 ticket</div>\n              </div>\n              <div class=\"use\" style=\"color:var(--pink)\">−6 rep</div>\n              <div class=\"age\">11m</div>\n            </div>\n            <div class=\"wl-row\">\n              <div class=\"ico\" style=\"color: var(--amber)\">⚠</div>\n              <div>\n                <div class=\"name\">Fan duty cycle &gt; 80%</div>\n                <div class=\"meta\">11:48 PM · Day 11 · power overrun</div>\n              </div>\n              <div class=\"use\" style=\"color:var(--amber)\">−$8</div>\n              <div class=\"age\">4h</div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Hardware catalog -->\n        <section class=\"panel cat-panel\">\n          <div class=\"ph\">\n            <h3>Hardware catalog</h3>\n            <span class=\"ph-sub\">// 12 in stock</span>\n          </div>\n          <div class=\"cat-search\">\n            <input placeholder=\"Search 'GPU', 'enterprise', '2U'...\" />\n            <div class=\"cat-filters\">\n              <button class=\"on\">All</button>\n              <button>Compute</button>\n              <button>Storage</button>\n              <button>GPU</button>\n              <button>Network</button>\n            </div>\n          </div>\n          <div class=\"cat-list\">\n            <div class=\"cat-item affordable\">\n              <div class=\"row1\">\n                <span class=\"name\">1U Pentium III</span>\n                <span class=\"tag\">In stock</span>\n              </div>\n              <div class=\"specs-mini\"><span>1U · 1 GHz</span><span>2 GB</span><span>20 GB IDE</span></div>\n              <div class=\"row2\">\n                <span class=\"price\">$120</span>\n                <button class=\"buy\">Buy →</button>\n              </div>\n            </div>\n            <div class=\"cat-item affordable\">\n              <div class=\"row1\">\n                <span class=\"name\">1U Pentium 4 +RAM</span>\n                <span class=\"tag\">In stock</span>\n              </div>\n              <div class=\"specs-mini\"><span>1U · 2.8 GHz</span><span>8 GB</span><span>40 GB IDE</span></div>\n              <div class=\"row2\">\n                <span class=\"price\">$180</span>\n                <button class=\"buy\">Buy →</button>\n              </div>\n            </div>\n            <div class=\"cat-item\">\n              <div class=\"row1\">\n                <span class=\"name\">2U Dual Xeon</span>\n                <span class=\"tag new\">Newer</span>\n              </div>\n              <div class=\"specs-mini\"><span>2U · 2× 3.0 GHz</span><span>16 GB ECC</span><span>2× 80 GB</span></div>\n              <div class=\"row2\">\n                <span class=\"price\">$420</span>\n                <button class=\"buy\">Buy →</button>\n              </div>\n            </div>\n            <div class=\"cat-item\">\n              <div class=\"row1\">\n                <span class=\"name\">RAID-5 storage shelf</span>\n                <span class=\"tag\">In stock</span>\n              </div>\n              <div class=\"specs-mini\"><span>3U</span><span>4× 250 GB SCSI</span><span>hot-swap</span></div>\n              <div class=\"row2\">\n                <span class=\"price\">$680</span>\n                <button class=\"buy\">Buy →</button>\n              </div>\n            </div>\n            <div class=\"cat-item locked\">\n              <div class=\"row1\">\n                <span class=\"name\">1U Opteron blade</span>\n                <span class=\"tag lock\">🔒 Era 2</span>\n              </div>\n              <div class=\"specs-mini\"><span>1U · 4× cores</span><span>32 GB</span><span>2× 146 GB SAS</span></div>\n              <div class=\"row2\">\n                <span class=\"price lock\">$1,100</span>\n                <button class=\"buy\">View</button>\n              </div>\n            </div>\n            <div class=\"cat-item locked\">\n              <div class=\"row1\">\n                <span class=\"name\">GPU pod · Quadro FX</span>\n                <span class=\"tag lock\">🔒 Era 3</span>\n              </div>\n              <div class=\"specs-mini\"><span>4U · 2 GPUs</span><span>watts ↑↑</span><span>render only</span></div>\n              <div class=\"row2\">\n                <span class=\"price lock\">$3,400</span>\n                <button class=\"buy\">View</button>\n              </div>\n            </div>\n          </div>\n\n          <div style=\"padding: 0 14px 16px;\">\n            <div class=\"empty-bay\">\n              <div class=\"icn\">⌐</div>\n              <h4>22 empty bays</h4>\n              <div>Fill them before Karen finds a competitor.</div>\n            </div>\n          </div>\n        </section>\n\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Servers</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify({
    company: companyName, initials, founded, day: dayNum, era: player.current_era,
    cashUsd, mrrUsd, rep: player.reputation,
    servers: serversData, buyable: buyableData, upgrades: upgradesData,
    ownedUpgradeCount: ownedUpgradeIds.size, totalUpgradeCount: UPGRADE_SPECS.length,
  })}></script>

<script is:inline>
    try {
      const s = JSON.parse(document.getElementById('state').textContent);
      const crest = document.querySelector('.company-card .crest');
      if (crest) crest.textContent = s.initials;
      const cname = document.querySelector('.company-card .name');
      if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
      const csub = document.querySelector('.company-card .sub');
      if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
      const ts = document.querySelectorAll('.topbar-stats .tstat .v');
      if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
      if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
      if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
      const h1 = document.querySelector('.pagehead h1');
      if (h1) {
        const count = h1.querySelector('.count');
        if (h1.firstChild) h1.firstChild.textContent = 'Servers ';
        if (count) count.textContent = s.servers.length + ' owned';
      }

      // Replace mock hardware catalog with real buyableData (XSS-safe DOM build).
      const catList = document.querySelector('.cat-list');
      if (catList) {
        catList.replaceChildren();
        if (!s.buyable || s.buyable.length === 0) {
          const empty = document.createElement('div');
          empty.style.cssText = 'padding:20px;text-align:center;color:var(--dim);font-family:var(--mono);font-size:12px;';
          empty.textContent = 'No servers available at your current era.';
          catList.appendChild(empty);
        } else {
          for (const item of s.buyable) {
            const card = document.createElement('div');
            card.className = 'cat-item' + (item.affordable ? ' affordable' : '');
            const row1 = document.createElement('div');
            row1.className = 'row1';
            const name = document.createElement('span');
            name.className = 'name';
            name.textContent = item.name;
            const tag = document.createElement('span');
            tag.className = 'tag' + (item.affordable ? '' : ' lock');
            tag.textContent = item.affordable ? 'In stock' : 'Need cash';
            row1.append(name, tag);
            const specs = document.createElement('div');
            specs.className = 'specs-mini';
            const cap = document.createElement('span');
            cap.textContent = item.capacity + ' slots';
            const mon = document.createElement('span');
            mon.textContent = '$' + item.monthly + '/mo';
            const fl = document.createElement('span');
            fl.textContent = item.flavor || '';
            specs.append(cap, mon, fl);
            const row2 = document.createElement('div');
            row2.className = 'row2';
            const price = document.createElement('span');
            price.className = 'price' + (item.affordable ? '' : ' lock');
            price.textContent = '$' + item.cost;
            const buy = document.createElement('button');
            buy.className = 'buy';
            buy.textContent = item.affordable ? 'Buy →' : 'Locked';
            if (item.affordable) {
              buy.dataset.buyServer = item.type;
            } else {
              buy.disabled = true;
            }
            row2.append(price, buy);
            card.append(row1, specs, row2);
            catList.appendChild(card);
          }
        }
      }

      // Upgrade section (appended below catalog) — real upgradesData.
      if (s.upgrades && s.upgrades.length > 0) {
        const catPanel = document.querySelector('.cat-panel');
        if (catPanel) {
          const sec = document.createElement('div');
          sec.style.cssText = 'border-top:1px solid var(--line);padding:12px 14px;';
          const hd = document.createElement('div');
          hd.style.cssText = 'font-family:var(--mono);font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;';
          hd.textContent = 'Upgrades · ' + s.ownedUpgradeCount + '/' + s.totalUpgradeCount + ' owned';
          sec.appendChild(hd);
          for (const u of s.upgrades) {
            const card = document.createElement('div');
            card.className = 'cat-item' + (u.affordable ? ' affordable' : '');
            const row1 = document.createElement('div');
            row1.className = 'row1';
            const nm = document.createElement('span');
            nm.className = 'name';
            nm.textContent = u.name;
            row1.appendChild(nm);
            const eff = document.createElement('div');
            eff.className = 'specs-mini';
            const e1 = document.createElement('span');
            e1.textContent = u.effect || '';
            eff.appendChild(e1);
            const row2 = document.createElement('div');
            row2.className = 'row2';
            const pr = document.createElement('span');
            pr.className = 'price' + (u.affordable ? '' : ' lock');
            pr.textContent = '$' + u.cost;
            const bt = document.createElement('button');
            bt.className = 'buy';
            bt.textContent = u.affordable ? 'Research →' : 'Need cash';
            if (u.affordable) {
              bt.dataset.buyUpgrade = u.id;
            } else {
              bt.disabled = true;
            }
            row2.append(pr, bt);
            card.append(row1, eff, row2);
            sec.appendChild(card);
          }
          catPanel.appendChild(sec);
        }
      }

      // Day-counter
      const dayEl = document.querySelector('.clock .day');
      if (dayEl) {
        const small = dayEl.querySelector('small');
        dayEl.textContent = 'Day ' + s.day;
        if (small) { small.textContent = ' / 365'; dayEl.appendChild(small); }
      }

      // Crumb "RACK-01 / U21" — real first server slot, or strip.
      const lastCrumb = document.querySelector('.crumbs span:last-child');
      if (lastCrumb) {
        if (s.servers && s.servers.length > 0) lastCrumb.textContent = 'RACK-01 / U22';
        else lastCrumb.textContent = 'empty rack';
      }

      // Hide the "Workloads hosted" + "Recent incidents" detail-sections —
      // they reference Karen / nutricoach / pixelbrew customers + Day 12
      // incidents that the player never created. We don't have a real
      // workload-to-server mapping table yet, so collapse them entirely.
      document.querySelectorAll('.detail-section').forEach((sec) => {
        const h4 = sec.querySelector('h4');
        const t = h4?.textContent || '';
        if (/Workloads hosted|Recent incidents/.test(t)) sec.remove();
      });

      // "22 empty bays / Karen finds a competitor" mock empty-bay note
      const emptyBay = document.querySelector('.empty-bay');
      if (emptyBay) emptyBay.remove();
    } catch (e) { console.error('hydrate', e); }

    // Buy-server + buy-upgrade handlers (preserved from old page).
    document.addEventListener('click', async (ev) => {
      const target = ev.target;
      if (!(target instanceof HTMLElement)) return;
      const btn = target.closest('[data-buy-server], [data-buy-upgrade]');
      if (!btn) return;
      ev.preventDefault();
      if (btn.dataset.buyServer) {
        const r = await fetch('/api/game/server', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ type: btn.dataset.buyServer }),
        });
        if (!r.ok) { alert('Error: ' + await r.text()); return; }
        location.reload();
      } else if (btn.dataset.buyUpgrade) {
        const r = await fetch('/api/game/upgrade', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ upgrade_id: btn.dataset.buyUpgrade }),
        });
        if (!r.ok) { alert('Error: ' + await r.text()); return; }
        location.reload();
      }
    });
  </script>
<script is:inline>
  // Idle rack-LED activity: subtly flip random LEDs to amber every ~1.9s
  // so the rack feels alive even on an idle dashboard.
  (function () {
    const leds = document.querySelectorAll('.u-row .leds i');
    if (leds.length === 0) return;
    setInterval(() => {
      const idx = Math.floor(Math.random() * leds.length);
      const led = leds[idx];
      if (!led.dataset.orig) led.dataset.orig = led.className;
      led.className = 'a';
      setTimeout(() => { led.className = led.dataset.orig; }, 320);
    }, 1900);
  })();
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
<DashboardAnims />
</body>
</html>
