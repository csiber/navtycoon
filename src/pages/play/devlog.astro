---
// /play/devlog -- backend wiring complete.
// Real event-feed + recent upgrades + customer joins from D1.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';
import { UPGRADE_SPECS } from '../../lib/game/upgrade-tree';
import type { EventType, PersonaArchetype } from '../../lib/game/types';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/devlog');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

interface EventRow {
  id: number;
  event_type: EventType;
  data_json: string | null;
  spawned_at: number;
  resolved_at: number | null;
  outcome: 'positive' | 'neutral' | 'negative' | null;
}
const eventsRaw = (await db.prepare(
  'SELECT id, event_type, data_json, spawned_at, resolved_at, outcome FROM events ' +
  'WHERE player_id = ? ORDER BY spawned_at DESC LIMIT 20',
).bind(user.id).all<EventRow>()).results ?? [];

interface UpgradeJoinRow { upgrade_id: string; purchased_at: number }
const upgradesRaw = (await db.prepare(
  'SELECT upgrade_id, purchased_at FROM upgrades WHERE player_id = ? ORDER BY purchased_at DESC LIMIT 10',
).bind(user.id).all<UpgradeJoinRow>()).results ?? [];

interface CustomerJoinRow { name: string; persona_archetype: PersonaArchetype; joined_at: number }
const customerJoins = (await db.prepare(
  'SELECT name, persona_archetype, joined_at FROM customers WHERE player_id = ? ORDER BY joined_at DESC LIMIT 10',
).bind(user.id).all<CustomerJoinRow>()).results ?? [];

const upgradeMap = new Map(UPGRADE_SPECS.map(u => [u.id, u]));

function relTime(ts: number): string {
  const now = Math.floor(Date.now() / 1000);
  const diff = Math.max(0, now - ts);
  if (diff < 60) return diff + 's ago';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return Math.floor(diff / 86400) + 'd ago';
}

const eventEntries = eventsRaw.map(e => ({
  type: e.event_type,
  outcome: e.outcome ?? 'open',
  rel: relTime(e.spawned_at),
  resolved: !!e.resolved_at,
  data: e.data_json,
}));

const upgradeEntries = upgradesRaw.map(u => {
  const spec = upgradeMap.get(u.upgrade_id);
  return {
    id: u.upgrade_id,
    name: spec ? spec.display_name : u.upgrade_id,
    era: spec ? spec.era : 0,
    effect: spec ? spec.effect : '',
    rel: relTime(u.purchased_at),
  };
});

const customerEntries = customerJoins.map(c => ({
  name: c.name,
  archetype: c.persona_archetype,
  rel: relTime(c.joined_at),
}));

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  displayName,
  events: eventEntries,
  upgrades: upgradeEntries,
  customers: customerEntries,
  totalEvents: eventsRaw.length,
  totalUpgrades: upgradesRaw.length,
  totalCustomers: customerJoins.length,
};
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 1fr 320px; gap: 18px; }\n\n  /* Pinned post */\n  .pinned {\n    padding: 24px;\n    background:\n      radial-gradient(ellipse at top right, rgba(245,158,11,.12), transparent 60%),\n      var(--panel);\n    border-bottom: 1px solid var(--line);\n    position: relative;\n  }\n  .pin-tag {\n    position: absolute; top: 18px; right: 18px;\n    font-family: var(--mono); font-size: 10px;\n    padding: 4px 10px; border-radius: 999px;\n    background: rgba(245,158,11,.15); color: var(--amber);\n    border: 1px solid rgba(245,158,11,.3);\n    text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700;\n  }\n  .pinned .ver {\n    font-family: var(--mono); font-size: 11px; color: var(--cyan);\n    letter-spacing: 0.06em;\n  }\n  .pinned h2 {\n    margin: 4px 0 8px;\n    font-family: var(--display); font-size: 28px; font-weight: 700;\n    line-height: 1.15;\n  }\n  .pinned .meta {\n    display: flex; gap: 14px; font-family: var(--mono); font-size: 11px; color: var(--dim);\n    margin-bottom: 16px;\n  }\n  .pinned .meta b { color: var(--text); }\n  .pinned p { color: var(--muted); font-size: 14px; line-height: 1.6; margin: 0 0 10px; max-width: 720px; }\n  .pinned .highlights {\n    margin-top: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px;\n  }\n  .pinned .hl {\n    display: grid; grid-template-columns: 24px 1fr; gap: 10px;\n    padding: 8px 0; border-top: 1px dashed var(--line);\n    font-size: 13px;\n  }\n  .pinned .hl:nth-child(-n+2) { border-top: 0; }\n  .pinned .hl .pre {\n    font-family: var(--mono); font-size: 10px; font-weight: 700;\n    padding: 3px 6px; border-radius: 4px;\n    background: var(--panel-3); color: var(--mint);\n    height: fit-content;\n    text-transform: uppercase; letter-spacing: 0.06em;\n  }\n  .pinned .hl .pre.fix { color: var(--amber); }\n  .pinned .hl .pre.bal { color: var(--cyan); }\n  .pinned .hl .pre.brk { color: var(--pink); }\n  .pinned .actions { margin-top: 18px; display: flex; gap: 10px; }\n\n  /* Patch entries */\n  .patch {\n    padding: 22px 24px;\n    border-bottom: 1px solid var(--line);\n    display: grid; grid-template-columns: 140px 1fr;\n    gap: 28px;\n  }\n  .patch .gutter {\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n    text-align: right;\n    position: relative;\n  }\n  .patch .gutter .ver {\n    font-size: 14px; color: var(--text); font-weight: 700; display: block;\n  }\n  .patch .gutter .date { margin-top: 3px; }\n  .patch .gutter .tag {\n    display: inline-block;\n    font-size: 9px; padding: 2px 7px; border-radius: 4px;\n    margin-top: 6px;\n    background: var(--panel-3); color: var(--muted);\n    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .patch .gutter .tag.major { background: rgba(99,102,241,.15); color: var(--indigo-2); }\n  .patch .gutter .tag.hotfix { background: rgba(244,63,94,.15); color: var(--pink); }\n  .patch h3 {\n    margin: 0 0 6px;\n    font-family: var(--display); font-size: 19px; font-weight: 600;\n  }\n  .patch .author { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-bottom: 12px; }\n  .patch .author .ava {\n    display: inline-block; width: 18px; height: 18px; border-radius: 50%;\n    background: var(--indigo); color: #fff;\n    text-align: center; line-height: 18px; font-size: 10px; font-weight: 700;\n    margin-right: 6px; vertical-align: middle;\n  }\n  .patch ul { margin: 0; padding: 0; list-style: none; }\n  .patch li {\n    display: grid; grid-template-columns: 64px 1fr;\n    gap: 10px; padding: 5px 0;\n    font-size: 13px; color: var(--muted); line-height: 1.5;\n  }\n  .patch li b { color: var(--text); font-weight: 500; }\n  .patch li .pre {\n    font-family: var(--mono); font-size: 9px; font-weight: 700;\n    padding: 2px 6px; border-radius: 4px; height: fit-content; align-self: start;\n    text-transform: uppercase; letter-spacing: 0.06em; text-align: center;\n  }\n  .patch li .pre.new { background: rgba(52,211,153,.12); color: var(--mint); }\n  .patch li .pre.fix { background: rgba(245,158,11,.12); color: var(--amber); }\n  .patch li .pre.bal { background: rgba(34,211,238,.12); color: var(--cyan); }\n  .patch li .pre.brk { background: rgba(244,63,94,.12); color: var(--pink); }\n  .patch li .pre.lore { background: rgba(167,139,250,.12); color: #c4b5fd; }\n  .patch .reactions {\n    margin-top: 14px; display: flex; gap: 6px;\n  }\n  .patch .rx {\n    font-family: var(--mono); font-size: 11px;\n    padding: 4px 10px; border-radius: 999px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    color: var(--muted); display: inline-flex; gap: 4px; align-items: center;\n  }\n  .patch .rx b { color: var(--text); }\n  .patch .rx.hot { border-color: rgba(245,158,11,.3); }\n\n  /* Right: roadmap + community */\n  .road-item {\n    padding: 12px 16px;\n    border-bottom: 1px dashed var(--line);\n    font-size: 13px;\n    display: grid; grid-template-columns: 14px 1fr auto;\n    gap: 10px; align-items: center;\n  }\n  .road-item .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--dim); margin-top: 5px; }\n  .road-item.shipped .dot { background: var(--mint); }\n  .road-item.next .dot { background: var(--amber); box-shadow: 0 0 6px var(--amber); }\n  .road-item.later .dot { background: var(--line-2); }\n  .road-item .name { font-weight: 500; }\n  .road-item .name small { display: block; color: var(--dim); font-family: var(--mono); font-size: 10px; margin-top: 1px; }\n  .road-item .when {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.04em;\n  }\n  .road-item.shipped .when { color: var(--mint); }\n  .road-item.next .when { color: var(--amber); }\n\n  /* Discord-style card */\n  .discord {\n    padding: 16px;\n    background: linear-gradient(135deg, rgba(99,102,241,.12), rgba(34,211,238,.08));\n    border: 1px solid rgba(99,102,241,.2);\n    border-radius: 12px;\n    margin: 14px 16px;\n  }\n  .discord h4 {\n    margin: 0 0 4px;\n    font-family: var(--display); font-size: 15px;\n  }\n  .discord p {\n    margin: 0 0 12px;\n    font-size: 12px; color: var(--muted);\n  }\n  .discord .stats { display: flex; gap: 16px; font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 12px; }\n  .discord .stats b { color: var(--text); display: block; font-family: var(--display); font-size: 16px; font-weight: 700; }\n  .discord .btn-row { display: flex; gap: 6px; }\n\n  @media (max-width: 1100px) {\n    .layout { grid-template-columns: 1fr; }\n    .patch { grid-template-columns: 1fr; gap: 12px; }\n    .patch .gutter { text-align: left; }\n    .pinned .highlights { grid-template-columns: 1fr; }\n  }\n";
const pageHtml = "\n<div class=\"app\">\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscaler</a>\n    <div class=\"company-card\">\n      <div class=\"row\"><div class=\"crest\">SN</div><div><div class=\"name\">SyncNode <span class=\"edit\">✎</span></div><div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div></div></div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> Dashboard</a>\n      <a class=\"nav-item\" href=\"/play/servers\"><span class=\"ico\">▤</span> Servers <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> Customers <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> Tickets <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> Finance</a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Grow</div>\n      <a class=\"nav-item\" href=\"/play/research\"><span class=\"ico\">⚙</span> Research <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> Marketplace</a>\n      <a class=\"nav-item locked\" href=\"/play/staff\"><span class=\"ico\">☰</span> Staff <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item locked\" href=\"/play/network\"><span class=\"ico\">◴</span> Network <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> Leaderboard</a>\n      <a class=\"nav-item active\"><span class=\"ico\">▶</span> Devlog</a>\n      <a class=\"nav-item\" href=\"/play/settings\"><span class=\"ico\">⚒</span> Settings</a>\n    </div>\n    <div class=\"side-foot\"><div>v0.7.2 · build 18,402</div><a href=\"#\">⌨ Shortcuts ⌘K</a><div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div></div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Meta</span><span class=\"sep\">›</span><b>Devlog</b><span class=\"sep\">›</span><span>Patch notes, roadmap, community</span></div>\n      <div class=\"clock\"><div class=\"day\">Day 12<small> / 365</small></div><div class=\"time\">03:42 AM</div><div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div></div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Devlog <span class=\"count\">18 patches · 4 minor · 1 major this season</span></h1>\n          <div class=\"sub\">What we shipped. What we broke. What Karen is mad about this week.</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">RSS</button>\n          <button class=\"btn\">Subscribe</button>\n          <button class=\"btn primary\">Submit feedback →</button>\n        </div>\n      </div>\n\n      <div class=\"layout\">\n        <section class=\"panel\">\n\n          <!-- Pinned major release -->\n          <div class=\"pinned\">\n            <div class=\"pin-tag\">📌 Pinned · current</div>\n            <div class=\"ver\">v0.7 — \"Reputation Matters\"</div>\n            <h2>Reputation now actually affects who signs up.</h2>\n            <div class=\"meta\">\n              <span>Released <b>Day 0 of Season 3</b></span>\n              <span>Build <b>18,402</b></span>\n              <span>👥 <b>2,841</b> players online</span>\n              <span>💬 <b>412</b> comments</span>\n            </div>\n            <p>You asked: \"why does my 12-rep garage attract the same enterprise customers as paulwall?\" Fair. We rewrote the customer acquisition model so reputation, region, and price tier all bias the pool of leads you see in Marketplace. Karen is no longer guaranteed to find you.</p>\n            <p>Also: every NPC customer now remembers your past tickets across save files. Yes, Karen will hold a grudge. We're sorry. Continue reading the highlights ↓</p>\n            <div class=\"highlights\">\n              <div class=\"hl\"><span class=\"pre\">NEW</span><div><b>Public reputation page.</b> Every player has a /rep URL showing uptime, response time, last 10 reviews. Linkable in Marketplace.</div></div>\n              <div class=\"hl\"><span class=\"pre bal\">BAL</span><div><b>Customer churn tuned.</b> Loyal personas (Devon-type) tolerate 2 P2s/month; Karen-type tolerates none. Adjust your shift coverage.</div></div>\n              <div class=\"hl\"><span class=\"pre fix\">FIX</span><div><b>Ticket inbox no longer freezes</b> when 200+ tickets stack from a regional outage event. (Sorry, paulwall.)</div></div>\n              <div class=\"hl\"><span class=\"pre brk\">BRK</span><div><b>Pre-Season 3 saves migrate</b> on load. Old reputation numbers will shift up to ±20 to fit the new scale.</div></div>\n            </div>\n            <div class=\"actions\">\n              <button class=\"btn primary\">Read full notes ↗</button>\n              <button class=\"btn\">Watch dev stream (44 min)</button>\n              <button class=\"btn\">412 comments →</button>\n            </div>\n          </div>\n\n          <!-- Patch entries -->\n          <div class=\"patch\">\n            <div class=\"gutter\">\n              <span class=\"ver\">v0.7.2</span>\n              <div class=\"date\">Day 9 · 4 days ago</div>\n              <span class=\"tag hotfix\">Hotfix</span>\n            </div>\n            <div>\n              <h3>The \"Karen Spawn Rate\" hotfix</h3>\n              <div class=\"author\"><span class=\"ava\">M</span>by mira — Lead Sim · 11 commits</div>\n              <ul>\n                <li><span class=\"pre fix\">FIX</span><div>Karen-type customers were spawning at <b>3× the intended rate</b> for new players in Era 1. Tuned down to 0.4× until Day 30. New players, this is on us.</div></li>\n                <li><span class=\"pre bal\">BAL</span><div>Anon-trial customers now <b>cap at 2 per save</b> during Era 1 (was unlimited). Their abandoned servers were filling racks.</div></li>\n                <li><span class=\"pre fix\">FIX</span><div>Server temperature widget no longer reports <b>22°C</b> when the actual sim value is 31°C+. We were lying to you.</div></li>\n                <li><span class=\"pre new\">NEW</span><div>Pager sound effects now <b>respect system volume</b>. The pinned community thread \"PLEASE\" was heard.</div></li>\n              </ul>\n              <div class=\"reactions\">\n                <span class=\"rx hot\">🔥 <b>1.2k</b></span>\n                <span class=\"rx\">❤️ <b>418</b></span>\n                <span class=\"rx\">😭 <b>92</b> · \"thank you\"</span>\n                <span class=\"rx\">💬 <b>87</b></span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"patch\">\n            <div class=\"gutter\">\n              <span class=\"ver\">v0.7.1</span>\n              <div class=\"date\">Day 4 · 9 days ago</div>\n              <span class=\"tag\">Patch</span>\n            </div>\n            <div>\n              <h3>Marketplace polish &amp; new persona</h3>\n              <div class=\"author\"><span class=\"ava\" style=\"background:#34d399;color:#07120c\">D</span>by devon — Sim · 24 commits</div>\n              <ul>\n                <li><span class=\"pre new\">NEW</span><div>Meet <b>\"Mira\" enterprise persona.</b> Long sales cycle, asks compliance questions, signs $400+/mo if you have RAID and a backup story. Era 2+.</div></li>\n                <li><span class=\"pre new\">NEW</span><div>Marketplace lead detail page shows the <b>customer's last 3 horror stories</b> from their previous host. Read them, this is your due diligence.</div></li>\n                <li><span class=\"pre bal\">BAL</span><div>Forum reputation no longer regenerates passively; you have to <b>actually resolve tickets</b>. (You were just waiting it out, we noticed.)</div></li>\n                <li><span class=\"pre fix\">FIX</span><div>\"Cousin's garage\" rack no longer crashes during summer event when ambient temp &gt; 35°C. Now your fans just spin loud and bill you.</div></li>\n              </ul>\n              <div class=\"reactions\">\n                <span class=\"rx\">🔥 <b>740</b></span>\n                <span class=\"rx\">🚀 <b>331</b></span>\n                <span class=\"rx\">💬 <b>52</b></span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"patch\">\n            <div class=\"gutter\">\n              <span class=\"ver\">v0.7.0</span>\n              <div class=\"date\">Season start</div>\n              <span class=\"tag major\">Major</span>\n            </div>\n            <div>\n              <h3>Season 3 — \"Bare Metal Summer\" launch</h3>\n              <div class=\"author\"><span class=\"ava\" style=\"background:#a78bfa\">L</span>by lin — Game Director · 312 commits</div>\n              <ul>\n                <li><span class=\"pre new\">NEW</span><div><b>Era 1 redesign.</b> Garage Era now lasts 30 in-game days (was 14). More time to make mistakes before you matter.</div></li>\n                <li><span class=\"pre new\">NEW</span><div><b>AI-generated tickets</b> with persistent persona voices. Karen sounds like Karen across save files; she remembers your name.</div></li>\n                <li><span class=\"pre new\">NEW</span><div><b>Public reputation pages</b> at /rep/[your-handle]. Shareable. Shame is a feature.</div></li>\n                <li><span class=\"pre lore\">LORE</span><div>Background timeline event in Era 3: <b>\"The 2014 GPU Gold Rush.\"</b> NPCs reference it; some are still bitter.</div></li>\n                <li><span class=\"pre brk\">BRK</span><div>Save files from Season 2 will <b>migrate but not preserve leaderboard rank</b>. Fresh ladder.</div></li>\n              </ul>\n              <div class=\"reactions\">\n                <span class=\"rx hot\">🔥 <b>3.4k</b></span>\n                <span class=\"rx\">🚀 <b>1.1k</b></span>\n                <span class=\"rx\">😭 <b>208</b> · \"rank reset 😭\"</span>\n                <span class=\"rx\">💬 <b>892</b></span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"patch\">\n            <div class=\"gutter\">\n              <span class=\"ver\">v0.6.4</span>\n              <div class=\"date\">Last season</div>\n              <span class=\"tag\">Patch</span>\n            </div>\n            <div>\n              <h3>The \"stop spawning P1s at 3 AM\" patch</h3>\n              <div class=\"author\"><span class=\"ava\" style=\"background:#f59e0b;color:#1c1300\">K</span>by karen-dev (community) — 4 commits</div>\n              <ul>\n                <li><span class=\"pre bal\">BAL</span><div>P1 tickets now only spawn between <b>9 AM – 11 PM in-game time</b>. Off-hours go to P3.</div></li>\n                <li><span class=\"pre fix\">FIX</span><div>Pager intensity scaled by <b>customer mood</b>, not customer count. A happy whale is quieter than ten grumpy guppies.</div></li>\n                <li><span class=\"pre new\">NEW</span><div>\"Quiet hours\" toggle in Settings — for when you actually need to sleep IRL. Pages defer to a daily summary.</div></li>\n              </ul>\n              <div class=\"reactions\">\n                <span class=\"rx\">😴 <b>2.1k</b> · \"finally\"</span>\n                <span class=\"rx\">❤️ <b>540</b></span>\n              </div>\n            </div>\n          </div>\n\n          <div style=\"padding: 20px; text-align: center;\">\n            <button class=\"btn\">Load older patches (14 more) →</button>\n          </div>\n\n        </section>\n\n        <!-- Right column -->\n        <div style=\"display: flex; flex-direction: column; gap: 18px;\">\n\n          <section class=\"panel\">\n            <div class=\"ph\"><h3>Roadmap</h3><span class=\"ph-sub\">// next 90 days, ish</span></div>\n            <div class=\"road-item shipped\"><div class=\"dot\"></div><div class=\"name\">Reputation system overhaul<small>v0.7 · shipped</small></div><div class=\"when\">Done</div></div>\n            <div class=\"road-item shipped\"><div class=\"dot\"></div><div class=\"name\">\"Mira\" enterprise persona<small>v0.7.1 · shipped</small></div><div class=\"when\">Done</div></div>\n            <div class=\"road-item next\"><div class=\"dot\"></div><div class=\"name\">Async multiplayer raids<small>your fleet vs. another's, off-hours</small></div><div class=\"when\">v0.8 · soon</div></div>\n            <div class=\"road-item next\"><div class=\"dot\"></div><div class=\"name\">Era 4 — \"Hyperscale\" preview<small>private peering, custom silicon</small></div><div class=\"when\">v0.8 · soon</div></div>\n            <div class=\"road-item\"><div class=\"dot\"></div><div class=\"name\">BYO model — plug your API key<small>let your real Claude run support shifts</small></div><div class=\"when\">v0.9</div></div>\n            <div class=\"road-item\"><div class=\"dot\"></div><div class=\"name\">Steam Workshop · custom NPCs<small>upload your own customer persona</small></div><div class=\"when\">v0.9</div></div>\n            <div class=\"road-item later\"><div class=\"dot\"></div><div class=\"name\">Console port<small>controller-first UI overhaul</small></div><div class=\"when\">Later</div></div>\n            <div class=\"road-item later\"><div class=\"dot\"></div><div class=\"name\">Mod tools / tech tree editor<small>users have asked for this since closed alpha</small></div><div class=\"when\">Later</div></div>\n          </section>\n\n          <section class=\"panel\" style=\"padding-bottom: 4px;\">\n            <div class=\"ph\"><h3>Community</h3><span class=\"ph-sub\">// be loud, be helpful</span></div>\n            <div class=\"discord\">\n              <h4>💬 Hyperscaler Discord</h4>\n              <p>Devs hang in #devlog. Karen mains hang in #venting.</p>\n              <div class=\"stats\">\n                <div><b>14.2k</b>members</div>\n                <div><b>892</b>online</div>\n                <div><b>#42</b>channels</div>\n              </div>\n              <div class=\"btn-row\">\n                <button class=\"btn sm primary\">Join</button>\n                <button class=\"btn sm\">Open in browser</button>\n              </div>\n            </div>\n            <div style=\"padding: 0 16px 16px; display: flex; flex-direction: column; gap: 8px;\">\n              <a href=\"#\" class=\"btn\" style=\"text-align: left; justify-content: flex-start;\">🐦 /r/hyperscaler · 28k</a>\n              <a href=\"#\" class=\"btn\" style=\"text-align: left; justify-content: flex-start;\">🐤 @hyperscalerco · 41k</a>\n              <a href=\"#\" class=\"btn\" style=\"text-align: left; justify-content: flex-start;\">📺 Twitch: dev streams · Fri</a>\n              <a href=\"#\" class=\"btn\" style=\"text-align: left; justify-content: flex-start;\">🐛 Bug tracker · open issues 142</a>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\"><h3>From the devs</h3><span class=\"ph-sub\">// this week's drama</span></div>\n            <div style=\"padding: 14px 16px;\">\n              <div style=\"display:flex;gap:10px;align-items:center;margin-bottom:8px;\">\n                <div style=\"width:32px;height:32px;border-radius:50%;background:#a78bfa;display:grid;place-items:center;color:#fff;font-weight:700;font-size:12px;\">L</div>\n                <div>\n                  <div style=\"font-weight:600;font-size:13px;\">Lin (Game Director)</div>\n                  <div style=\"font-family:var(--mono);font-size:10px;color:var(--dim);\">replying to thread \"Karen is OP\"</div>\n                </div>\n              </div>\n              <p style=\"font-size:13px;color:var(--muted);line-height:1.55;margin:0;\">\"Karen is intentionally hard. She's the tutorial for the rest of the game. If you can keep her happy at $19/mo, you can keep anyone happy. We will not be nerfing Karen. We <b style=\"color:var(--text)\">might</b> nerf her spawn rate (we did). That's it.\"</p>\n            </div>\n          </section>\n\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Devlog</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Common: sidebar / topbar
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // Pagehead count
    const phCount = document.querySelector('.pagehead .count');
    if (phCount) {
      phCount.textContent = s.totalEvents + ' events · ' + s.totalUpgrades + ' upgrades · '
        + s.totalCustomers + ' customer joins';
    }
    const phSub = document.querySelector('.pagehead .sub');
    if (phSub) phSub.textContent = 'Your real timeline — events, upgrades, customer joins.';

    // Build dynamic feed: replace pinned + patches.
    const panel = document.querySelector('section.panel');
    if (panel) {
      // Pinned: show latest event or "no activity"
      const pinned = panel.querySelector('.pinned');
      if (pinned) {
        const ver = pinned.querySelector('.ver');
        const h2 = pinned.querySelector('h2');
        const metaSpans = pinned.querySelectorAll('.meta span b');
        const ps = pinned.querySelectorAll('p');
        if (s.events.length > 0) {
          const e0 = s.events[0];
          if (ver) ver.textContent = 'Event #' + (s.events.length) + ' · ' + e0.type;
          if (h2) h2.textContent = formatEventTitle(e0.type, e0.outcome);
          if (metaSpans[0]) metaSpans[0].textContent = 'Day ' + s.day;
          if (metaSpans[1]) metaSpans[1].textContent = e0.rel;
          if (metaSpans[2]) metaSpans[2].textContent = String(s.totalEvents);
          if (metaSpans[3]) metaSpans[3].textContent = String(s.totalUpgrades);
          if (ps[0]) ps[0].textContent = 'Latest activity from your save. ' +
            (e0.resolved ? 'Resolved (' + e0.outcome + ').' : 'Currently open.');
          if (ps[1]) ps[1].textContent = 'Below: full event-feed, upgrades purchased, and customer joins.';
        } else {
          if (ver) ver.textContent = 'No activity yet';
          if (h2) h2.textContent = 'Your devlog will fill as you play.';
          if (metaSpans[0]) metaSpans[0].textContent = 'Day ' + s.day;
          if (metaSpans[1]) metaSpans[1].textContent = '—';
          if (metaSpans[2]) metaSpans[2].textContent = '0';
          if (metaSpans[3]) metaSpans[3].textContent = '0';
          if (ps[0]) ps[0].textContent = 'No events spawned, no upgrades bought, no customers signed yet. Start a shift to see things move.';
          if (ps[1] && ps[1].parentNode) ps[1].parentNode.removeChild(ps[1]);
        }
        // Hide highlights row
        const hl = pinned.querySelector('.highlights');
        if (hl) hl.style.display = 'none';
        const actions = pinned.querySelector('.actions');
        if (actions) actions.style.display = 'none';
      }

      // Patch entries (4 in template) → replace with our 3 groups (events / upgrades / customers).
      const patches = panel.querySelectorAll('.patch');
      // Group 1: events
      if (patches[0]) renderPatch(patches[0], 'Event feed', 'last ' + s.events.length + ' events',
        s.events.length === 0 ? [{ pre: 'lore', text: 'No events yet — events spawn during shifts.' }] :
        s.events.map(e => ({
          pre: e.outcome === 'positive' ? 'new' : e.outcome === 'negative' ? 'brk' : 'lore',
          text: formatEventTitle(e.type, e.outcome) + ' · ' + e.rel + (e.resolved ? ' (' + e.outcome + ')' : ' (open)'),
        })));
      // Group 2: upgrades
      if (patches[1]) renderPatch(patches[1], 'Upgrades acquired', s.upgrades.length + ' total',
        s.upgrades.length === 0 ? [{ pre: 'fix', text: 'No upgrades purchased yet.' }] :
        s.upgrades.map(u => ({
          pre: 'new',
          text: u.name + ' (Era ' + u.era + ') · ' + u.rel + (u.effect ? ' — ' + u.effect : ''),
        })));
      // Group 3: customer joins
      if (patches[2]) renderPatch(patches[2], 'Customer joins', s.customers.length + ' tracked',
        s.customers.length === 0 ? [{ pre: 'lore', text: 'No customers have signed up yet.' }] :
        s.customers.map(c => ({
          pre: 'bal',
          text: c.name + ' · ' + c.archetype + '-type · ' + c.rel,
        })));
      // Group 4: hide
      if (patches[3]) patches[3].style.display = 'none';
    }

    function formatEventTitle(type, outcome) {
      const labels = {
        ddos_attempt: 'DDoS attempt',
        viral_blog: 'Viral blog post',
        electricity_spike: 'Electricity spike',
        recruit_ad: 'Recruit ad placed',
        intern_incident: 'Intern incident',
        dmca: 'DMCA notice',
        cooling_failure: 'Cooling failure',
        security_breach: 'Security breach',
      };
      return labels[type] || type;
    }
    function renderPatch(patch, title, sub, items) {
      const h3 = patch.querySelector('h3'); if (h3) h3.textContent = title;
      const author = patch.querySelector('.author');
      if (author) author.textContent = '// ' + sub;
      const gutterVer = patch.querySelector('.gutter .ver');
      if (gutterVer) gutterVer.textContent = title.split(' ')[0];
      const gutterDate = patch.querySelector('.gutter .date');
      if (gutterDate) gutterDate.textContent = 'Day ' + s.day;
      const gutterTag = patch.querySelector('.gutter .tag');
      if (gutterTag) gutterTag.textContent = 'Live';
      const ul = patch.querySelector('ul');
      if (ul) {
        // Clear and re-populate
        while (ul.firstChild) ul.removeChild(ul.firstChild);
        items.forEach(it => {
          const li = document.createElement('li');
          const pre = document.createElement('span');
          pre.className = 'pre ' + it.pre;
          pre.textContent = it.pre.toUpperCase();
          const div = document.createElement('div');
          div.textContent = it.text;
          li.appendChild(pre);
          li.appendChild(div);
          ul.appendChild(li);
        });
      }
      const rx = patch.querySelector('.reactions');
      if (rx) rx.style.display = 'none';
    }
  } catch (e) { console.error('hydrate', e); }
</script>
<div id="achievements-wrap" style="max-width: 1100px; margin: 24px auto; padding: 24px; background: var(--panel); border: 1px solid var(--line); border-radius: 12px;">
  <h3 style="font-family: var(--display); margin: 0 0 16px;">🏆 Achievements</h3>
  <div id="ach-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;"></div>
</div>
<script is:inline>
  (function () {
    var grid = document.getElementById('ach-grid');
    if (!grid) return;
    fetch('/api/game/achievements')
      .then(function (r) { return r.json(); })
      .then(function (j) {
        if (!j || !j.ok || !Array.isArray(j.achievements)) return;
        j.achievements.forEach(function (a) {
          var card = document.createElement('div');
          card.style.cssText = 'background:var(--panel-2);border:1px solid var(--line);border-radius:10px;padding:12px;opacity:' + (a.unlocked ? '1' : '.4') + ';';
          var head = document.createElement('div');
          head.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:6px;font-family:var(--display);font-weight:600;font-size:13px;';
          var emoji = document.createElement('span');
          emoji.style.fontSize = '20px';
          emoji.textContent = a.emoji || '';
          var title = document.createElement('span');
          title.textContent = a.title || '';
          head.appendChild(emoji);
          head.appendChild(title);
          if (a.unlocked) {
            var tag = document.createElement('span');
            tag.style.cssText = 'margin-left:auto;font-size:10px;background:var(--mint);color:#000;padding:1px 6px;border-radius:99px;';
            tag.textContent = 'UNLOCKED';
            head.appendChild(tag);
          }
          var desc = document.createElement('div');
          desc.style.cssText = 'color:var(--muted);font-size:12px;';
          desc.textContent = a.description || '';
          card.appendChild(head);
          card.appendChild(desc);
          grid.appendChild(card);
        });
      })
      .catch(function () {});
  })();
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
</body>
</html>
