x; top: 290px;\">\n              <div class=\"ico\">∿</div>\n              <div class=\"name\">Cron monitoring</div>\n              <div class=\"cost\"><span class=\"rp\">6 RP</span><span class=\"ttl\">18h</span></div>\n            </div>\n            <div class=\"node available\" style=\"left: 390px; top: 290px;\">\n              <div class=\"ico\">⎈</div>\n              <div class=\"name\">Backup tape rotation</div>\n              <div class=\"cost\"><span class=\"rp\">8 RP</span><span class=\"ttl\">1d</span></div>\n            </div>\n\n            <!-- Tier 3 -->\n            <div class=\"node locked\" style=\"left: 30px; top: 440px;\">\n              <div class=\"ico\">≣</div>\n              <div class=\"name\">RAID-5 storage</div>\n              <div class=\"cost\"><span class=\"rp\">10 RP</span><span class=\"ttl\">2d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 210px; top: 440px;\">\n              <div class=\"ico\">⚒</div>\n              <div class=\"name\">Postmortem culture</div>\n              <div class=\"cost\"><span class=\"rp\">12 RP</span><span class=\"ttl\">2d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 390px; top: 440px;\">\n              <div class=\"ico\">⚐</div>\n              <div class=\"name\">Status page</div>\n              <div class=\"cost\"><span class=\"rp\">8 RP</span><span class=\"ttl\">1d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 570px; top: 440px;\">\n              <div class=\"ico\">⌖</div>\n              <div class=\"name\">2nd power feed</div>\n              <div class=\"cost\"><span class=\"rp\">14 RP</span><span class=\"ttl\">3d</span></div>\n            </div>\n\n            <!-- Era 2 gate -->\n            <div class=\"node locked\" style=\"left: 300px; top: 565px; width: 220px; border-style: dashed;\">\n              <div class=\"ico\">🔒</div>\n              <div class=\"name\">ERA 2 · Colocation</div>\n              <div class=\"cost\"><b>Requires 4 Era 1 techs + $1,000</b></div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Detail + queue -->\n        <div style=\"display: flex; flex-direction: column; gap: 18px;\">\n\n          <section class=\"panel\">\n            <div class=\"det-head\">\n              <div class=\"ico-lg\" style=\"background: var(--amber); color: #1c1300;\">↺</div>\n              <h2>Auto-restart cron</h2>\n              <div class=\"cat\">Tier 1 · Reliability · in progress</div>\n            </div>\n            <div class=\"det-section\">\n              <h4>What it does</h4>\n              <p>Drops a <em>watchdog</em> on every server that resurrects crashed processes in &lt;15s. Trades a tiny bit of CPU for a lot of fewer 3 AM pages.</p>\n            </div>\n            <div class=\"det-section\">\n              <h4>Effects when complete</h4>\n              <div class=\"det-effects\">\n                <div class=\"effect\"><span class=\"pos\">▲ +35%</span><span class=\"lbl\">SLA on stateless workloads</span></div>\n                <div class=\"effect\"><span class=\"pos\">▲ +6</span><span class=\"lbl\">Customer mood (less downtime)</span></div>\n                <div class=\"effect\"><span class=\"pos\">−40%</span><span class=\"lbl\">P1 ticket rate (est.)</span></div>\n                <div class=\"effect\"><span class=\"neg\">▼ −2%</span><span class=\"lbl\">Average CPU available</span></div>\n              </div>\n            </div>\n            <div class=\"det-section\">\n              <h4>Cost &amp; time</h4>\n              <div class=\"det-cost\">\n                <div class=\"c\"><div class=\"k\">Research</div><div class=\"v rp\">4 RP</div></div>\n                <div class=\"c\"><div class=\"k\">Time left</div><div class=\"v ttl\">2h 14m</div></div>\n                <div class=\"c\"><div class=\"k\">Prereq</div><div class=\"v\" style=\"font-size:13px;\">Garage Eng. ✓</div></div>\n                <div class=\"c\"><div class=\"k\">Unlocks</div><div class=\"v\" style=\"font-size:13px;\">Cron Monitoring</div></div>\n              </div>\n            </div>\n            <div class=\"det-action\">\n              <button class=\"btn primary\">Boost research · $40 (-1h 30m)</button>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>Research queue</h3>\n              <span class=\"ph-sub\">// max 2 parallel · Era 1</span>\n            </div>\n            <div class=\"queue-list\">\n              <div class=\"queue-row\">\n                <div class=\"ico\">↺</div>\n                <div>\n                  <div class=\"name\">Auto-restart cron</div>\n                  <div class=\"pb\"><i style=\"width: 62%\"></i></div>\n                </div>\n                <div class=\"ttl\">2h 14m</div>\n              </div>\n              <div class=\"queue-row\" style=\"opacity: .55;\">\n                <div class=\"ico\" style=\"background: var(--panel-3); color: var(--dim); border: 1px dashed var(--line-2);\">＋</div>\n                <div>\n                  <div class=\"name\" style=\"color: var(--dim);\">Slot 2 — empty</div>\n                  <div class=\"pb\"></div>\n                </div>\n                <div class=\"ttl\" style=\"color: var(--dim);\">queue</div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>How to earn RP</h3>\n              <span class=\"ph-sub\">// Era 1</span>\n            </div>\n            <div style=\"padding: 12px 18px; display: flex; flex-direction: column; gap: 8px;\">\n              <div class=\"effect\"><span class=\"pos\">+2 RP</span><span class=\"lbl\">Resolve P1 ticket within SLA</span></div>\n              <div class=\"effect\"><span class=\"pos\">+5 RP</span><span class=\"lbl\">Write postmortem after outage</span></div>\n              <div class=\"effect\"><span class=\"pos\">+1 RP</span><span class=\"lbl\">Customer at mood &gt; 80 for 7 days</span></div>\n              <div class=\"effect\"><span class=\"pos\">+3 RP</span><span class=\"lbl\">Forum post compliments your SLA</span></div>\n            </div>\n          </section>\n        </div>\n\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Research</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Common: sidebar / topbar
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // Sidebar "Research X/Y" badge
    document.querySelectorAll('aside .nav-item').forEach(a => {
      const t = a.textContent || '';
      if (t.includes('Research')) {
        const b = a.querySelector('.badge');
        if (b) b.textContent = s.ownedCount + '/' + s.totalNodes;
      }
    });

    // Pagehead count
    const phCount = document.querySelector('.pagehead .count');
    if (phCount) {
      phCount.textContent = s.ownedCount + ' of ' + s.totalNodes + ' unlocked · '
        + s.availableCount + ' available now';
    }

    // Header points pill
    const points = document.querySelector('.tree-wrap .points b');
    if (points) points.textContent = String(s.availableCount);

    // Replace tree nodes — rebuild from spec list grouped by era.
    const tree = document.querySelector('.tree');
    if (tree) {
      // Remove existing nodes (keep SVG lines element).
      const existing = tree.querySelectorAll('.node');
      existing.forEach(n => n.parentNode && n.parentNode.removeChild(n));

      // Layout: 4 cols × N rows per era, era1 on top, era2 below
      const era1 = s.nodes.filter(n => n.era === 1);
      const era2 = s.nodes.filter(n => n.era === 2);
      const colX = [30, 210, 390, 570];
      const rowY1 = 16;
      const rowY2 = 145;
      const era1Row2Y = 290;

      function makeNode(n, x, y) {
        const el = document.createElement('div');
        el.className = 'node ' + (n.status === 'owned' ? 'acquired' : (n.status === 'available' ? 'available' : 'locked'));
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        const ico = document.createElement('div'); ico.className = 'ico'; ico.textContent = '⚙';
        const nm = document.createElement('div'); nm.className = 'name'; nm.textContent = n.name;
        const cost = document.createElement('div'); cost.className = 'cost';
        if (n.status === 'owned') {
          while (cost.firstChild) cost.removeChild(cost.firstChild);
          const b = document.createElement('b'); b.textContent = 'Acquired'; cost.appendChild(b);
        } else {
          const c = document.createElement('span'); c.textContent = '$' + n.costUsd;
          cost.appendChild(c);
          const e = document.createElement('span'); e.className = 'ttl'; e.textContent = 'Era ' + n.era;
          cost.appendChild(e);
        }
        el.appendChild(ico); el.appendChild(nm); el.appendChild(cost);
        el.title = n.effect + (n.prereq ? ' (req: ' + n.prereq + ')' : '');
        return el;
      }

      era1.slice(0, 4).forEach((n, i) => tree.appendChild(makeNode(n, colX[i], rowY1)));
      era1.slice(4, 8).forEach((n, i) => tree.appendChild(makeNode(n, colX[i], rowY2)));
      era2.slice(0, 4).forEach((n, i) => tree.appendChild(makeNode(n, colX[i], era1Row2Y)));
      era2.slice(4, 8).forEach((n, i) => tree.appendChild(makeNode(n, colX[i], era1Row2Y + 140)));
      era2.slice(8, 12).forEach((n, i) => tree.appendChild(makeNode(n, colX[i], era1Row2Y + 280)));

      tree.style.height = Math.max(600, era1Row2Y + 280 + 120) + 'px';
    }

    // Replace right-side detail panel with summary
    const detHead = document.querySelector('.det-head h2');
    if (detHead) detHead.textContent = 'Research overview';
    const detCat = document.querySelector('.det-head .cat');
    if (detCat) detCat.textContent = 'Era ' + s.era + ' · ' + s.ownedCount + ' owned';
    const detSections = document.querySelectorAll('.det-section');
    if (detSections[0]) {
      const p = detSections[0].querySelector('p');
      if (p) p.textContent = 'Click a node in the tree to acquire it (when you have the cash and prereqs).';
    }
    if (detSections[1]) {
      const eff = detSections[1].querySelector('.det-effects');
      if (eff) {
        while (eff.firstChild) eff.removeChild(eff.firstChild);
        const summary = [
          { lbl: 'Owned', val: s.ownedCount + ' / ' + s.totalNodes, pos: true },
          { lbl: 'Available now', val: String(s.availableCount), pos: s.availableCount > 0 },
          { lbl: 'Current Era', val: String(s.era), pos: true },
        ];
        summary.forEach(it => {
          const div = document.createElement('div'); div.className = 'effect';
          const sp = document.createElement('span'); sp.className = it.pos ? 'pos' : 'neg'; sp.textContent = it.val;
          const lb = document.createElement('span'); lb.className = 'lbl'; lb.textContent = it.lbl;
          div.appendChild(sp); div.appendChild(lb);
          eff.appendChild(div);
        });
      }
    }
  } catch (e) { console.error('hydrate', e); }
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
</body>
</html>
