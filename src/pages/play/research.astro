// /play/research -- backend wiring complete.
// Tech-tree state: which UPGRADE_SPECS are owned / available / locked per player.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer, listUpgrades } from '../../lib/game/db';
import { UPGRADE_SPECS } from '../../lib/game/upgrade-tree';
import I18nDashboard from '../../components/I18nDashboard.astro';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/research');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const owned = await listUpgrades(db, user.id);
const ownedIds = new Set(owned.map(u => u.upgrade_id));

const treeNodes = UPGRADE_SPECS.map(u => {
  let status: 'owned' | 'available' | 'locked' = 'locked';
  const prereqMet = !u.prereq || ownedIds.has(u.prereq);
  if (ownedIds.has(u.id)) status = 'owned';
  else if (prereqMet && u.era <= player.current_era) status = 'available';
  return {
    id: u.id,
    name: u.display_name,
    era: u.era,
    costUsd: (u.cost_usd_cents / 100).toFixed(0),
    effect: u.effect,
    status,
    prereq: u.prereq ?? null,
  };
});

const ownedCount = treeNodes.filter(n => n.status === 'owned').length;
const availableCount = treeNodes.filter(n => n.status === 'available').length;

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  displayName,
  nodes: treeNodes,
  ownedCount,
  availableCount,
  totalNodes: treeNodes.length,
};
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 1fr 340px; gap: 18px; }\n  .tree-wrap {\n    padding: 0; position: relative;\n    background:\n      radial-gradient(circle at 20% 30%, rgba(99,102,241,.04), transparent 60%),\n      radial-gradient(circle at 80% 70%, rgba(34,211,238,.04), transparent 60%);\n  }\n  .tree-wrap .header-pad { padding: 14px 18px; display: flex; align-items: center; gap: 14px; border-bottom: 1px solid var(--line); }\n  .tree-wrap h3 { margin: 0; font-family: var(--display); font-size: 17px; font-weight: 600; }\n  .tree-wrap .points {\n    margin-left: auto; display: flex; align-items: center; gap: 8px;\n    padding: 6px 12px; border-radius: 999px;\n    background: rgba(34,211,238,.10); border: 1px solid rgba(34,211,238,.3);\n    font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--cyan);\n  }\n  .tree-wrap .points b { font-family: var(--display); font-size: 16px; }\n  .tree-wrap .legend-row {\n    padding: 8px 18px; display: flex; gap: 14px;\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    border-bottom: 1px solid var(--line); background: var(--panel-2);\n    text-transform: uppercase; letter-spacing: 0.06em;\n  }\n  .tree-wrap .legend-row b { color: var(--text); font-weight: 700; }\n  .tree-wrap .legend-row span { display: flex; align-items: center; gap: 5px; }\n  .tree-wrap .legend-row i { display: inline-block; width: 10px; height: 10px; border-radius: 2px; }\n  .tree-wrap .legend-row i.av { background: var(--mint); }\n  .tree-wrap .legend-row i.un { background: var(--indigo); }\n  .tree-wrap .legend-row i.lk { background: var(--dim); }\n  .tree-wrap .legend-row i.rs { background: var(--amber); }\n\n  .tree {\n    position: relative; padding: 30px 18px 30px;\n    height: 600px;\n    overflow: auto;\n  }\n  .tree svg.lines {\n    position: absolute; inset: 0;\n    width: 100%; height: 100%;\n    pointer-events: none;\n  }\n  .node {\n    position: absolute;\n    width: 160px;\n    padding: 10px 12px;\n    border-radius: 11px;\n    background: var(--panel-2); border: 1.5px solid var(--line);\n    cursor: pointer;\n    transition: transform .12s, border-color .12s, box-shadow .12s;\n  }\n  .node:hover { transform: translateY(-1px); border-color: var(--line-2); }\n  .node .ico {\n    width: 26px; height: 26px; border-radius: 7px;\n    background: var(--panel-3); border: 1px solid var(--line-2);\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 12px; color: var(--text);\n    margin-bottom: 6px;\n  }\n  .node .name { font-weight: 600; font-size: 12.5px; line-height: 1.25; }\n  .node .cost {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    margin-top: 4px;\n    display: flex; gap: 8px;\n  }\n  .node .cost b { color: var(--text); font-weight: 700; }\n  .node .cost .rp { color: var(--cyan); }\n  .node .cost .ttl { color: var(--amber); }\n  .node.acquired {\n    border-color: rgba(52,211,153,.45);\n    background: linear-gradient(180deg, rgba(52,211,153,.10), var(--panel-2));\n  }\n  .node.acquired .ico { background: var(--mint); color: #07120c; border-color: var(--mint); }\n  .node.acquired::after {\n    content: \"✓\"; position: absolute; top: -6px; right: -6px;\n    width: 20px; height: 20px; border-radius: 50%;\n    background: var(--mint); color: #07120c;\n    font-weight: 700; font-size: 12px;\n    display: grid; place-items: center;\n    border: 2px solid var(--panel);\n  }\n  .node.researching {\n    border-color: rgba(245,158,11,.5);\n    background: linear-gradient(180deg, rgba(245,158,11,.10), var(--panel-2));\n    box-shadow: 0 0 0 1px rgba(245,158,11,.3);\n  }\n  .node.researching .ico { background: var(--amber); color: #1c1300; border-color: var(--amber); }\n  .node.researching .progress {\n    margin-top: 6px; height: 4px; background: var(--line); border-radius: 2px; overflow: hidden;\n  }\n  .node.researching .progress i {\n    display: block; height: 100%; background: var(--amber); width: 62%;\n  }\n  .node.available {\n    border-color: rgba(99,102,241,.45);\n    background: linear-gradient(180deg, rgba(99,102,241,.08), var(--panel-2));\n  }\n  .node.available .ico { background: var(--indigo); color: #fff; border-color: var(--indigo); }\n  .node.available:hover { box-shadow: 0 0 0 2px rgba(99,102,241,.3); }\n  .node.locked { opacity: 0.55; }\n  .node.locked .ico { color: var(--dim); }\n  .node.selected { box-shadow: 0 0 0 2px var(--text); border-color: var(--text); }\n\n  /* Detail sidebar */\n  .det-head { padding: 18px 18px 14px; border-bottom: 1px solid var(--line); }\n  .det-head .ico-lg {\n    width: 56px; height: 56px; border-radius: 14px;\n    background: var(--indigo); color: #fff;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 22px;\n    margin-bottom: 10px;\n  }\n  .det-head h2 { margin: 0; font-family: var(--display); font-size: 20px; font-weight: 600; }\n  .det-head .cat {\n    font-family: var(--mono); font-size: 10px; color: var(--indigo-2);\n    text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px;\n  }\n\n  .det-section { padding: 14px 18px; border-bottom: 1px solid var(--line); }\n  .det-section h4 { margin: 0 0 8px; font-family: var(--mono); font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.1em; }\n  .det-section p { margin: 0; font-size: 13px; line-height: 1.55; color: var(--muted); }\n  .det-section p em { font-style: normal; color: var(--text); font-family: var(--mono); }\n\n  .det-effects { display: flex; flex-direction: column; gap: 6px; }\n  .effect {\n    display: flex; align-items: center; gap: 8px;\n    padding: 7px 10px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    font-size: 12px;\n  }\n  .effect .pos { color: var(--mint); font-family: var(--mono); font-weight: 700; flex-shrink: 0; }\n  .effect .neg { color: var(--pink); font-family: var(--mono); font-weight: 700; flex-shrink: 0; }\n  .effect .lbl { color: var(--text); }\n\n  .det-cost {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;\n  }\n  .det-cost .c {\n    padding: 10px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 8px;\n  }\n  .det-cost .c .k { font-family: var(--mono); font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; }\n  .det-cost .c .v { font-family: var(--display); font-weight: 700; font-size: 18px; margin-top: 2px; }\n  .det-cost .c .v.rp { color: var(--cyan); }\n  .det-cost .c .v.ttl { color: var(--amber); }\n\n  .det-action { padding: 14px 18px; }\n  .det-action .btn { width: 100%; padding: 12px; font-size: 14px; }\n\n  /* Queue */\n  .queue-list { padding: 0; }\n  .queue-row {\n    display: grid; grid-template-columns: 32px 1fr auto; gap: 10px;\n    padding: 10px 18px;\n    border-bottom: 1px solid var(--line);\n    align-items: center;\n  }\n  .queue-row .ico {\n    width: 32px; height: 32px; border-radius: 8px;\n    background: var(--amber); color: #1c1300;\n    display: grid; place-items: center; font-family: var(--mono); font-weight: 700;\n  }\n  .queue-row .name { font-weight: 500; font-size: 13px; }\n  .queue-row .pb {\n    margin-top: 4px;\n    width: 100%; height: 4px; background: var(--line); border-radius: 2px; overflow: hidden;\n  }\n  .queue-row .pb i { display: block; height: 100%; background: var(--amber); }\n  .queue-row .ttl { font-family: var(--mono); font-size: 11px; color: var(--amber); font-weight: 700; }\n\n  @media (max-width: 1240px) { .layout { grid-template-columns: 1fr; } }\n";
