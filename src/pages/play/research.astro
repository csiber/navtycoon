---
// /play/research -- TODO Plan 3: wire backend.
// Auth-gate only; static content from design template.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/research');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 1fr 340px; gap: 18px; }\n  .tree-wrap {\n    padding: 0; position: relative;\n    background:\n      radial-gradient(circle at 20% 30%, rgba(99,102,241,.04), transparent 60%),\n      radial-gradient(circle at 80% 70%, rgba(34,211,238,.04), transparent 60%);\n  }\n  .tree-wrap .header-pad { padding: 14px 18px; display: flex; align-items: center; gap: 14px; border-bottom: 1px solid var(--line); }\n  .tree-wrap h3 { margin: 0; font-family: var(--display); font-size: 17px; font-weight: 600; }\n  .tree-wrap .points {\n    margin-left: auto; display: flex; align-items: center; gap: 8px;\n    padding: 6px 12px; border-radius: 999px;\n    background: rgba(34,211,238,.10); border: 1px solid rgba(34,211,238,.3);\n    font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--cyan);\n  }\n  .tree-wrap .points b { font-family: var(--display); font-size: 16px; }\n  .tree-wrap .legend-row {\n    padding: 8px 18px; display: flex; gap: 14px;\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    border-bottom: 1px solid var(--line); background: var(--panel-2);\n    text-transform: uppercase; letter-spacing: 0.06em;\n  }\n  .tree-wrap .legend-row b { color: var(--text); font-weight: 700; }\n  .tree-wrap .legend-row span { display: flex; align-items: center; gap: 5px; }\n  .tree-wrap .legend-row i { display: inline-block; width: 10px; height: 10px; border-radius: 2px; }\n  .tree-wrap .legend-row i.av { background: var(--mint); }\n  .tree-wrap .legend-row i.un { background: var(--indigo); }\n  .tree-wrap .legend-row i.lk { background: var(--dim); }\n  .tree-wrap .legend-row i.rs { background: var(--amber); }\n\n  .tree {\n    position: relative; padding: 30px 18px 30px;\n    height: 600px;\n    overflow: auto;\n  }\n  .tree svg.lines {\n    position: absolute; inset: 0;\n    width: 100%; height: 100%;\n    pointer-events: none;\n  }\n  .node {\n    position: absolute;\n    width: 160px;\n    padding: 10px 12px;\n    border-radius: 11px;\n    background: var(--panel-2); border: 1.5px solid var(--line);\n    cursor: pointer;\n    transition: transform .12s, border-color .12s, box-shadow .12s;\n  }\n  .node:hover { transform: translateY(-1px); border-color: var(--line-2); }\n  .node .ico {\n    width: 26px; height: 26px; border-radius: 7px;\n    background: var(--panel-3); border: 1px solid var(--line-2);\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 12px; color: var(--text);\n    margin-bottom: 6px;\n  }\n  .node .name { font-weight: 600; font-size: 12.5px; line-height: 1.25; }\n  .node .cost {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    margin-top: 4px;\n    display: flex; gap: 8px;\n  }\n  .node .cost b { color: var(--text); font-weight: 700; }\n  .node .cost .rp { color: var(--cyan); }\n  .node .cost .ttl { color: var(--amber); }\n  .node.acquired {\n    border-color: rgba(52,211,153,.45);\n    background: linear-gradient(180deg, rgba(52,211,153,.10), var(--panel-2));\n  }\n  .node.acquired .ico { background: var(--mint); color: #07120c; border-color: var(--mint); }\n  .node.acquired::after {\n    content: \"✓\"; position: absolute; top: -6px; right: -6px;\n    width: 20px; height: 20px; border-radius: 50%;\n    background: var(--mint); color: #07120c;\n    font-weight: 700; font-size: 12px;\n    display: grid; place-items: center;\n    border: 2px solid var(--panel);\n  }\n  .node.researching {\n    border-color: rgba(245,158,11,.5);\n    background: linear-gradient(180deg, rgba(245,158,11,.10), var(--panel-2));\n    box-shadow: 0 0 0 1px rgba(245,158,11,.3);\n  }\n  .node.researching .ico { background: var(--amber); color: #1c1300; border-color: var(--amber); }\n  .node.researching .progress {\n    margin-top: 6px; height: 4px; background: var(--line); border-radius: 2px; overflow: hidden;\n  }\n  .node.researching .progress i {\n    display: block; height: 100%; background: var(--amber); width: 62%;\n  }\n  .node.available {\n    border-color: rgba(99,102,241,.45);\n    background: linear-gradient(180deg, rgba(99,102,241,.08), var(--panel-2));\n  }\n  .node.available .ico { background: var(--indigo); color: #fff; border-color: var(--indigo); }\n  .node.available:hover { box-shadow: 0 0 0 2px rgba(99,102,241,.3); }\n  .node.locked { opacity: 0.55; }\n  .node.locked .ico { color: var(--dim); }\n  .node.selected { box-shadow: 0 0 0 2px var(--text); border-color: var(--text); }\n\n  /* Detail sidebar */\n  .det-head { padding: 18px 18px 14px; border-bottom: 1px solid var(--line); }\n  .det-head .ico-lg {\n    width: 56px; height: 56px; border-radius: 14px;\n    background: var(--indigo); color: #fff;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 22px;\n    margin-bottom: 10px;\n  }\n  .det-head h2 { margin: 0; font-family: var(--display); font-size: 20px; font-weight: 600; }\n  .det-head .cat {\n    font-family: var(--mono); font-size: 10px; color: var(--indigo-2);\n    text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px;\n  }\n\n  .det-section { padding: 14px 18px; border-bottom: 1px solid var(--line); }\n  .det-section h4 { margin: 0 0 8px; font-family: var(--mono); font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.1em; }\n  .det-section p { margin: 0; font-size: 13px; line-height: 1.55; color: var(--muted); }\n  .det-section p em { font-style: normal; color: var(--text); font-family: var(--mono); }\n\n  .det-effects { display: flex; flex-direction: column; gap: 6px; }\n  .effect {\n    display: flex; align-items: center; gap: 8px;\n    padding: 7px 10px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    font-size: 12px;\n  }\n  .effect .pos { color: var(--mint); font-family: var(--mono); font-weight: 700; flex-shrink: 0; }\n  .effect .neg { color: var(--pink); font-family: var(--mono); font-weight: 700; flex-shrink: 0; }\n  .effect .lbl { color: var(--text); }\n\n  .det-cost {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;\n  }\n  .det-cost .c {\n    padding: 10px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 8px;\n  }\n  .det-cost .c .k { font-family: var(--mono); font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; }\n  .det-cost .c .v { font-family: var(--display); font-weight: 700; font-size: 18px; margin-top: 2px; }\n  .det-cost .c .v.rp { color: var(--cyan); }\n  .det-cost .c .v.ttl { color: var(--amber); }\n\n  .det-action { padding: 14px 18px; }\n  .det-action .btn { width: 100%; padding: 12px; font-size: 14px; }\n\n  /* Queue */\n  .queue-list { padding: 0; }\n  .queue-row {\n    display: grid; grid-template-columns: 32px 1fr auto; gap: 10px;\n    padding: 10px 18px;\n    border-bottom: 1px solid var(--line);\n    align-items: center;\n  }\n  .queue-row .ico {\n    width: 32px; height: 32px; border-radius: 8px;\n    background: var(--amber); color: #1c1300;\n    display: grid; place-items: center; font-family: var(--mono); font-weight: 700;\n  }\n  .queue-row .name { font-weight: 500; font-size: 13px; }\n  .queue-row .pb {\n    margin-top: 4px;\n    width: 100%; height: 4px; background: var(--line); border-radius: 2px; overflow: hidden;\n  }\n  .queue-row .pb i { display: block; height: 100%; background: var(--amber); }\n  .queue-row .ttl { font-family: var(--mono); font-size: 11px; color: var(--amber); font-weight: 700; }\n\n  @media (max-width: 1240px) { .layout { grid-template-columns: 1fr; } }\n";
const pageHtml = "\n<div class=\"app\">\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscaler</a>\n    <div class=\"company-card\">\n      <div class=\"row\"><div class=\"crest\">SN</div><div><div class=\"name\">SyncNode <span class=\"edit\">✎</span></div><div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div></div></div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> Dashboard</a>\n      <a class=\"nav-item\" href=\"/play/servers\"><span class=\"ico\">▤</span> Servers <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> Customers <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> Tickets <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> Finance</a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Grow</div>\n      <a class=\"nav-item active\"><span class=\"ico\">⚙</span> Research <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> Marketplace</a>\n      <a class=\"nav-item locked\" href=\"/play/staff\"><span class=\"ico\">☰</span> Staff <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item locked\" href=\"/play/network\"><span class=\"ico\">◴</span> Network <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> Leaderboard</a>\n      <a class=\"nav-item\" href=\"/play/devlog\"><span class=\"ico\">▶</span> Devlog</a>\n      <a class=\"nav-item\" href=\"/play/settings\"><span class=\"ico\">⚒</span> Settings</a>\n    </div>\n    <div class=\"side-foot\"><div>v0.7.2 · build 18,402</div><a href=\"#\">⌨ Shortcuts ⌘K</a><div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div></div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Play</span><span class=\"sep\">›</span><b>Research</b><span class=\"sep\">›</span><span>Tech tree · Era 1</span></div>\n      <div class=\"clock\"><div class=\"day\">Day 12<small> / 365</small></div><div class=\"time\">03:42 AM</div><div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div></div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Research <span class=\"count\">3 of 32 unlocked · Era 1 branch</span></h1>\n          <div class=\"sub\">Earn RP from happy customers, postmortems, and outages survived.</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">Switch branch</button>\n          <button class=\"btn primary\">＋ Queue research</button>\n        </div>\n      </div>\n\n      <div class=\"layout\">\n\n        <!-- Tech tree -->\n        <section class=\"panel tree-wrap\">\n          <div class=\"header-pad\">\n            <h3>Tech tree · Era 1 — Garage Engineering</h3>\n            <div class=\"points\"><b>14</b> RP available</div>\n          </div>\n          <div class=\"legend-row\">\n            <span><i class=\"av\"></i><b>Acquired</b></span>\n            <span><i class=\"rs\"></i><b>Researching</b></span>\n            <span><i class=\"un\"></i><b>Available</b></span>\n            <span><i class=\"lk\"></i><b>Locked</b></span>\n            <span style=\"margin-left:auto;\">⌨ scroll to pan</span>\n          </div>\n\n          <div class=\"tree\">\n            <svg class=\"lines\" viewBox=\"0 0 880 600\" preserveAspectRatio=\"none\">\n              <!-- connection lines -->\n              <g stroke=\"#2a3050\" stroke-width=\"2\" fill=\"none\">\n                <!-- root → tier1 -->\n                <path d=\"M 110 70 L 110 145\" stroke=\"#34d399\"/>\n                <path d=\"M 110 70 L 290 145\" stroke=\"#34d399\"/>\n                <path d=\"M 110 70 L 470 145\"/>\n                <!-- tier1 → tier2 -->\n                <path d=\"M 110 200 L 110 290\" stroke=\"#34d399\"/>\n                <path d=\"M 290 200 L 290 290\" stroke=\"#f59e0b\"/>\n                <path d=\"M 470 200 L 470 290\"/>\n                <path d=\"M 290 200 L 110 290\"/>\n                <!-- tier2 → tier3 -->\n                <path d=\"M 110 345 L 110 440\"/>\n                <path d=\"M 290 345 L 290 440\"/>\n                <path d=\"M 470 345 L 470 440\"/>\n                <path d=\"M 470 345 L 650 440\"/>\n                <!-- tier3 → era 2 gate -->\n                <path d=\"M 110 495 L 380 575\" stroke-dasharray=\"5 4\"/>\n                <path d=\"M 290 495 L 380 575\" stroke-dasharray=\"5 4\"/>\n                <path d=\"M 470 495 L 380 575\" stroke-dasharray=\"5 4\"/>\n                <path d=\"M 650 495 L 380 575\" stroke-dasharray=\"5 4\"/>\n              </g>\n            </svg>\n\n            <!-- Root -->\n            <div class=\"node acquired\" style=\"left: 30px; top: 16px;\">\n              <div class=\"ico\">★</div>\n              <div class=\"name\">Garage Engineering</div>\n              <div class=\"cost\"><b>Starter</b></div>\n            </div>\n\n            <!-- Tier 1 -->\n            <div class=\"node acquired\" style=\"left: 30px; top: 145px;\">\n              <div class=\"ico\">⚡</div>\n              <div class=\"name\">Power-strip uplink</div>\n              <div class=\"cost\"><b>Free</b></div>\n            </div>\n            <div class=\"node researching selected\" style=\"left: 210px; top: 145px;\">\n              <div class=\"ico\">↺</div>\n              <div class=\"name\">Auto-restart cron</div>\n              <div class=\"cost\"><span class=\"rp\">4 RP</span><span class=\"ttl\">6h</span></div>\n              <div class=\"progress\"><i></i></div>\n            </div>\n            <div class=\"node available\" style=\"left: 390px; top: 145px;\">\n              <div class=\"ico\">⌨</div>\n              <div class=\"name\">SSH bastion</div>\n              <div class=\"cost\"><span class=\"rp\">5 RP</span><span class=\"ttl\">12h</span></div>\n            </div>\n\n            <!-- Tier 2 -->\n            <div class=\"node acquired\" style=\"left: 30px; top: 290px;\">\n              <div class=\"ico\">▤</div>\n              <div class=\"name\">Rack mounting</div>\n              <div class=\"cost\"><b>Day 6</b></div>\n            </div>\n            <div class=\"node available\" style=\"left: 210px; top: 290px;\">\n              <div class=\"ico\">∿</div>\n              <div class=\"name\">Cron monitoring</div>\n              <div class=\"cost\"><span class=\"rp\">6 RP</span><span class=\"ttl\">18h</span></div>\n            </div>\n            <div class=\"node available\" style=\"left: 390px; top: 290px;\">\n              <div class=\"ico\">⎈</div>\n              <div class=\"name\">Backup tape rotation</div>\n              <div class=\"cost\"><span class=\"rp\">8 RP</span><span class=\"ttl\">1d</span></div>\n            </div>\n\n            <!-- Tier 3 -->\n            <div class=\"node locked\" style=\"left: 30px; top: 440px;\">\n              <div class=\"ico\">≣</div>\n              <div class=\"name\">RAID-5 storage</div>\n              <div class=\"cost\"><span class=\"rp\">10 RP</span><span class=\"ttl\">2d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 210px; top: 440px;\">\n              <div class=\"ico\">⚒</div>\n              <div class=\"name\">Postmortem culture</div>\n              <div class=\"cost\"><span class=\"rp\">12 RP</span><span class=\"ttl\">2d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 390px; top: 440px;\">\n              <div class=\"ico\">⚐</div>\n              <div class=\"name\">Status page</div>\n              <div class=\"cost\"><span class=\"rp\">8 RP</span><span class=\"ttl\">1d</span></div>\n            </div>\n            <div class=\"node locked\" style=\"left: 570px; top: 440px;\">\n              <div class=\"ico\">⌖</div>\n              <div class=\"name\">2nd power feed</div>\n              <div class=\"cost\"><span class=\"rp\">14 RP</span><span class=\"ttl\">3d</span></div>\n            </div>\n\n            <!-- Era 2 gate -->\n            <div class=\"node locked\" style=\"left: 300px; top: 565px; width: 220px; border-style: dashed;\">\n              <div class=\"ico\">🔒</div>\n              <div class=\"name\">ERA 2 · Colocation</div>\n              <div class=\"cost\"><b>Requires 4 Era 1 techs + $1,000</b></div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Detail + queue -->\n        <div style=\"display: flex; flex-direction: column; gap: 18px;\">\n\n          <section class=\"panel\">\n            <div class=\"det-head\">\n              <div class=\"ico-lg\" style=\"background: var(--amber); color: #1c1300;\">↺</div>\n              <h2>Auto-restart cron</h2>\n              <div class=\"cat\">Tier 1 · Reliability · in progress</div>\n            </div>\n            <div class=\"det-section\">\n              <h4>What it does</h4>\n              <p>Drops a <em>watchdog</em> on every server that resurrects crashed processes in &lt;15s. Trades a tiny bit of CPU for a lot of fewer 3 AM pages.</p>\n            </div>\n            <div class=\"det-section\">\n              <h4>Effects when complete</h4>\n              <div class=\"det-effects\">\n                <div class=\"effect\"><span class=\"pos\">▲ +35%</span><span class=\"lbl\">SLA on stateless workloads</span></div>\n                <div class=\"effect\"><span class=\"pos\">▲ +6</span><span class=\"lbl\">Customer mood (less downtime)</span></div>\n                <div class=\"effect\"><span class=\"pos\">−40%</span><span class=\"lbl\">P1 ticket rate (est.)</span></div>\n                <div class=\"effect\"><span class=\"neg\">▼ −2%</span><span class=\"lbl\">Average CPU available</span></div>\n              </div>\n            </div>\n            <div class=\"det-section\">\n              <h4>Cost &amp; time</h4>\n              <div class=\"det-cost\">\n                <div class=\"c\"><div class=\"k\">Research</div><div class=\"v rp\">4 RP</div></div>\n                <div class=\"c\"><div class=\"k\">Time left</div><div class=\"v ttl\">2h 14m</div></div>\n                <div class=\"c\"><div class=\"k\">Prereq</div><div class=\"v\" style=\"font-size:13px;\">Garage Eng. ✓</div></div>\n                <div class=\"c\"><div class=\"k\">Unlocks</div><div class=\"v\" style=\"font-size:13px;\">Cron Monitoring</div></div>\n              </div>\n            </div>\n            <div class=\"det-action\">\n              <button class=\"btn primary\">Boost research · $40 (-1h 30m)</button>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>Research queue</h3>\n              <span class=\"ph-sub\">// max 2 parallel · Era 1</span>\n            </div>\n            <div class=\"queue-list\">\n              <div class=\"queue-row\">\n                <div class=\"ico\">↺</div>\n                <div>\n                  <div class=\"name\">Auto-restart cron</div>\n                  <div class=\"pb\"><i style=\"width: 62%\"></i></div>\n                </div>\n                <div class=\"ttl\">2h 14m</div>\n              </div>\n              <div class=\"queue-row\" style=\"opacity: .55;\">\n                <div class=\"ico\" style=\"background: var(--panel-3); color: var(--dim); border: 1px dashed var(--line-2);\">＋</div>\n                <div>\n                  <div class=\"name\" style=\"color: var(--dim);\">Slot 2 — empty</div>\n                  <div class=\"pb\"></div>\n                </div>\n                <div class=\"ttl\" style=\"color: var(--dim);\">queue</div>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>How to earn RP</h3>\n              <span class=\"ph-sub\">// Era 1</span>\n            </div>\n            <div style=\"padding: 12px 18px; display: flex; flex-direction: column; gap: 8px;\">\n              <div class=\"effect\"><span class=\"pos\">+2 RP</span><span class=\"lbl\">Resolve P1 ticket within SLA</span></div>\n              <div class=\"effect\"><span class=\"pos\">+5 RP</span><span class=\"lbl\">Write postmortem after outage</span></div>\n              <div class=\"effect\"><span class=\"pos\">+1 RP</span><span class=\"lbl\">Customer at mood &gt; 80 for 7 days</span></div>\n              <div class=\"effect\"><span class=\"pos\">+3 RP</span><span class=\"lbl\">Forum post compliments your SLA</span></div>\n            </div>\n          </section>\n        </div>\n\n      </div>\n    </div>\n  </main>\n</div>\n";
