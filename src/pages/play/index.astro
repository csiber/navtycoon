---
// /play -- main dashboard. Auth-required.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const customerCount = (await db.prepare(
  'SELECT COUNT(*) AS n FROM customers WHERE player_id = ? AND is_active = 1',
).bind(user.id).first<{ n: number }>())?.n ?? 0;
const serverCount = (await db.prepare(
  'SELECT COUNT(*) AS n FROM servers WHERE player_id = ?',
).bind(user.id).first<{ n: number }>())?.n ?? 0;
const openTickets = (await db.prepare(
  `SELECT COUNT(*) AS n FROM tickets WHERE player_id = ? AND status IN ('open', 'in_progress')`,
).bind(user.id).first<{ n: number }>())?.n ?? 0;

const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const companyName = player.company_name;
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const pageCss = "\n  :root {\n    --bg: #07090f;\n    --bg-1: #0b0e17;\n    --bg-2: #0e1220;\n    --panel: #121626;\n    --panel-2: #161a2c;\n    --panel-3: #1a1f33;\n    --line: #1e2338;\n    --line-2: #262c46;\n    --text: #e9ecf5;\n    --muted: #8b92ad;\n    --dim: #5d6483;\n    --indigo: #6366f1;\n    --indigo-2: #818cf8;\n    --amber: #f59e0b;\n    --mint: #34d399;\n    --pink: #f43f5e;\n    --cyan: #22d3ee;\n    --display: \"Space Grotesk\", system-ui, sans-serif;\n    --body: \"Inter\", system-ui, sans-serif;\n    --mono: \"JetBrains Mono\", ui-monospace, monospace;\n  }\n  * { box-sizing: border-box; }\n  html, body { margin: 0; padding: 0; }\n  body {\n    background: var(--bg);\n    color: var(--text);\n    font-family: var(--body);\n    font-size: 14px;\n    line-height: 1.5;\n    -webkit-font-smoothing: antialiased;\n  }\n  body::before {\n    content: \"\";\n    position: fixed; inset: 0;\n    background:\n      radial-gradient(900px 500px at 0% 0%, rgba(99,102,241,.10), transparent 60%),\n      radial-gradient(700px 500px at 100% 0%, rgba(245,158,11,.06), transparent 60%);\n    pointer-events: none; z-index: 0;\n  }\n  a { color: inherit; text-decoration: none; }\n  button { font-family: inherit; cursor: pointer; }\n\n  /* ─── Layout ─── */\n  .app {\n    display: grid;\n    grid-template-columns: 240px 1fr;\n    min-height: 100vh;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* ─── Sidebar ─── */\n  aside {\n    background: var(--bg-1);\n    border-right: 1px solid var(--line);\n    padding: 18px 14px;\n    position: sticky; top: 0; height: 100vh;\n    display: flex; flex-direction: column; gap: 18px;\n    overflow-y: auto;\n  }\n  .brand {\n    display: flex; align-items: center; gap: 10px;\n    font-family: var(--display); font-weight: 700; font-size: 17px;\n    padding: 4px 8px;\n  }\n  .brand-mark {\n    width: 28px; height: 28px; border-radius: 7px;\n    background: linear-gradient(135deg, var(--indigo), #4f46e5);\n    display: grid; place-items: center;\n    box-shadow: 0 0 0 1px rgba(255,255,255,.08) inset, 0 8px 24px -8px rgba(99,102,241,.7);\n    position: relative;\n  }\n  .brand-mark::before {\n    content: \"\"; width: 12px; height: 12px; background: #fff;\n    clip-path: polygon(55% 0, 0 60%, 45% 60%, 30% 100%, 100% 35%, 55% 35%);\n  }\n\n  .company-card {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 10px;\n    padding: 12px;\n  }\n  .company-card .row { display: flex; align-items: center; gap: 10px; }\n  .company-card .crest {\n    width: 32px; height: 32px; border-radius: 8px;\n    background: linear-gradient(135deg, #22d3ee, #0891b2);\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 12px; color: #fff;\n  }\n  .company-card .name {\n    font-family: var(--display); font-weight: 600; font-size: 14px;\n    display: flex; align-items: center; gap: 6px;\n  }\n  .company-card .edit {\n    color: var(--dim); font-size: 11px; cursor: pointer;\n  }\n  .company-card .edit:hover { color: var(--text); }\n  .company-card .sub {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    margin-top: 1px; letter-spacing: 0.04em;\n  }\n  .company-card .runway {\n    margin-top: 10px;\n    font-family: var(--mono); font-size: 10px; color: var(--muted);\n    display: flex; justify-content: space-between;\n  }\n  .company-card .runway b { color: var(--amber); }\n  .company-card .bar {\n    margin-top: 4px;\n    height: 4px; border-radius: 2px;\n    background: var(--line);\n    overflow: hidden;\n  }\n  .company-card .bar > i {\n    display: block; height: 100%; width: 38%;\n    background: linear-gradient(90deg, var(--pink), var(--amber));\n  }\n\n  .nav-section {\n    display: flex; flex-direction: column; gap: 2px;\n  }\n  .nav-head {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.1em;\n    padding: 6px 10px 4px;\n  }\n  .nav-item {\n    display: flex; align-items: center; gap: 10px;\n    padding: 8px 10px;\n    border-radius: 7px;\n    color: var(--muted);\n    font-size: 13px; font-weight: 500;\n    cursor: pointer;\n  }\n  .nav-item:hover { background: var(--panel); color: var(--text); }\n  .nav-item.active {\n    background: rgba(99,102,241,.13);\n    color: var(--text);\n    border: 1px solid rgba(99,102,241,.3);\n  }\n  .nav-item .ico {\n    width: 16px; height: 16px;\n    display: grid; place-items: center;\n    color: var(--dim);\n  }\n  .nav-item.active .ico { color: var(--indigo-2); }\n  .nav-item .badge {\n    margin-left: auto;\n    background: var(--pink); color: #fff;\n    font-family: var(--mono); font-size: 10px; font-weight: 700;\n    padding: 1px 6px; border-radius: 999px;\n  }\n  .nav-item .badge.new {\n    background: var(--mint);\n  }\n  .nav-item .badge.muted {\n    background: var(--panel-3); color: var(--muted);\n  }\n  .nav-item .lock {\n    margin-left: auto;\n    color: var(--dim); font-size: 11px;\n  }\n  .nav-item.locked { color: var(--dim); cursor: not-allowed; }\n  .nav-item.locked:hover { background: transparent; color: var(--dim); }\n\n  .side-foot {\n    margin-top: auto;\n    padding: 10px;\n    border-top: 1px dashed var(--line);\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    display: flex; flex-direction: column; gap: 4px;\n  }\n  .side-foot a { color: var(--muted); }\n  .side-foot .me { display: flex; align-items: center; gap: 8px; margin-top: 4px; color: var(--muted); }\n  .side-foot .me .ava {\n    width: 22px; height: 22px; border-radius: 50%;\n    background: linear-gradient(135deg, #f59e0b, #ef4444);\n    display: grid; place-items: center;\n    color: #fff; font-weight: 700; font-size: 11px;\n  }\n\n  /* ─── Top bar ─── */\n  main { display: flex; flex-direction: column; }\n  header.topbar {\n    height: 60px;\n    border-bottom: 1px solid var(--line);\n    background: rgba(11,14,23,.75);\n    backdrop-filter: blur(14px);\n    position: sticky; top: 0; z-index: 30;\n    display: flex; align-items: center;\n    padding: 0 28px;\n    gap: 20px;\n  }\n  .crumbs {\n    font-family: var(--mono); font-size: 12px; color: var(--dim);\n    display: flex; align-items: center; gap: 8px;\n  }\n  .crumbs b { color: var(--text); font-weight: 600; }\n  .crumbs .sep { color: var(--line-2); }\n\n  .topbar-stats {\n    margin-left: auto;\n    display: flex; align-items: center; gap: 6px;\n  }\n  .tstat {\n    padding: 5px 12px;\n    border-radius: 7px;\n    background: var(--panel);\n    border: 1px solid var(--line);\n    display: flex; flex-direction: column;\n    min-width: 100px;\n  }\n  .tstat .k {\n    font-family: var(--mono); font-size: 9px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.08em;\n  }\n  .tstat .v {\n    font-family: var(--display); font-weight: 700; font-size: 15px;\n    margin-top: 0;\n    display: flex; align-items: baseline; gap: 6px;\n  }\n  .tstat .v small {\n    font-family: var(--mono); font-size: 10px; color: var(--mint); font-weight: 500;\n  }\n  .tstat .v small.dn { color: var(--pink); }\n  .tstat.cash .v { color: var(--text); }\n\n  .clock {\n    margin-left: 6px;\n    display: flex; align-items: center; gap: 10px;\n    padding: 6px 12px; border-radius: 7px;\n    background: var(--panel); border: 1px solid var(--line);\n  }\n  .clock .day {\n    font-family: var(--display); font-weight: 700; font-size: 14px;\n  }\n  .clock .day small { font-family: var(--mono); font-size: 10px; color: var(--dim); font-weight: 400; }\n  .clock .time {\n    font-family: var(--mono); font-size: 12px; color: var(--amber);\n  }\n  .clock .ctrls { display: flex; gap: 3px; margin-left: 4px; }\n  .clock .ctrls button {\n    width: 24px; height: 24px; border-radius: 5px;\n    background: var(--panel-2); border: 1px solid var(--line-2);\n    color: var(--muted); font-size: 11px; padding: 0;\n    display: grid; place-items: center;\n  }\n  .clock .ctrls button.on { color: var(--mint); border-color: rgba(52,211,153,.4); background: rgba(52,211,153,.1); }\n  .clock .ctrls button:hover { color: var(--text); }\n\n  .topbar-actions {\n    display: flex; align-items: center; gap: 8px;\n  }\n  .bell {\n    width: 36px; height: 36px; border-radius: 8px;\n    background: var(--panel); border: 1px solid var(--line);\n    display: grid; place-items: center;\n    position: relative;\n    color: var(--muted);\n  }\n  .bell::after {\n    content: \"4\"; position: absolute; top: -4px; right: -4px;\n    background: var(--pink); color: #fff;\n    font-family: var(--mono); font-size: 10px; font-weight: 700;\n    padding: 1px 5px; border-radius: 999px;\n  }\n\n  /* ─── Content ─── */\n  .content {\n    padding: 24px 28px 60px;\n    display: grid; gap: 18px;\n    grid-template-columns: repeat(12, 1fr);\n  }\n\n  /* Advisor strip */\n  .advisor {\n    grid-column: span 12;\n    background: linear-gradient(135deg, rgba(99,102,241,.15), rgba(245,158,11,.08) 80%);\n    border: 1px solid rgba(99,102,241,.3);\n    border-radius: 12px;\n    padding: 14px 18px;\n    display: flex; align-items: center; gap: 16px;\n    position: relative; overflow: hidden;\n  }\n  .advisor .av {\n    width: 44px; height: 44px; border-radius: 10px;\n    background: linear-gradient(135deg, #6366f1, #4f46e5);\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 13px;\n    box-shadow: 0 0 0 1px rgba(255,255,255,.06) inset;\n    color: #fff; flex-shrink: 0;\n  }\n  .advisor .msg { flex: 1; }\n  .advisor .who {\n    font-family: var(--mono); font-size: 11px; color: var(--indigo-2);\n    text-transform: uppercase; letter-spacing: 0.08em;\n  }\n  .advisor .text {\n    font-size: 15px; color: var(--text); margin-top: 2px;\n  }\n  .advisor .text b { color: var(--amber); font-weight: 600; }\n  .advisor .actions {\n    display: flex; gap: 6px;\n  }\n  .advisor .actions button {\n    padding: 7px 12px; border-radius: 7px;\n    background: rgba(7,9,15,.4); border: 1px solid var(--line-2);\n    color: var(--text); font-weight: 500; font-size: 12px;\n  }\n  .advisor .actions button.primary {\n    background: var(--text); color: var(--bg); border-color: transparent;\n    font-weight: 600;\n  }\n  .advisor .dismiss {\n    width: 26px; height: 26px; border-radius: 6px;\n    background: transparent; border: 0; color: var(--muted);\n    display: grid; place-items: center;\n  }\n\n  /* KPI tiles */\n  .kpi {\n    grid-column: span 3;\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 16px 18px;\n    position: relative; overflow: hidden;\n  }\n  .kpi .k {\n    font-family: var(--mono); font-size: 10px;\n    color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;\n  }\n  .kpi .v {\n    font-family: var(--display); font-weight: 700;\n    font-size: 30px; letter-spacing: -0.02em;\n    margin-top: 6px;\n    display: flex; align-items: baseline; gap: 10px;\n  }\n  .kpi .v small {\n    font-family: var(--mono); font-size: 12px; font-weight: 500;\n    color: var(--mint);\n  }\n  .kpi .v small.dn { color: var(--pink); }\n  .kpi .meta {\n    margin-top: 4px;\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n  }\n  .kpi .meta b { color: var(--muted); }\n  .kpi.cash::after {\n    content: \"\"; position: absolute; top: 0; left: 0; bottom: 0;\n    width: 3px; background: var(--mint);\n  }\n  .kpi.mrr::after {\n    content: \"\"; position: absolute; top: 0; left: 0; bottom: 0;\n    width: 3px; background: var(--indigo);\n  }\n  .kpi.rep::after {\n    content: \"\"; position: absolute; top: 0; left: 0; bottom: 0;\n    width: 3px; background: var(--amber);\n  }\n  .kpi.cust::after {\n    content: \"\"; position: absolute; top: 0; left: 0; bottom: 0;\n    width: 3px; background: var(--cyan);\n  }\n  .kpi .spark {\n    position: absolute; right: 14px; bottom: 14px;\n    width: 70px; height: 30px;\n  }\n\n  /* Panels */\n  .panel {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    overflow: hidden;\n    display: flex; flex-direction: column;\n  }\n  .panel .ph {\n    padding: 14px 16px;\n    border-bottom: 1px solid var(--line);\n    display: flex; align-items: center; gap: 10px;\n    background: rgba(7,9,15,.25);\n  }\n  .panel .ph h3 {\n    margin: 0;\n    font-family: var(--display); font-weight: 600; font-size: 14px;\n  }\n  .panel .ph .ph-sub {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.06em;\n  }\n  .panel .ph .ph-right {\n    margin-left: auto;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .panel .ph .live {\n    font-family: var(--mono); font-size: 10px; color: var(--mint);\n    display: inline-flex; align-items: center; gap: 5px;\n  }\n  .panel .ph .live i {\n    width: 6px; height: 6px; border-radius: 50%; background: var(--mint);\n    box-shadow: 0 0 0 0 rgba(52,211,153,.5);\n    animation: pulse 1.8s infinite;\n  }\n  @keyframes pulse {\n    0% { box-shadow: 0 0 0 0 rgba(52,211,153,.5); }\n    70% { box-shadow: 0 0 0 6px rgba(52,211,153,0); }\n    100% { box-shadow: 0 0 0 0 rgba(52,211,153,0); }\n  }\n  .panel .ph a.more {\n    font-family: var(--mono); font-size: 11px; color: var(--indigo-2);\n  }\n  .panel .ph a.more:hover { color: var(--text); }\n\n  /* Event feed */\n  .feed { grid-column: span 8; }\n  .feed-body {\n    padding: 4px 0;\n    max-height: 420px; overflow-y: auto;\n  }\n  .event {\n    display: grid; grid-template-columns: 70px 28px 1fr auto;\n    gap: 12px; padding: 10px 16px;\n    border-bottom: 1px solid var(--line);\n    align-items: start;\n  }\n  .event:last-child { border-bottom: 0; }\n  .event .ts {\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    padding-top: 3px;\n  }\n  .event .ico {\n    width: 28px; height: 28px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    display: grid; place-items: center;\n    color: var(--muted); font-size: 13px;\n    flex-shrink: 0;\n  }\n  .event.alert .ico { background: rgba(244,63,94,.12); border-color: rgba(244,63,94,.3); color: var(--pink); }\n  .event.warn .ico { background: rgba(245,158,11,.12); border-color: rgba(245,158,11,.3); color: var(--amber); }\n  .event.good .ico { background: rgba(52,211,153,.12); border-color: rgba(52,211,153,.3); color: var(--mint); }\n  .event.info .ico { background: rgba(99,102,241,.12); border-color: rgba(99,102,241,.3); color: var(--indigo-2); }\n  .event .body { font-size: 13px; color: var(--text); }\n  .event .body b { font-weight: 600; }\n  .event .body em {\n    font-style: normal; font-family: var(--mono); font-size: 12px;\n    color: var(--muted);\n    background: rgba(7,9,15,.5); padding: 1px 6px; border-radius: 4px;\n  }\n  .event .body .quote {\n    display: block; margin-top: 4px;\n    font-size: 12px; color: var(--muted);\n    padding-left: 10px; border-left: 2px solid var(--line-2);\n    line-height: 1.45;\n  }\n  .event .impact {\n    font-family: var(--mono); font-size: 11px; font-weight: 600;\n    text-align: right;\n    white-space: nowrap;\n  }\n  .event .impact.pos { color: var(--mint); }\n  .event .impact.neg { color: var(--pink); }\n  .event .impact small { display: block; color: var(--dim); font-weight: 400; font-size: 10px; }\n\n  /* Right column (fleet + mood) */\n  .side-stack {\n    grid-column: span 4;\n    display: flex; flex-direction: column; gap: 18px;\n  }\n\n  /* Mini rack */\n  .rack-body {\n    padding: 14px;\n    display: flex; flex-direction: column; gap: 4px;\n  }\n  .u {\n    height: 22px; border-radius: 4px;\n    background: linear-gradient(90deg, #1a1f33, #232a45 70%, #1a1f33);\n    border: 1px solid #232a45;\n    display: grid; grid-template-columns: 50px 1fr 56px 60px;\n    align-items: center; gap: 8px;\n    padding: 0 10px;\n    font-family: var(--mono); font-size: 10px; color: var(--muted);\n  }\n  .u .lbl { color: var(--dim); }\n  .u .leds { display: flex; gap: 4px; }\n  .u .leds i { width: 6px; height: 6px; border-radius: 50%; display: block; background: #2a3050; }\n  .u .leds i.g { background: var(--mint); box-shadow: 0 0 5px var(--mint); }\n  .u .leds i.a { background: var(--amber); box-shadow: 0 0 5px var(--amber); }\n  .u .leds i.r { background: var(--pink); box-shadow: 0 0 5px var(--pink); }\n  .u .name { color: var(--text); }\n  .u .util { text-align: right; color: var(--mint); }\n  .u.warn .util { color: var(--amber); }\n  .u.hot { background: linear-gradient(90deg, #2a1a1f, #3b2230 70%, #2a1a1f); border-color: #4a2535; }\n  .u.hot .util { color: var(--pink); }\n  .u.empty {\n    background: repeating-linear-gradient(45deg, #0d1020 0 6px, #131726 6px 12px);\n    color: var(--dim);\n  }\n  .u.empty .util { color: var(--dim); }\n  .u.empty .name { color: var(--dim); }\n\n  .rack-foot {\n    padding: 12px 14px 14px;\n    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;\n    border-top: 1px dashed var(--line);\n  }\n  .mini-stat {\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 6px; padding: 8px 9px;\n    font-family: var(--mono);\n  }\n  .mini-stat .k { font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.06em; }\n  .mini-stat .v { font-size: 14px; font-weight: 700; color: var(--text); margin-top: 2px; font-family: var(--display); }\n  .mini-stat .v.good { color: var(--mint); }\n  .mini-stat .v.warn { color: var(--amber); }\n\n  /* Customer mood */\n  .mood-body {\n    padding: 16px;\n    display: grid; grid-template-columns: 100px 1fr; gap: 16px;\n    align-items: center;\n  }\n  .mood-ring {\n    position: relative; width: 100px; height: 100px;\n  }\n  .mood-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }\n  .mood-ring .center {\n    position: absolute; inset: 0;\n    display: grid; place-items: center;\n    text-align: center;\n  }\n  .mood-ring .center .big {\n    font-family: var(--display); font-weight: 700; font-size: 22px;\n  }\n  .mood-ring .center .lbl {\n    font-family: var(--mono); font-size: 9px; color: var(--dim);\n    text-transform: uppercase; letter-spacing: 0.08em;\n  }\n  .mood-list { display: flex; flex-direction: column; gap: 8px; font-size: 12px; }\n  .mood-list .row {\n    display: grid; grid-template-columns: 80px 1fr 30px; gap: 8px;\n    align-items: center;\n  }\n  .mood-list .row span:first-child { color: var(--muted); }\n  .mood-list .row .b { height: 6px; border-radius: 3px; background: var(--line); overflow: hidden; }\n  .mood-list .row .b i { display: block; height: 100%; }\n  .mood-list .row .v { font-family: var(--mono); font-size: 11px; color: var(--text); text-align: right; }\n  .mood-list .row .b i.good { background: var(--mint); }\n  .mood-list .row .b i.ok { background: var(--cyan); }\n  .mood-list .row .b i.warn { background: var(--amber); }\n  .mood-list .row .b i.bad { background: var(--pink); }\n\n  /* Tickets preview */\n  .tickets-panel { grid-column: span 5; }\n  .tickets-body { padding: 4px 0; display: flex; flex-direction: column; }\n  .ticket-row {\n    display: grid; grid-template-columns: 32px 1fr auto auto;\n    gap: 12px; padding: 12px 16px;\n    border-bottom: 1px solid var(--line);\n    align-items: center;\n  }\n  .ticket-row:last-child { border-bottom: 0; }\n  .ticket-row .av {\n    width: 32px; height: 32px; border-radius: 50%;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 12px; color: #fff;\n  }\n  .av-K { background: linear-gradient(135deg, #f97316, #ea580c); }\n  .av-D { background: linear-gradient(135deg, #22d3ee, #0891b2); }\n  .av-A { background: linear-gradient(135deg, #a78bfa, #7c3aed); }\n  .av-M { background: linear-gradient(135deg, #f43f5e, #e11d48); }\n  .av-R { background: linear-gradient(135deg, #34d399, #059669); }\n  .ticket-row .info {\n    overflow: hidden;\n  }\n  .ticket-row .who {\n    font-size: 13px; font-weight: 600;