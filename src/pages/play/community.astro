---
// /play/community — forum thread list (newest-first, pinned on top).
// Async player-to-player + NPC. Auth required.
import Base from '../../layouts/Base.astro';
import { getCurrentUser, getDB } from '../../lib/auth';
import { listThreads } from '../../lib/forum/db';
import { translateThread, type ForumLang } from '../../lib/forum/translations';
import { resolveLocale } from '../../lib/i18n/server';
import { t } from '../../lib/i18n';

const user = await getCurrentUser(Astro);
if (!user) return Astro.redirect('/login?next=/play/community');
const db = getDB(Astro);

const viewerLang: ForumLang = await resolveLocale({
  request: Astro.request,
  db,
  userId: user.id,
});

const rawThreads = db ? await listThreads(db, 50, 0) : [];
const threads = rawThreads.map((t) => {
  if (t.is_npc === 1) {
    const tr = translateThread(viewerLang, { title: t.title, body: t.body });
    return { ...t, title: tr.title, body: tr.body };
  }
  return t;
});

const NOW_LABEL = t(viewerLang, 'time.now');
const MIN_SUFFIX = t(viewerLang, 'time.minute_suffix');
const HOUR_SUFFIX = t(viewerLang, 'time.hour_suffix');
const DAY_SUFFIX = t(viewerLang, 'time.day_suffix');

function timeAgo(ts: number): string {
  const sec = Math.floor(Date.now() / 1000) - ts;
  if (sec < 60) return NOW_LABEL;
  if (sec < 3600) return `${Math.floor(sec / 60)}${MIN_SUFFIX}`;
  if (sec < 86400) return `${Math.floor(sec / 3600)}${HOUR_SUFFIX}`;
  return `${Math.floor(sec / 86400)}${DAY_SUFFIX}`;
}

function avatarChar(name: string | null): string {
  return (name?.trim()[0] ?? '?').toUpperCase();
}

const unknownAuthor = t(viewerLang, 'community.unknown_author');
const postingLabel = t(viewerLang, 'community.form.posting');
const errorPrefix = t(viewerLang, 'community.error.prefix');
const errorUnknown = t(viewerLang, 'community.error.unknown');
const repliesWord = t(viewerLang, 'community.thread.replies_other').replace('{n}', '').trim();
const lastReplyTpl = t(viewerLang, 'community.thread.last_reply');
---
<Base title={t(viewerLang, 'community.page_title')}>
  <div class="max-w-4xl mx-auto">
    <div class="flex items-baseline justify-between mb-2">
      <div>
        <h1 class="text-3xl font-bold">{t(viewerLang, 'community.title')}</h1>
        <p class="text-nt-text-dim text-sm mt-1">
          {t(viewerLang, 'community.sub').replace('{count}', String(threads.length))}
        </p>
      </div>
      <button id="new-thread-btn"
              class="px-4 py-2 bg-nt-accent rounded font-semibold text-sm hover:opacity-90 transition">
        {t(viewerLang, 'community.new_post')}
      </button>
    </div>

    {/* New-thread form, hidden by default */}
    <form id="new-thread-form" class="hidden mt-4 mb-6 p-4 bg-nt-bg-2 border border-nt-border rounded-lg space-y-3">
      <div>
        <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">{t(viewerLang, 'community.form.title')}</label>
        <input type="text" name="title" required minlength="4" maxlength="140"
               placeholder={t(viewerLang, 'community.form.title_ph')}
               class="w-full px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none transition" />
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wide text-nt-text-dim mb-1">{t(viewerLang, 'community.form.body')}</label>
        <textarea name="body" required minlength="4" maxlength="8000" rows="6"
                  placeholder={t(viewerLang, 'community.form.body_ph')}
                  class="w-full px-3 py-2 bg-nt-bg border border-nt-border rounded text-nt-text focus:border-nt-accent focus:outline-none transition resize-y"></textarea>
      </div>
      <div class="flex items-center gap-2">
        <button type="submit" class="px-4 py-2 bg-nt-accent rounded font-semibold text-sm hover:opacity-90 transition">
          {t(viewerLang, 'community.form.submit')}
        </button>
        <button type="button" id="new-thread-cancel" class="px-4 py-2 text-nt-text-dim hover:text-nt-text text-sm transition">
          {t(viewerLang, 'community.form.cancel')}
        </button>
        <p id="new-thread-status" class="text-sm ml-auto" aria-live="polite"></p>
      </div>
    </form>

    {threads.length === 0 ? (
      <p class="mt-12 text-center text-nt-text-dim">{t(viewerLang, 'community.empty')}</p>
    ) : (
      <div class="mt-4 space-y-2">
        {threads.map((th) => (
          <a href={`/play/community/${th.id}`} class="block p-4 bg-nt-bg-2 border border-nt-border rounded-lg hover:border-nt-accent transition">
            <div class="flex items-start gap-3">
              <div class={`w-10 h-10 rounded-full flex-shrink-0 grid place-items-center text-sm font-bold ${th.is_npc ? 'bg-nt-bg' : 'bg-nt-accent text-white'}`}>
                {avatarChar(th.author_name)}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-2 text-xs text-nt-text-dim mb-1">
                  <span class="font-semibold text-nt-text">{th.author_name ?? unknownAuthor}</span>
                  {th.author_city && <span>· {th.author_city}</span>}
                  {th.is_npc === 1 && th.npc_archetype && (
                    <span class="px-1.5 py-0.5 bg-nt-bg rounded text-[10px] uppercase tracking-wide">{th.npc_archetype.replace(/_/g, ' ')}</span>
                  )}
                  <span class="ml-auto">{timeAgo(th.created_at)}</span>
                </div>
                <h3 class="font-semibold mb-1 truncate">{th.title}</h3>
                <p class="text-sm text-nt-text-dim line-clamp-2">{th.body}</p>
                <div class="flex gap-3 mt-2 text-xs text-nt-text-dim">
                  <span>💬 {th.replies_count} {repliesWord}</span>
                  {th.replies_count > 0 && <span>{lastReplyTpl.replace('{when}', timeAgo(th.last_reply_at))}</span>}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

  <script define:vars={{ postingLabel, errorPrefix, errorUnknown }}>
    const btn = document.getElementById('new-thread-btn');
    const form = document.getElementById('new-thread-form');
    const cancel = document.getElementById('new-thread-cancel');
    const status = document.getElementById('new-thread-status');

    btn?.addEventListener('click', () => {
      form.classList.remove('hidden');
      btn.classList.add('hidden');
    });
    cancel?.addEventListener('click', () => {
      form.classList.add('hidden');
      btn?.classList.remove('hidden');
      form.reset();
      if (status) status.textContent = '';
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      if (status) {
        status.textContent = postingLabel;
        status.className = 'text-sm text-nt-text-dim ml-auto';
      }
      const r = await fetch('/api/forum/threads', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ title: fd.get('title'), body: fd.get('body') }),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        if (status) {
          status.textContent = errorPrefix + (j.error ?? errorUnknown);
          status.className = 'text-sm text-red-400 ml-auto';
        }
        return;
      }
      const j = await r.json();
      location.href = `/play/community/${j.id}`;
    });
  </script>
</Base>
