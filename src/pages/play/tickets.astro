%, 100% { opacity: 0.3; } }\n\n  .thread { padding: 18px 22px; display: flex; flex-direction: column; gap: 16px; }\n  .tmsg { display: grid; grid-template-columns: 36px 1fr; gap: 12px; }\n  .tmsg .av {\n    width: 36px; height: 36px; border-radius: 50%;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 14px; color: #fff;\n  }\n  .tmsg.you .av { background: linear-gradient(135deg, var(--indigo), #4f46e5); }\n  .tmsg .head { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }\n  .tmsg .who { font-weight: 600; font-size: 13px; }\n  .tmsg .ts { font-family: var(--mono); font-size: 10px; color: var(--dim); }\n  .tmsg .body {\n    padding: 12px 14px; border-radius: 10px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    font-size: 13px; line-height: 1.5; color: var(--text);\n  }\n  .tmsg.you .body { background: rgba(99,102,241,.08); border-color: rgba(99,102,241,.25); }\n  .tmsg .body p { margin: 0 0 8px; }\n  .tmsg .body p:last-child { margin-bottom: 0; }\n  .tmsg .body code {\n    font-family: var(--mono); font-size: 11px;\n    background: var(--panel-3); padding: 1px 5px; border-radius: 3px;\n    color: var(--cyan);\n  }\n  .tmsg .body blockquote {\n    margin: 8px 0; padding: 6px 10px;\n    border-left: 2px solid var(--line-2);\n    color: var(--muted); font-style: italic;\n  }\n  .sys-note {\n    padding: 8px 12px;\n    background: var(--panel-2); border-radius: 8px;\n    border: 1px dashed var(--line-2);\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n    display: flex; align-items: center; gap: 8px;\n  }\n  .sys-note b { color: var(--amber); font-weight: 700; }\n\n  .composer {\n    border-top: 1px solid var(--line);\n    padding: 14px 22px 18px;\n    background: rgba(7,9,15,.4);\n  }\n  .composer .ai-suggest {\n    padding: 10px 12px; border-radius: 8px;\n    background: rgba(99,102,241,.08); border: 1px solid rgba(99,102,241,.25);\n    font-size: 12px; colo