<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Finance</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Common: sidebar / topbar
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    const runway = document.querySelector('.company-card .runway b');
    if (runway) runway.textContent = s.runwayDays + ' days';
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // KPI cards
    const kpis = document.querySelectorAll('.kpi-card');
    if (kpis[0]) {
      const v = kpis[0].querySelector('.v'); if (v) v.textContent = '$' + s.cashUsd;
      const d = kpis[0].querySelector('.delta'); if (d) d.textContent = 'Runway ' + s.runwayDays + ' days';
    }
    if (kpis[1]) {
      const v = kpis[1].querySelector('.v'); if (v) v.textContent = '$' + s.mrrUsd;
      const d = kpis[1].querySelector('.delta');
      if (d) d.textContent = s.customerCount + ' active customers';
    }
    if (kpis[2]) {
      const v = kpis[2].querySelector('.v'); if (v) v.textContent = '$' + s.burnPerDay + '/day';
      const d = kpis[2].querySelector('.delta');
      if (d) d.textContent = 'estimated burn';
    }
    if (kpis[3]) {
      const v = kpis[3].querySelector('.v');
      const cashN = parseFloat(s.cashUsd);
      const mrrN = parseFloat(s.mrrUsd);
      const margin = mrrN > 0 ? Math.max(0, Math.min(100, Math.round((mrrN - s.burnPerDay * 30 / 100 * 100) / Math.max(1, mrrN) * 100))) : 0;
      if (v) v.textContent = margin + '%';
      void cashN;
    }
    if (kpis[4]) {
      const v = kpis[4].querySelector('.v'); if (v) v.textContent = '$' + s.avgLtvUsd;
      const d = kpis[4].querySelector('.delta');
      if (d) d.textContent = 'avg customer LTV';
      const k = kpis[4].querySelector('.k');
      if (k) k.textContent = 'Avg LTV';
    }

    // Pagehead
    const phCount = document.querySelector('.pagehead h1 .count');
    if (phCount) phCount.textContent = 'Era ' + s.era;

    // Invoice list — replace template's 7 rows with real ticket-derived txs.
    const invRows = document.querySelectorAll('.inv-row');
    invRows.forEach((row, i) => {
      if (i >= s.transactions.length) { row.style.display = 'none'; return; }
      const t = s.transactions[i];
      const av = row.querySelector('.av'); if (av) av.textContent = t.initial;
      const nameEl = row.querySelector('.name'); if (nameEl) nameEl.textContent = t.customer + ' · #T-' + String(1000 + i);
      const metaEl = row.querySelector('.meta');
      if (metaEl) metaEl.textContent = t.summary + ' · ' + t.day;
      const statusEl = row.querySelector('.status');
      if (statusEl) {
        statusEl.className = 'status ' + t.status;
        statusEl.textContent = t.status === 'paid' ? 'Paid' :
          t.status === 'due' ? 'Pending' :
          t.status === 'late' ? 'Late' : 'Waived';
      }
      const amtEl = row.querySelector('.amt');
      if (amtEl) {
        amtEl.textContent = (t.amt < 0 ? '−$' + Math.abs(t.amt) : '$' + t.amt);
        amtEl.style.color = t.amt < 0 ? 'var(--pink)' : (t.status === 'paid' ? 'var(--mint)' : 'var(--amber)');
      }
    });
    // Invoice header count
    const invHead = document.querySelector('.panel.full .ph .ph-sub');
    if (invHead) invHead.textContent = '// ' + s.transactions.length + ' recent tickets';
  } catch (e) { console.error('hydrate', e); }
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
</body>
</html>
