---
// /play/finance -- backend wiring complete.
// KPIs from player + recent ticket-based transaction list.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';
import I18nDashboard from '../../components/I18nDashboard.astro';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/finance');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const activeCustomers = (await db.prepare(
  'SELECT COUNT(*) AS n, COALESCE(AVG(lifetime_value_cents), 0) AS ltv FROM customers ' +
  'WHERE player_id = ? AND is_active = 1',
).bind(user.id).first<{ n: number; ltv: number }>()) ?? { n: 0, ltv: 0 };

interface TxRow {
  id: number;
  customer_name: string;
  summary: string;
  status: string;
  satisfaction_delta: number | null;
  ai_quality_rating: number | null;
  resolved_at: number | null;
  created_at: number;
}
const txRaw = (await db.prepare(
  'SELECT t.id AS id, c.name AS customer_name, t.summary AS summary, t.status AS status, ' +
  't.satisfaction_delta AS satisfaction_delta, t.ai_quality_rating AS ai_quality_rating, ' +
  't.resolved_at AS resolved_at, t.created_at AS created_at ' +
  'FROM tickets t LEFT JOIN customers c ON c.id = t.customer_id ' +
  'WHERE t.player_id = ? ORDER BY t.created_at DESC LIMIT 10',
).bind(user.id).all<TxRow>()).results ?? [];

function fmtDay(ts: number, foundedAt: number): string {
  return 'Day ' + Math.max(1, Math.floor((ts - foundedAt) / 86400) + 1);
}

const txEntries = txRaw.map(t => {
  const refunded = (t.satisfaction_delta ?? 0) < 0;
  const resolved = t.status === 'resolved' || t.status === 'churned';
  const amt = refunded ? -19 : (resolved ? 19 : 0);
  let status: 'paid' | 'due' | 'late' | 'waived' = 'paid';
  if (refunded) status = 'waived';
  else if (!resolved) status = 'due';
  return {
    customer: t.customer_name ?? 'unknown',
    initial: (t.customer_name ?? '?')[0].toUpperCase(),
    summary: t.summary,
    status,
    amt,
    day: fmtDay(t.created_at, player.founded_at),
  };
});

const burnPerDayUsd = 15; // template default; will refine when sales-events exist
const runwayDays = burnPerDayUsd > 0 ? Math.floor((player.cash_usd_cents / 100) / burnPerDayUsd) : 999;

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  displayName,
  customerCount: activeCustomers.n,
  avgLtvUsd: (activeCustomers.ltv / 100).toFixed(0),
  burnPerDay: burnPerDayUsd,
  runwayDays,
  transactions: txEntries,
};
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 1.4fr 1fr; gap: 18px; }\n  .full { grid-column: span 12; }\n\n  /* KPI row */\n  .kpis { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }\n  .kpi-card {\n    background: var(--panel); border: 1px solid var(--line);\n    border-radius: 12px; padding: 16px 18px;\n    position: relative; overflow: hidden;\n  }\n  .kpi-card.green { border-color: rgba(52,211,153,.3); background: linear-gradient(180deg, rgba(52,211,153,.08), var(--panel) 60%); }\n  .kpi-card.red { border-color: rgba(244,63,94,.3); background: linear-gradient(180deg, rgba(244,63,94,.08), var(--panel) 60%); }\n  .kpi-card.amber { border-color: rgba(245,158,11,.3); background: linear-gradient(180deg, rgba(245,158,11,.08), var(--panel) 60%); }\n  .kpi-card .k { font-family: var(--mono); font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; }\n  .kpi-card .v { font-family: var(--display); font-weight: 700; font-size: 30px; margin-top: 6px; line-height: 1; }\n  .kpi-card .v.bad { color: var(--pink); }\n  .kpi-card .v.good { color: var(--mint); }\n  .kpi-card .v.warn { color: var(--amber); }\n  .kpi-card .delta {\n    font-family: var(--mono); font-size: 11px; color: var(--mint);\n    margin-top: 6px; display: flex; align-items: center; gap: 6px;\n  }\n  .kpi-card .delta.dn { color: var(--pink); }\n  .kpi-card .delta.flat { color: var(--dim); }\n  .kpi-card .spark {\n    position: absolute; right: 14px; bottom: 14px; width: 80px; height: 26px;\n  }\n\n  /* Cashflow chart */\n  .chart-wrap { padding: 18px 22px; }\n  .chart-wrap .head {\n    display: flex; align-items: baseline; margin-bottom: 12px; gap: 14px;\n  }\n  .chart-wrap h3 { margin: 0; font-family: var(--display); font-size: 17px; font-weight: 600; }\n  .chart-wrap .legend { display: flex; gap: 14px; font-family: var(--mono); font-size: 11px; color: var(--muted); margin-left: auto; }\n  .chart-wrap .legend i { display: inline-block; width: 10px; height: 10px; border-radius: 2px; margin-right: 5px; vertical-align: -1px; }\n  .legend .rev i { background: var(--mint); }\n  .legend .exp i { background: var(--pink); }\n  .legend .proj i { background: transparent; border: 1.5px dashed var(--amber); border-radius: 0; }\n  .chart-wrap svg { width: 100%; height: 240px; display: block; }\n  .chart-wrap .x-axis {\n    display: grid; grid-template-columns: repeat(8, 1fr); gap: 4px;\n    margin-top: 4px;\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n    text-align: center;\n  }\n  .chart-wrap .x-axis .now { color: var(--amber); font-weight: 700; }\n\n  /* P&L table */\n  .pnl-table { padding: 0; }\n  .pnl-table table { width: 100%; border-collapse: collapse; font-size: 13px; }\n  .pnl-table th, .pnl-table td {\n    padding: 10px 16px; text-align: right;\n    font-family: var(--mono); font-size: 12px;\n    border-bottom: 1px solid var(--line);\n  }\n  .pnl-table th { font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; background: var(--panel-2); }\n  .pnl-table td:first-child, .pnl-table th:first-child { text-align: left; font-family: var(--body); padding-left: 22px; }\n  .pnl-table td.lbl { color: var(--text); font-weight: 500; }\n  .pnl-table td.sub { padding-left: 38px; color: var(--muted); font-size: 12px; }\n  .pnl-table tr.total td { font-weight: 700; background: var(--panel-2); color: var(--text); }\n  .pnl-table tr.total td.lbl { font-family: var(--display); font-size: 13px; }\n  .pnl-table tr.grand td { background: var(--panel-3); border-top: 2px solid var(--line-2); font-size: 14px; }\n  .pnl-table td.pos { color: var(--mint); }\n  .pnl-table td.neg { color: var(--pink); }\n  .pnl-table td.dim { color: var(--dim); }\n\n  /* Invoices */\n  .inv-row {\n    display: grid; grid-template-columns: 36px 1fr auto auto;\n    gap: 12px; padding: 12px 18px;\n    border-bottom: 1px solid var(--line);\n    align-items: center;\n  }\n  .inv-row .av {\n    width: 36px; height: 36px; border-radius: 50%;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 13px; color: #fff;\n  }\n  .inv-row .name { font-weight: 500; font-size: 13px; }\n  .inv-row .meta { font-family: var(--mono); font-size: 10px; color: var(--dim); margin-top: 2px; }\n  .inv-row .status {\n    font-family: var(--mono); font-size: 10px; padding: 3px 8px;\n    border-radius: 999px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .inv-row .status.paid { background: rgba(52,211,153,.12); color: var(--mint); border: 1px solid rgba(52,211,153,.3); }\n  .inv-row .status.due  { background: rgba(245,158,11,.12); color: var(--amber); border: 1px solid rgba(245,158,11,.3); }\n  .inv-row .status.late { background: rgba(244,63,94,.12); color: var(--pink); border: 1px solid rgba(244,63,94,.3); }\n  .inv-row .status.waived { background: var(--panel-3); color: var(--dim); border: 1px solid var(--line); }\n  .inv-row .amt { font-family: var(--mono); font-weight: 700; font-size: 14px; min-width: 70px; text-align: right; }\n\n  /* Scenario planner */\n  .scen-card { padding: 16px 18px; }\n  .scen-toggle {\n    display: flex; gap: 6px; padding: 4px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 9px; margin-bottom: 14px;\n  }\n  .scen-toggle button {\n    flex: 1; padding: 7px; border-radius: 6px;\n    background: transparent; border: 0;\n    color: var(--muted); font-size: 12px; font-family: var(--mono); font-weight: 600;\n  }\n  .scen-toggle button.on { background: var(--text); color: var(--bg); }\n  .scen-row {\n    display: grid; grid-template-columns: 1fr auto;\n    align-items: center; padding: 10px 0;\n    border-bottom: 1px dashed var(--line);\n    font-size: 13px;\n  }\n  .scen-row:last-of-type { border-bottom: 0; }\n  .scen-row .lbl small { display: block; color: var(--dim); font-family: var(--mono); font-size: 10px; margin-top: 2px; }\n  .scen-slider { display: flex; align-items: center; gap: 10px; }\n  .scen-slider .bar {\n    width: 110px; height: 5px; background: var(--line); border-radius: 3px; position: relative;\n  }\n  .scen-slider .bar i {\n    position: absolute; height: 100%; background: var(--indigo); border-radius: 3px;\n  }\n  .scen-slider .bar i::after {\n    content: \"\"; position: absolute; right: -6px; top: -4px;\n    width: 12px; height: 12px; border-radius: 50%; background: var(--text);\n    box-shadow: 0 0 0 3px rgba(99,102,241,.3);\n  }\n  .scen-slider .val { font-family: var(--mono); font-size: 12px; font-weight: 700; min-width: 50px; text-align: right; }\n  .scen-result {\n    margin-top: 14px; padding: 12px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 9px;\n    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;\n  }\n  .scen-result .r { font-family: var(--mono); font-size: 11px; }\n  .scen-result .r small { display: block; color: var(--dim); }\n  .scen-result .r b {\n    font-family: var(--display); font-size: 16px; color: var(--text);\n    display: block; margin-top: 2px;\n  }\n  .scen-result .r b.good { color: var(--mint); }\n  .scen-result .r b.bad { color: var(--pink); }\n\n  /* Burn rate */\n  .burn-list .row {\n    display: grid; grid-template-columns: 1fr 80px 56px;\n    gap: 10px; padding: 10px 18px;\n    align-items: center;\n    border-bottom: 1px solid var(--line);\n    font-size: 13px;\n  }\n  .burn-list .row .b {\n    height: 6px; background: var(--line); border-radius: 3px; overflow: hidden;\n  }\n  .burn-list .row .b i { display: block; height: 100%; }\n  .burn-list .row .v { font-family: var(--mono); font-weight: 700; text-align: right; color: var(--pink); }\n  .burn-list .row .lbl small { display: block; color: var(--dim); font-family: var(--mono); font-size: 10px; margin-top: 1px; }\n\n  @media (max-width: 1240px) {\n    .layout { grid-template-columns: 1fr; }\n    .kpis { grid-template-columns: repeat(2, 1fr); }\n  }\n";
