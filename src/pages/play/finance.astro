x=\"202\" y=\"86\" width=\"22\" height=\"34\" rx=\"2\"/>\n                  <rect x=\"234\" y=\"78\" width=\"22\" height=\"42\" rx=\"2\"/>\n                  <rect x=\"266\" y=\"72\" width=\"22\" height=\"48\" rx=\"2\"/>\n                  <rect x=\"298\" y=\"66\" width=\"22\" height=\"54\" rx=\"2\"/>\n                  <rect x=\"330\" y=\"60\" width=\"22\" height=\"60\" rx=\"2\"/>\n                  <rect x=\"362\" y=\"50\" width=\"22\" height=\"70\" rx=\"2\"/>\n                  <rect x=\"394\" y=\"44\" width=\"22\" height=\"76\" rx=\"2\"/>\n                </g>\n                <!-- cash trend line -->\n                <polyline fill=\"none\" stroke=\"#34d399\" stroke-width=\"2.5\" stroke-linejoin=\"round\"\n                  points=\"20,170 52,168 84,160 116,156 148,148 180,138 212,128 244,112 276,98 308,82 340,68 372,48 404,32\"/>\n                <!-- TODAY divider -->\n                <line x1=\"420\" y1=\"0\" x2=\"420\" y2=\"220\" stroke=\"#f59e0b\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\"/>\n                <text x=\"424\" y=\"14\" fill=\"#f59e0b\" font-family=\"JetBrains Mono\" font-size=\"10\" font-weight=\"700\">DAY 12 · NOW</text>\n                <text x=\"424\" y=\"26\" fill=\"#f59e0b\" font-family=\"JetBrains Mono\" font-size=\"10\">$390</text>\n                <!-- projection (dashed) -->\n                <polyline fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"2\" stroke-dasharray=\"5 5\" stroke-linejoin=\"round\"\n                  points=\"420,30 452,28 484,40 516,32 548,50 580,42 612,68 644,80 676,100 708,118 740,140 772,160\"/>\n                <!-- projection band -->\n                <path d=\"M 420 22 L 772 130 L 772 180 L 420 50 Z\" fill=\"#f59e0b\" opacity=\"0.07\"/>\n\n                <!-- crisis marker on Day 9 (Karen P1 #018) -->\n                <circle cx=\"148\" cy=\"148\" r=\"4\" fill=\"#f43f5e\" stroke=\"#0a0d18\" stroke-width=\"2\"/>\n                <circle cx=\"244\" cy=\"112\" r=\"4\" fill=\"#f43f5e\" stroke=\"#0a0d18\" stroke-width=\"2\"/>\n                <circle cx=\"404\" cy=\"32\" r=\"5\" fill=\"#f43f5e\" stroke=\"#0a0d18\" stroke-width=\"2\"/>\n                <text x=\"410\" y=\"20\" fill=\"#f43f5e\" font-family=\"JetBrains Mono\" font-size=\"9\">Karen P1 #042</text>\n              </svg>\n              <div class=\"x-axis\">\n                <div>Day −12</div><div>Day −9</div><div>Day −6</div><div>Day −3</div>\n                <div class=\"now\">TODAY</div>\n                <div>Day +3</div><div>Day +7</div><div>Day +14</div>\n              </div>\n            </div>\n          </section>\n\n          <!-- P&L -->\n          <section class=\"panel pnl-table\">\n            <div class=\"ph\">\n              <h3>P&amp;L · last 12 days</h3>\n              <span class=\"ph-sub\">// vs. Day 0–12 baseline</span>\n              <div class=\"ph-right\">\n                <select style=\"background: var(--panel-2); border: 1px solid var(--line); color: var(--text); padding: 4px 8px; border-radius: 6px; font-family: var(--mono); font-size: 11px;\">\n                  <option>Last 12 days</option><option>Era 1 lifetime</option><option>Custom…</option>\n                </select>\n              </div>\n            </div>\n            <table>\n              <thead>\n                <tr><th>Line</th><th>Days 1–6</th><th>Days 7–12</th><th>Total</th></tr>\n              </thead>\n              <tbody>\n                <tr><td class=\"lbl\">Revenue</td><td class=\"dim\">—</td><td class=\"dim\">—</td><td class=\"dim\">—</td></tr>\n                <tr><td class=\"sub\">Subscriptions (Devon, Karen, Mira-lead)</td><td class=\"pos\">$29</td><td class=\"pos\">$87</td><td class=\"pos\">$116</td></tr>\n                <tr><td class=\"sub\">Overage charges</td><td class=\"pos\">$0</td><td class=\"pos\">$14</td><td class=\"pos\">$14</td></tr>\n                <tr><td class=\"sub\">Marketplace referrals</td><td class=\"pos\">$0</td><td class=\"pos\">$8</td><td class=\"pos\">$8</td></tr>\n                <tr class=\"total\"><td class=\"lbl\">Gross revenue</td><td class=\"pos\">$29</td><td class=\"pos\">$109</td><td class=\"pos\">$138</td></tr>\n                <tr><td class=\"lbl\">COGS</td><td class=\"dim\">—</td><td class=\"dim\">—</td><td class=\"dim\">—</td></tr>\n                <tr><td class=\"sub\">Power &amp; cooling</td><td class=\"neg\">−$24</td><td class=\"neg\">−$33</td><td class=\"neg\">−$57</td></tr>\n                <tr><td class=\"sub\">Bandwidth (peering, transit)</td><td class=\"neg\">−$11</td><td class=\"neg\">−$18</td><td class=\"neg\">−$29</td></tr>\n                <tr><td class=\"sub\">Hardware depreciation</td><td class=\"neg\">−$6</td><td class=\"neg\">−$8</td><td class=\"neg\">−$14</td></tr>\n                <tr class=\"total\"><td class=\"lbl\">Gross profit</td><td class=\"neg\">−$12</td><td class=\"pos\">$50</td><td class=\"pos\">$38</td></tr>\n                <tr><td class=\"lbl\">Opex</td><td class=\"dim\">—</td><td class=\"dim\">—</td><td class=\"dim\">—</td></tr>\n                <tr><td class=\"sub\">Refunds &amp; credits</td><td class=\"neg\">−$0</td><td class=\"neg\">−$19</td><td class=\"neg\">−$19</td></tr>\n                <tr><td class=\"sub\">Garage rent (cousin)</td><td class=\"neg\">−$40</td><td class=\"neg\">−$40</td><td class=\"neg\">−$80</td></tr>\n                <tr><td class=\"sub\">Snacks &amp; coffee</td><td class=\"neg\">−$8</td><td class=\"neg\">−$11</td><td class=\"neg\">−$19</td></tr>\n                <tr class=\"total\"><td class=\"lbl\">Operating loss</td><td class=\"neg\">−$60</td><td class=\"neg\">−$20</td><td class=\"neg\">−$80</td></tr>\n                <tr class=\"grand\"><td class=\"lbl\">Δ Cash position</td><td class=\"neg\">−$60</td><td class=\"neg\">−$20</td><td class=\"neg\">−$80</td></tr>\n              </tbody>\n            </table>\n          </section>\n        </div>\n\n        <!-- Right column -->\n        <div style=\"display: flex; flex-direction: column; gap: 18px;\">\n\n          <!-- Scenario planner -->\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>What-if simulator</h3>\n              <span class=\"ph-sub\">// projects 30 days</span>\n            </div>\n            <div class=\"scen-card\">\n              <div class=\"scen-toggle\">\n                <button>Conservative</button>\n                <button class=\"on\">Realistic</button>\n                <button>Bullish</button>\n              </div>\n\n              <div class=\"scen-row\">\n                <div class=\"lbl\">Price bump<small>Starter plan $19 → $24</small></div>\n                <div class=\"scen-slider\">\n                  <div class=\"bar\"><i style=\"width: 40%\"></i></div>\n                  <span class=\"val\">$24</span>\n                </div>\n              </div>\n              <div class=\"scen-row\">\n                <div class=\"lbl\">New customers / day<small>Marketplace + word of mouth</small></div>\n                <div class=\"scen-slider\">\n                  <div class=\"bar\"><i style=\"width: 30%\"></i></div>\n                  <span class=\"val\">0.6</span>\n                </div>\n              </div>\n              <div class=\"scen-row\">\n                <div class=\"lbl\">Server expansion<small>Buy U18-U20 this week</small></div>\n                <div class=\"scen-slider\">\n                  <div class=\"bar\"><i style=\"width: 66%\"></i></div>\n                  <span class=\"val\">3 units</span>\n                </div>\n              </div>\n              <div class=\"scen-row\">\n                <div class=\"lbl\">Churn from price bump<small>Karen leaves at 81% prob</small></div>\n                <div class=\"scen-slider\">\n                  <div class=\"bar\"><i style=\"width: 81%; background: var(--pink);\"></i></div>\n                  <span class=\"val\">−1</span>\n                </div>\n              </div>\n\n              <div class=\"scen-result\">\n                <div class=\"r\"><small>Cash @ Day 42</small><b class=\"good\">$1,184</b></div>\n                <div class=\"r\"><small>MRR @ Day 42</small><b class=\"good\">$162</b></div>\n                <div class=\"r\"><small>Runway</small><b>78 days</b></div>\n                <div class=\"r\"><small>Era 2 ETA</small><b>Day 38</b></div>\n              </div>\n            </div>\n          </section>\n\n          <!-- Burn breakdown -->\n          <section class=\"panel\">\n            <div class=\"ph\">\n              <h3>Where the money goes</h3>\n              <span class=\"ph-sub\">// $15/day burn</span>\n            </div>\n            <div class=\"burn-list\">\n              <div class=\"row\">\n                <div class=\"lbl\">Power &amp; cooling<small>1.4 kW · ELMÜ residential rate</small></div>\n                <div class=\"b\"><i style=\"width: 60%; background: var(--pink);\"></i></div>\n                <div class=\"v\">−$5.4</div>\n              </div>\n              <div class=\"row\">\n                <div class=\"lbl\">Bandwidth<small>2 TB egress · upstream resale</small></div>\n                <div class=\"b\"><i style=\"width: 40%; background: var(--pink);\"></i></div>\n                <div class=\"v\">−$3.8</div>\n              </div>\n              <div class=\"row\">\n                <div class=\"lbl\">Garage rent<small>\"Cousin Tibi\" weekly</small></div>\n                <div class=\"b\"><i style=\"width: 33%; background: var(--amber);\"></i></div>\n                <div class=\"v\">−$3.3</div>\n              </div>\n              <div class=\"row\">\n                <div class=\"lbl\">Hardware deprec.<small>~$10 / server / month</small></div>\n                <div class=\"b\"><i style=\"width: 18%; background: var(--indigo);\"></i></div>\n                <div class=\"v\">−$1.4</div>\n              </div>\n              <div class=\"row\">\n                <div class=\"lbl\">Refunds / credits<small>Karen, twice</small></div>\n                <div class=\"b\"><i style=\"width: 14%; background: var(--pink);\"></i></div>\n                <div class=\"v\">−$1.1</div>\n              </div>\n            </div>\n          </section>\n\n        </div>\n      </div>\n\n      <!-- Invoices -->\n      <section class=\"panel full\" style=\"margin-top: 18px;\">\n        <div class=\"ph\">\n          <h3>Invoices &amp; transactions</h3>\n          <span class=\"ph-sub\">// 11 total · 1 late</span>\n          <div class=\"ph-right\">\n            <button class=\"btn sm\">All</button>\n            <button class=\"btn sm\">Late · 1</button>\n            <button class=\"btn sm\">Waived · 1</button>\n          </div>\n        </div>\n        <div>\n          <div class=\"inv-row\">\n            <div class=\"av av-K\">K</div>\n            <div>\n              <div class=\"name\">Karen Holloway · INV-009</div>\n              <div class=\"meta\">$19 · Starter · Day 12 (today) · auto-billed</div>\n            </div>\n            <div class=\"status waived\">Waived</div>\n            <div class=\"amt\" style=\"color: var(--dim);\">$0</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-D\">D</div>\n            <div>\n              <div class=\"name\">Devon Park · INV-008</div>\n              <div class=\"meta\">$29 · Builder · Day 11 · card on file ending 4242</div>\n            </div>\n            <div class=\"status paid\">Paid</div>\n            <div class=\"amt\" style=\"color: var(--mint);\">$29</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-M\">M</div>\n            <div>\n              <div class=\"name\">Mira Sato · INV-Q01 (quote)</div>\n              <div class=\"meta\">$1,200 · Enterprise pilot · sent Day 11 · expires Day 14</div>\n            </div>\n            <div class=\"status due\">Pending</div>\n            <div class=\"amt\" style=\"color: var(--amber);\">$1,200</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-A\">A</div>\n            <div>\n              <div class=\"name\">\"Anon\" · INV-007</div>\n              <div class=\"meta\">$67 · overage · Day 10 · ⚠ payment method unverified</div>\n            </div>\n            <div class=\"status late\">7d late</div>\n            <div class=\"amt\" style=\"color: var(--pink);\">$67</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-D\">D</div>\n            <div>\n              <div class=\"name\">Devon Park · INV-006</div>\n              <div class=\"meta\">$29 · Builder · Day 4</div>\n            </div>\n            <div class=\"status paid\">Paid</div>\n            <div class=\"amt\" style=\"color: var(--mint);\">$29</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-K\">K</div>\n            <div>\n              <div class=\"name\">Karen Holloway · INV-005</div>\n              <div class=\"meta\">$15 → $19 · Starter price bump · Day 7 · she noticed</div>\n            </div>\n            <div class=\"status paid\">Paid</div>\n            <div class=\"amt\" style=\"color: var(--mint);\">$19</div>\n          </div>\n          <div class=\"inv-row\">\n            <div class=\"av av-R\">R</div>\n            <div>\n              <div class=\"name\">Rita Chen (churned) · INV-004</div>\n              <div class=\"meta\">$29 · final invoice · Day 5 · refunded after complaint</div>\n            </div>\n            <div class=\"status waived\">Refunded</div>\n            <div class=\"amt\" style=\"color: var(--dim);\">−$29</div>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  </main>\n</div>\n";
