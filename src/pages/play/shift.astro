---
// /play/shift — Shift-mode page. Auth-required.
// Plan 2 Task 13: pre-shift gate (open tickets + LLM-cap), then WS-driven chat UI.
// XSS-safe: customer/AI text is user-supplied → DOM via textContent only, NEVER innerHTML.
//
// Embed mode (`?embed=1`): hides the Base layout chrome (header nav,
// footer) so the page can be rendered inside an <iframe> modal on /play
// without the redundant outer header.
import Base from '../../layouts/Base.astro';
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer, listTickets } from '../../lib/game/db';
import { getLlmUsageToday, getDailyCap } from '../../lib/game/llm-cap';
import I18nDashboard from '../../components/I18nDashboard.astro';
import { t, type Locale, LOCALES } from '../../lib/i18n';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/shift');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

// Mirror /api/shift/start: both 'open' AND 'in_progress' count toward
// the shift-ready check. Otherwise abandoned in_progress tickets leave
// the user staring at "Inbox-empty" while the dashboard CTA still
// reads "9 open tickets waiting".
const openTickets = await listTickets(db, user.id, 'open');
const inProgress = await listTickets(db, user.id, 'in_progress');
const open = [...openTickets, ...inProgress];
const used = await getLlmUsageToday(db, user.id);
const cap = getDailyCap(player.is_pro === 1);
const cap_remaining = cap - used;
const ready = open.length > 0 && cap_remaining >= 5;
const isEmbed = new URL(Astro.request.url).searchParams.get('embed') === '1';

// Locale resolution mirrors signup/login: ?lang= URL param wins, then the
// player's saved preferred_lang, then Accept-Language header. Drives the
// HU/DE labels below so the shift screen doesn't read EN inside a HU UI.
function detectLocale(): Locale {
  const qLang = new URL(Astro.request.url).searchParams.get('lang');
  if (qLang && (LOCALES as readonly string[]).includes(qLang)) return qLang as Locale;
  const saved = (player as { preferred_lang?: string }).preferred_lang;
  if (saved && (LOCALES as readonly string[]).includes(saved)) return saved as Locale;
  const al = Astro.request.headers.get('accept-language') ?? '';
  const first = al.split(',')[0]?.slice(0, 2).toLowerCase();
  if (first && (LOCALES as readonly string[]).includes(first)) return first as Locale;
  return 'en';
}
const locale: Locale = detectLocale();

// Labels consumed by shift-app.ts at runtime. Emitted as a JSON
// <script type="application/json"> block below so the bundled TS can
// read them via document.getElementById('shift-labels').
const shiftLabels = {
  status_pending: t(locale, 'shift.queue.status.pending'),
  status_active: t(locale, 'shift.queue.status.active'),
  status_resolved: t(locale, 'shift.queue.status.resolved'),
  status_abandoned: t(locale, 'shift.queue.status.abandoned'),
  sat: t(locale, 'shift.queue.sat'),
  active_subject: t(locale, 'shift.active.subject'),
  active_sat: t(locale, 'shift.active.sat'),
  end_tickets: t(locale, 'shift.end.tickets'),
  end_total_sat: t(locale, 'shift.end.total_sat'),
  end_refunds: t(locale, 'shift.end.refunds'),
  end_rep: t(locale, 'shift.end.rep'),
  end_unlocked: t(locale, 'shift.end.unlocked'),
  err_could_not_start: t(locale, 'shift.error.could_not_start'),
  err_generic: t(locale, 'shift.error.generic'),
  arch_newbie: t(locale, 'shift.archetype.newbie'),
  arch_pro: t(locale, 'shift.archetype.pro'),
  arch_cheapskate: t(locale, 'shift.archetype.cheapskate'),
  arch_karen: t(locale, 'shift.archetype.karen'),
  arch_loyalist: t(locale, 'shift.archetype.loyalist'),
  arch_ghost: t(locale, 'shift.archetype.ghost'),
  arch_drama: t(locale, 'shift.archetype.drama'),
  arch_crypto: t(locale, 'shift.archetype.crypto'),
};
---
<Base title={t(locale, 'shift.title')}>
  {isEmbed && (
    <style is:global set:html={'header { display: none !important; } footer { display: none !important; } main { padding: 14px !important; max-width: none !important; } body { background: transparent !important; margin: 0 !important; }'}></style>
  )}
  {isEmbed && (
    <script is:inline set:html={`
      // Embed mode auto-resize: post our rendered content height to the
      // parent dialog so the modal shrinks for inbox-zero / pre-shift state
      // and grows when the shift area mounts. Debounced via rAF.
      (function () {
        if (window.parent === window) return;
        var lastH = 0;
        var raf = 0;
        function report() {
          raf = 0;
          // measure outer-padded main + small buffer, ignore overflow:hidden
          var main = document.querySelector('main');
          var h = main ? main.scrollHeight + 28 : document.body.scrollHeight;
          if (h === lastH) return;
          lastH = h;
          try {
            window.parent.postMessage({ type: 'shift-resize', height: h }, '*');
          } catch (e) { /* cross-origin guard */ }
        }
        function schedule() {
          if (raf) return;
          raf = requestAnimationFrame(report);
        }
        var ro = new ResizeObserver(schedule);
        ro.observe(document.body);
        // Re-measure when the hidden shift-area un-hides (class toggle by shift-app).
        var mo = new MutationObserver(schedule);
        mo.observe(document.body, { subtree: true, attributes: true, attributeFilter: ['class', 'style'] });
        window.addEventListener('load', schedule);
        schedule();
      })();
    `}></script>
  )}
  <h1 class="text-2xl font-bold mb-2">{t(locale, 'shift.title')}</h1>
  <p class="text-nt-text-dim mb-4 text-sm">
    {t(locale, 'shift.summary')
      .replace('{open}', String(open.length))
      .replace('{used}', String(cap_remaining))
      .replace('{cap}', String(cap))
      .replace('{shifts}', String(player.free_shifts_today + player.paid_shifts_today))}
  </p>

  <div id="pre-shift" class={ready ? '' : 'hidden'}>
    <button id="start-shift" class="px-6 py-3 bg-nt-accent rounded font-semibold">{t(locale, 'shift.start')}</button>
    <p class="text-nt-text-dim text-xs mt-3">{t(locale, 'shift.length_note')}</p>
  </div>

  {open.length === 0 && (
    <div class="bg-nt-bg-2 p-6 rounded">
      <p class="text-nt-accent mb-2">{t(locale, 'shift.inbox_zero_title')}</p>
      <p class="text-nt-text-dim text-sm">{t(locale, 'shift.inbox_zero_body')}</p>
    </div>
  )}

  {open.length > 0 && cap_remaining < 5 && (
    <div class="bg-nt-bg-2 p-6 rounded">
      <p class="text-yellow-400 mb-2">{t(locale, 'shift.low_budget_title').replace('{rem}', String(cap_remaining)).replace('{cap}', String(cap))}</p>
      <p class="text-nt-text-dim text-sm">{t(locale, 'shift.low_budget_body')}</p>
    </div>
  )}

  <div id="shift-area" class="hidden mt-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <aside class="bg-nt-bg-2 p-4 rounded col-span-1 max-h-[70vh] overflow-y-auto">
        <h2 class="font-bold mb-2 text-sm uppercase text-nt-text-dim">{t(locale, 'shift.queue_head')}</h2>
        <ul id="queue-list" class="space-y-2 text-sm"></ul>
      </aside>
      <section class="md:col-span-2 bg-nt-bg-2 p-4 rounded flex flex-col h-[70vh]">
        <header class="border-b border-nt-border pb-2 mb-2">
          <h3 id="active-customer" class="font-bold">—</h3>
          <p id="active-meta" class="text-xs text-nt-text-dim"></p>
        </header>
        <div id="messages" class="flex-1 overflow-y-auto space-y-2 mb-2"></div>
        <div class="flex gap-2 flex-wrap mb-2 text-xs">
          <button data-action="refund_30" class="px-2 py-1 bg-nt-bg-3 rounded">{t(locale, 'shift.action.refund_30')}</button>
          <button data-action="refund_50" class="px-2 py-1 bg-nt-bg-3 rounded">{t(locale, 'shift.action.refund_50')}</button>
          <button data-action="refund_100" class="px-2 py-1 bg-nt-bg-3 rounded">{t(locale, 'shift.action.refund_100')}</button>
          <button data-action="escalate" class="px-2 py-1 bg-nt-bg-3 rounded">{t(locale, 'shift.action.escalate')}</button>
          <button data-action="investigate" class="px-2 py-1 bg-nt-bg-3 rounded">{t(locale, 'shift.action.investigate')}</button>
          <button data-action="close" class="px-2 py-1 bg-red-500/20 text-red-300 rounded">{t(locale, 'shift.action.close')}</button>
        </div>
        <div class="flex gap-2">
          <input id="msg-input" type="text" placeholder={t(locale, 'shift.compose_ph')} class="flex-1 px-3 py-2 bg-nt-bg-3 border border-nt-border rounded" />
          <button id="msg-send" class="px-3 py-2 bg-nt-accent rounded text-sm font-semibold">{t(locale, 'shift.send')}</button>
        </div>
      </section>
    </div>
    <div id="shift-end" class="hidden bg-nt-bg-2 p-6 rounded mt-6">
      <h2 class="font-bold text-lg mb-2">{t(locale, 'shift.end_title')}</h2>
      <p id="end-summary" class="text-nt-text-dim"></p>
      <a href="/play" class="inline-block mt-4 px-4 py-2 bg-nt-accent rounded">{t(locale, 'shift.back_dashboard')}</a>
    </div>
  </div>

  <script type="application/json" id="shift-labels" set:html={JSON.stringify(shiftLabels)}></script>
  <script>
    // Vite/Astro bundles this import into a hashed asset at build time —
    // unlike `<script src="/src/scripts/...">` which 404s in production.
    import '../../scripts/shift/shift-app';
  </script>
</Base>
