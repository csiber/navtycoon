// /play/leaderboard -- backend wiring complete.
// Global top-100 by MRR + current player's rank.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';
import I18nDashboard from '../../components/I18nDashboard.astro';
import DashboardAnims from '../../components/DashboardAnims.astro';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/leaderboard');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

interface LbRow {
  user_id: string;
  company_name: string;
  mrr_usd_cents: number;
  cash_usd_cents: number;
  current_era: number;
  reputation: number;
  founded_at: number;
}
const lbResults = (await db.prepare(
  'SELECT user_id, company_name, mrr_usd_cents, cash_usd_cents, current_era, ' +
  'reputation, founded_at FROM players ORDER BY mrr_usd_cents DESC, cash_usd_cents DESC LIMIT 100',
).all<LbRow>()).results ?? [];

const rankRow = await db.prepare(
  'SELECT COUNT(*) + 1 AS rank FROM players WHERE mrr_usd_cents > ?',
).bind(player.mrr_usd_cents).first<{ rank: number }>();
const totalRow = await db.prepare(
  'SELECT COUNT(*) AS n FROM players',
).first<{ n: number }>();

const myRank = rankRow?.rank ?? 1;
const totalPlayers = totalRow?.n ?? 1;

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

function rowDay(foundedAt: number): number {
  return Math.max(1, Math.floor((Date.now() / 1000 - foundedAt) / 86400) + 1);
}
function rowInitial(name: string): string {
  return (name[0] ?? '?').toUpperCase();
}

const top3 = lbResults.slice(0, 3).map((r, i) => ({
  rank: i + 1,
  name: r.company_name,
  scoreUsd: (r.cash_usd_cents / 100).toFixed(0),
  mrrUsd: (r.mrr_usd_cents / 100).toFixed(0),
  day: rowDay(r.founded_at),
  initial: rowInitial(r.company_name),
  me: r.user_id === user.id,
}));

const tableRows = lbResults.slice(0, 20).map((r, i) => ({
  rank: i + 1,
  name: r.company_name,
  scoreUsd: (r.cash_usd_cents / 100).toFixed(0),
  mrrUsd: (r.mrr_usd_cents / 100).toFixed(0),
  day: rowDay(r.founded_at),
  era: r.current_era,
  rep: r.reputation,
  initial: rowInitial(r.company_name),
  me: r.user_id === user.id,
}));

const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  displayName,
  myRank,
  totalPlayers,
  top3,
  tableRows,
  myRowMrr: mrrUsd,
  myRowCash: cashUsd,
  myRowDay: dayNum,
  myRowEra: player.current_era,
  myInitial: rowInitial(companyName),
  myUserId: user.id,
};
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 1fr 320px; gap: 18px; }\n  .lb-tabs {\n    display: flex; gap: 4px; padding: 8px 12px;\n    border-bottom: 1px solid var(--line); background: rgba(7,9,15,.4);\n  }\n  .lb-tabs button {\n    padding: 7px 12px; border-radius: 7px;\n    background: transparent; border: 1px solid transparent;\n    color: var(--muted); font-size: 12px; font-family: var(--mono);\n  }\n  .lb-tabs button.on { background: var(--panel-2); color: var(--text); border-color: var(--line); }\n  .lb-tabs .right { margin-left: auto; font-family: var(--mono); font-size: 11px; color: var(--dim); padding: 7px 0; }\n\n  /* Podium */\n  .podium {\n    padding: 26px 24px 36px;\n    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px;\n    align-items: end;\n    border-bottom: 1px solid var(--line);\n    background: linear-gradient(180deg, rgba(245,158,11,.06), transparent 70%);\n  }\n  .pod {\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 14px; padding: 16px 16px 20px;\n    text-align: center; position: relative;\n  }\n  .pod .rank {\n    position: absolute; top: -16px; left: 50%; transform: translateX(-50%);\n    width: 38px; height: 38px; border-radius: 50%;\n    display: grid; place-items: center;\n    font-family: var(--display); font-weight: 700; font-size: 17px;\n    border: 3px solid var(--bg);\n  }\n  .pod.r1 { border-color: rgba(245,158,11,.4); background: linear-gradient(180deg, rgba(245,158,11,.14), var(--panel-2)); padding-bottom: 28px; }\n  .pod.r1 .rank { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1c1300; }\n  .pod.r2 .rank { background: linear-gradient(135deg, #cbd5e1, #94a3b8); color: #1c2230; }\n  .pod.r3 .rank { background: linear-gradient(135deg, #f97316, #c2410c); color: #1c0a00; }\n  .pod .av {\n    width: 56px; height: 56px; border-radius: 14px; margin: 6px auto 10px;\n    display: grid; place-items: center;\n    font-family: var