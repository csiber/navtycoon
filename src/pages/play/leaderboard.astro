font-size: 12px; }\n  .lb-row .v small { font-family: var(--mono); font-size: 10px; color: var(--dim); font-weight: 400; display: block; }\n  .lb-row .v.score { font-family: var(--display); font-size: 16px; color: var(--text); }\n  .lb-row .v.score small { color: var(--mint); font-weight: 700; }\n  .lb-row .v.score small.dn { color: var(--pink); }\n\n  /* Right side: badges + seasonal */\n  .season-card {\n    padding: 18px;\n    background:\n      linear-gradient(135deg, rgba(99,102,241,.18), rgba(34,211,238,.10));\n    border: 1px solid rgba(99,102,241,.3);\n    border-radius: 14px;\n  }\n  .season-card .lbl {\n    font-family: var(--mono); font-size: 10px; color: var(--indigo-2);\n    text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700;\n  }\n  .season-card h3 { margin: 6px 0 4px; font-family: var(--display); font-size: 22px; font-weight: 700; }\n  .season-card .sub { font-size: 13px; color: var(--muted); }\n  .season-card .countdown {\n    display: flex; gap: 8px; margin-top: 14px;\n  }\n  .season-card .cd {\n    flex: 1;\n    background: rgba(0,0,0,.3); border-radius: 8px;\n    padding: 8px;\n    text-align: center;\n  }\n  .season-card .cd b {\n    display: block; font-family: var(--display); font-size: 20px; font-weight: 700;\n  }\n  .season-card .cd small { font-family: var(--mono); font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; }\n  .season-card .rewards {\n    margin-top: 14px;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    padding: 10px 12px; border-radius: 8px; background: rgba(0,0,0,.25);\n  }\n  .season-card .rewards b { color: var(--text); }\n\n  /* Badges */\n  .badge-grid {\n    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;\n    padding: 14px 16px;\n  }\n  .b-cell {\n    aspect-ratio: 1;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 10px;\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    text-align: center; padding: 8px;\n    position: relative;\n  }\n  .b-cell.have {\n    background: linear-gradient(180deg, rgba(52,211,153,.12), var(--panel-2));\n    border-color: rgba(52,211,153,.3);\n  }\n  .b-cell.locked { opacity: 0.45; }\n  .b-cell .ico {\n    font-family: var(--display); font-size: 24px; font-weight: 700;\n    color: var(--text);\n  }\n  .b-cell.have .ico { color: var(--mint); }\n  .b-cell .name {\n    font-family: var(--mono); font-size: 9px; color: var(--muted);\n    margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em;\n    text-align: center; line-height: 1.2;\n  }\n  .b-cell.have .name { color: var(--text); }\n\n  @media (max-width: 1100px) {\n    .layout { grid-template-columns: 1fr; }\n    .lb-row { grid-template-columns: 40px 32px 1fr 80px 80px; }\n    .lb-row .hide-md { display: none; }\n  }\n";
