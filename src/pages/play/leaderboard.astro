/div><div class=\"org\">scroll to find them</div></div>\n            <div></div><div></div><div></div><div class=\"hide-md\"></div><div class=\"hide-md\"></div>\n          </div>\n\n          <div class=\"lb-row me\">\n            <div class=\"rk up\">147 <small>▲ 12</small></div>\n            <div class=\"av\" style=\"background: linear-gradient(135deg, var(--indigo), #4f46e5);\">P</div>\n            <div class=\"who\"><div class=\"name\">promnet — YOU</div><div class=\"org\">@syncnode</div></div>\n            <div class=\"v score\">$390 <small>+$45 / 24h</small></div>\n            <div class=\"v\">$48</div>\n            <div class=\"v\">12</div>\n            <div class=\"v hide-md\">3</div>\n            <div class=\"v hide-md\" style=\"color: var(--amber);\">Era 1</div>\n          </div>\n\n          <div class=\"lb-row\">\n            <div class=\"rk\">148 <small>—</small></div>\n            <div class=\"av\" style=\"background:#94a3b8;\">Z</div>\n            <div class=\"who\"><div class=\"name\">zola.minor</div><div class=\"org\">@cattown</div></div>\n            <div class=\"v score\">$386 <small class=\"dn\">−$4 / 24h</small></div>\n            <div class=\"v\">$29</div>\n            <div class=\"v\">14</div>\n            <div class=\"v hide-md\">2</div>\n            <div class=\"v hide-md\" style=\"color: var(--amber);\">Era 1</div>\n          </div>\n          <div class=\"lb-row\">\n            <div class=\"rk up\">149 <small>▲ 7</small></div>\n            <div class=\"av\" style=\"background:#fbbf24;color:#1c1300;\">H</div>\n            <div class=\"who\"><div class=\"name\">hostmuncher</div><div class=\"org\">@dadbird</div></div>\n            <div class=\"v score\">$382 <small>+$60 / 24h</small></div>\n            <div class=\"v\">$19</div>\n            <div class=\"v\">9</div>\n            <div class=\"v hide-md\">2</div>\n            <div class=\"v hide-md\" style=\"color: var(--amber);\">Era 1</div>\n          </div>\n          <div class=\"lb-row\">\n            <div class=\"rk dn\">150 <small>▼ 4</small></div>\n            <div class=\"av\" style=\"background:#f97316;\">L</div>\n            <div class=\"who\"><div class=\"name\">lex_buckets</div><div class=\"org\">@kettle.io</div></div>\n            <div class=\"v score\">$374 <small class=\"dn\">−$120 / 24h</small></div>\n            <div class=\"v\">$15</div>\n            <div class=\"v\">11</div>\n            <div class=\"v hide-md\">2</div>\n            <div class=\"v hide-md\" style=\"color: var(--amber);\">Era 1</div>\n          </div>\n        </section>\n\n        <!-- Right -->\n        <div style=\"display: flex; flex-direction: column; gap: 18px;\">\n\n          <div class=\"season-card\">\n            <div class=\"lbl\">SEASON 3 · \"Bare Metal Summer\"</div>\n            <h3>4d 18h until reset</h3>\n            <div class=\"sub\">Top 10 get cosmetic rack skins. Top 100 keep their best run on Hall of Fame.</div>\n            <div class=\"countdown\">\n              <div class=\"cd\"><b>04</b><small>days</small></div>\n              <div class=\"cd\"><b>18</b><small>hours</small></div>\n              <div class=\"cd\"><b>22</b><small>min</small></div>\n              <div class=\"cd\"><b>11</b><small>sec</small></div>\n            </div>\n            <div class=\"rewards\">\n              ★ <b>Top 1</b> — Custom AS number cosmetic<br/>\n              ★ <b>Top 10</b> — \"Bare Metal\" rack skin<br/>\n              ★ <b>Top 100</b> — Hall of Fame · permanent\n            </div>\n          </div>\n\n          <section class=\"panel\">\n            <div class=\"ph\"><h3>Badges &amp; achievements</h3><span class=\"ph-sub\">// 4 / 24</span></div>\n            <div class=\"badge-grid\">\n              <div class=\"b-cell have\"><div class=\"ico\">★</div><div class=\"name\">First customer</div></div>\n              <div class=\"b-cell have\"><div class=\"ico\">⚡</div><div class=\"name\">Survived shift</div></div>\n              <div class=\"b-cell have\"><div class=\"ico\">$</div><div class=\"name\">$100 cash</div></div>\n              <div class=\"b-cell have\"><div class=\"ico\">✉</div><div class=\"name\">Closed P1 in 5min</div></div>\n              <div class=\"b-cell\"><div class=\"ico\">⌖</div><div class=\"name\">$1k MRR</div></div>\n              <div class=\"b-cell\"><div class=\"ico\">▤</div><div class=\"name\">Full rack</div></div>\n              <div class=\"b-cell\"><div class=\"ico\">◴</div><div class=\"name\">Multi-region</div></div>\n              <div class=\"b-cell\"><div class=\"ico\">⚒</div><div class=\"name\">No 3 AM pages 30d</div></div>\n              <div class=\"b-cell locked\"><div class=\"ico\">🔒</div><div class=\"name\">Era 4</div></div>\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\"><h3>Friends online</h3><span class=\"ph-sub\">// 3 of 8</span></div>\n            <div style=\"padding: 0 0 8px;\">\n              <div class=\"lb-row\" style=\"grid-template-columns: 36px 1fr auto;\">\n                <div class=\"av\" style=\"background:#34d399;color:#07120c;\">T</div>\n                <div class=\"who\"><div class=\"name\">tia_ops</div><div class=\"org\">rank 5 · LIVE</div></div>\n                <div style=\"font-family: var(--mono); font-size: 10px; color: var(--mint);\">●</div>\n              </div>\n              <div class=\"lb-row\" style=\"grid-template-columns: 36px 1fr auto;\">\n                <div class=\"av\" style=\"background:#a78bfa;\">W</div>\n                <div class=\"who\"><div class=\"name\">wirefraud</div><div class=\"org\">rank 8 · idle</div></div>\n                <div style=\"font-family: var(--mono); font-size: 10px; color: var(--amber);\">●</div>\n              </div>\n              <div class=\"lb-row\" style=\"grid-template-columns: 36px 1fr auto; border: 0;\">\n                <div class=\"av\" style=\"background:#f59e0b;color:#1c1300;\">N</div>\n                <div class=\"who\"><div class=\"name\">nilsson_co</div><div class=\"org\">rank 73 · LIVE</div></div>\n                <div style=\"font-family: var(--mono); font-size: 10px; color: var(--mint);\">●</div>\n              </div>\n            </div>\n          </section>\n\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscales — Leaderboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Sidebar company-card
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;

    // Topbar stats
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);

    // Sidebar foot handle
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // Pagehead count
    const phCount = document.querySelector('.pagehead .count');
    if (phCount) phCount.textContent = 'Season 1 · ' + s.totalPlayers + ' players · You are #' + s.myRank;

    // Podium — replace 3 pod elements with real top3
    const pods = document.querySelectorAll('.podium .pod');
    s.top3.forEach((p, i) => {
      const pod = pods[i === 0 ? 1 : (i === 1 ? 0 : 2)]; // template order: r2,r1,r3
      if (!pod) return;
      const rankEl = pod.querySelector('.rank'); if (rankEl) rankEl.textContent = String(p.rank);
      const avEl = pod.querySelector('.av'); if (avEl) avEl.textContent = p.initial;
      const nameEl = pod.querySelector('.name'); if (nameEl) nameEl.textContent = p.name;
      const orgEl = pod.querySelector('.org'); if (orgEl) orgEl.textContent = '@' + p.name.toLowerCase().replace(/\s+/g, '');
      const scoreEl = pod.querySelector('.score'); if (scoreEl) scoreEl.textContent = '$' + p.scoreUsd;
      const stats = pod.querySelectorAll('.stats span b');
      if (stats[0]) stats[0].textContent = '$' + p.mrrUsd;
      if (stats[1]) stats[1].textContent = String(p.day);
    });

    // Leaderboard table rows — replace the template-rendered "fake" rows in-place.
    // Template has head + 5 fake rows + separator + me-row + 3 more rows.
    // Strategy: collect data-rows (not .head, not .me), trim to top 20, rewrite.
    const allRows = Array.from(document.querySelectorAll('.lb-row'));
    const dataRows = allRows.filter(r => !r.classList.contains('head') && !r.classList.contains('me')
      && !r.querySelector('[style*="padding: 7px"]')); // filter season-card list rows in right column

    // Render up to N rows we have, hide extras.
    const rowsToShow = s.tableRows.slice(0, dataRows.length);
    dataRows.forEach((row, i) => {
      if (i >= rowsToShow.length) { row.style.display = 'none'; return; }
      const data = rowsToShow[i];
      const rk = row.querySelector('.rk');
      if (rk) {
        rk.className = 'rk';
        // First child text node = rank number
        if (rk.firstChild && rk.firstChild.nodeType === 3) rk.firstChild.textContent = String(data.rank) + ' ';
        const small = rk.querySelector('small');
        if (small) small.textContent = '—';
      }
      const av = row.querySelector('.av');
      if (av) av.textContent = data.initial;
      const who = row.querySelector('.who');
      if (who) {
        const nm = who.querySelector('.name'); if (nm) nm.textContent = data.me ? (data.name + ' — YOU') : data.name;
        const org = who.querySelector('.org'); if (org) org.textContent = '@' + data.name.toLowerCase().replace(/\s+/g, '');
      }
      const vs = row.querySelectorAll('.v');
      if (vs[0]) {
        // score cell
        if (vs[0].firstChild && vs[0].firstChild.nodeType === 3) {
          vs[0].firstChild.textContent = '$' + data.scoreUsd + ' ';
        }
        const small = vs[0].querySelector('small');
        if (small) small.textContent = 'rep ' + data.rep;
      }
      if (vs[1]) vs[1].textContent = '$' + data.mrrUsd;
      if (vs[2]) vs[2].textContent = String(data.day);
      if (vs[3]) vs[3].textContent = 'Era ' + data.era;
      if (vs[4]) vs[4].textContent = 'Era ' + data.era;
      if (data.me) {
        row.classList.add('me');
        row.style.background = 'rgba(99,102,241,.06)';
        row.style.borderLeft = '3px solid var(--indigo)';
      }
    });

    // Replace "me" row (the bottom one) with my real data.
    // Note: the hydrator above may have added .me class to a top-N row when
    // the player is in the top 5 (data.me=true). In that case, the bottom
    // template me-row ("promnet — YOU @syncnode") is now a duplicate mock
    // and we hide it.
    const meRows = document.querySelectorAll('.lb-row.me');
    if (meRows.length > 1) {
      // The first hit is our newly-flagged top-N row; later ones are the
      // template mock. Hide all but the first.
      for (let i = 1; i < meRows.length; i++) meRows[i].style.display = 'none';
    }
    const meRow = meRows[0];
    // Also hide any leftover lb-row siblings of the template me-row that
    // weren't reached by the dataRows hydrator (zola.minor, hostmuncher,
    // lex_buckets — they sit after the separator row and after the mock
    // me-row, beyond the indices the loop above covers).
    const templateMockNames = ['zola.minor', 'hostmuncher', 'lex_buckets', 'tia_ops', 'wirefraud', 'nilsson_co', 'koolaid', 'bingbong', 'marcia.exe', 'paulwall', 'Fern Akiyama', 'grimsdotter'];
    document.querySelectorAll('.lb-row').forEach((row) => {
      const nm = row.querySelector('.who .name')?.textContent?.trim() || '';
      if (templateMockNames.some((m) => nm.includes(m))) row.style.display = 'none';
    });
    document.querySelectorAll('.podium .pod .name').forEach((nm) => {
      const t = nm.textContent?.trim() || '';
      if (templateMockNames.some((m) => t.includes(m))) {
        const pod = nm.closest('.pod');
        if (pod) pod.style.display = 'none';
      }
    });
    if (meRow) {
      const rk = meRow.querySelector('.rk');
      if (rk && rk.firstChild && rk.firstChild.nodeType === 3) rk.firstChild.textContent = String(s.myRank) + ' ';
      const small = rk ? rk.querySelector('small') : null;
      if (small) small.textContent = '—';
      const av = meRow.querySelector('.av'); if (av) av.textContent = s.myInitial;
      const who = meRow.querySelector('.who');
      if (who) {
        const nm = who.querySelector('.name'); if (nm) nm.textContent = s.company + ' — YOU';
        const org = who.querySelector('.org'); if (org) org.textContent = '@' + s.company.toLowerCase().replace(/\s+/g, '');
      }
      const vs = meRow.querySelectorAll('.v');
      if (vs[0]) {
        if (vs[0].firstChild && vs[0].firstChild.nodeType === 3) vs[0].firstChild.textContent = '$' + s.myRowCash + ' ';
        const sm = vs[0].querySelector('small'); if (sm) sm.textContent = 'rep ' + s.rep;
      }
      if (vs[1]) vs[1].textContent = '$' + s.myRowMrr;
      if (vs[2]) vs[2].textContent = String(s.myRowDay);
      if (vs[3]) vs[3].textContent = 'Era ' + s.myRowEra;
      if (vs[4]) vs[4].textContent = 'Era ' + s.myRowEra;
    }

    // "142 players above you" → real count
    const aboveRow = document.querySelector('.lb-row[style*="border-top: 2px"]');
    if (aboveRow) {
      const nm = aboveRow.querySelector('.name');
      if (nm) nm.textContent = Math.max(0, s.myRank - 1) + ' players above you';
    }

    // ─── DROP all mock panels that aren't wired to a real backend ─────
    // Season-card (countdown + Bare Metal Summer mock), Badges & achievements
    // (mock + we already pop achievements via /api/game/achievements toast),
    // Friends online (no friends-system) — all removed.
    document.querySelectorAll('.season-card').forEach((el) => el.remove());
    document.querySelectorAll('section.panel').forEach((p) => {
      const h3 = (p.querySelector('h3')?.textContent || '').trim();
      if (/Badges|Kitűzők|Friends online|Barátok online/i.test(h3)) p.remove();
    });
    // "View season prizes →" button (no season-system).
    document.querySelectorAll('.pagehead .h-right .btn').forEach((b) => {
      const t = (b.textContent || '').trim();
      if (/View season prizes|Szezon-jutalmak/i.test(t)) b.remove();
    });
    // Mock "Updated 1m ago · refresh in 04:12" timestamp in lb-tabs.
    document.querySelectorAll('.lb-tabs .right').forEach((el) => el.remove());

    // "Share my run" button → copies https://hyperscales.app/u/<my-id> to clipboard.
    const shareBtn = document.querySelector('.pagehead .h-right .btn');
    if (shareBtn && !shareBtn.classList.contains('primary')) {
      shareBtn.addEventListener('click', async function () {
        const url = location.origin + '/u/' + encodeURIComponent(s.myUserId);
        const text = s.company + ' · Day ' + s.day + ' · Rank #' + s.myRank + ' on Hyperscales';
        const orig = shareBtn.textContent;
        try {
          if (navigator.share) {
            await navigator.share({ title: text, url: url });
            shareBtn.textContent = '✓ Shared';
          } else {
            await navigator.clipboard.writeText(url);
            shareBtn.textContent = '✓ Link copied';
          }
        } catch (err) {
          shareBtn.textContent = '✗ Share failed';
        }
        setTimeout(function () { shareBtn.textContent = orig; }, 2200);
      });
    }

    // Day-counter
    const dayEl = document.querySelector('.clock .day');
    if (dayEl) {
      const small = dayEl.querySelector('small');
      dayEl.textContent = 'Day ' + s.day;
      if (small) { small.textContent = ' / 365'; dayEl.appendChild(small); }
    }
  } catch (e) { console.error('hydrate', e); }
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
<DashboardAnims />
</body>
</html>
