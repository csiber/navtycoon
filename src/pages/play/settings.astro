---
// /play/settings -- backend wiring complete.
// Profile + LLM cap + Pro status from D1.
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';
import { getLlmUsageToday, getDailyCap } from '../../lib/game/llm-cap';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/settings');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const isPro = player.is_pro === 1;
// Cast to D1Database for the llm-cap helper (uses @cloudflare/workers-types).
const llmUsed = await getLlmUsageToday(db as unknown as Parameters<typeof getLlmUsageToday>[0], user.id);
const llmCap = getDailyCap(isPro);
const shiftsToday = player.free_shifts_today + player.paid_shifts_today;

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

const proUntilStr = player.pro_until
  ? new Date(player.pro_until * 1000).toISOString().slice(0, 10)
  : null;
const proDaysLeft = player.pro_until
  ? Math.max(0, Math.floor((player.pro_until - Date.now() / 1000) / 86400))
  : 0;
const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  email: user.email,
  displayName,
  city: player.city ?? '—',
  isPro,
  proUntil: proUntilStr,
  proDaysLeft,
  llmUsed,
  llmCap,
  shiftsToday,
};
const pageCss = "\n  .layout { grid-column: span 12; display: grid; grid-template-columns: 220px 1fr; gap: 18px; }\n\n  /* Settings nav */\n  .set-nav {\n    position: sticky; top: 18px;\n    background: var(--panel); border: 1px solid var(--line);\n    border-radius: 12px; padding: 8px;\n  }\n  .set-nav a {\n    display: grid; grid-template-columns: 22px 1fr;\n    align-items: center; gap: 10px;\n    padding: 8px 10px; border-radius: 7px;\n    font-size: 13px; color: var(--muted);\n    cursor: pointer; transition: background .12s;\n  }\n  .set-nav a:hover { background: var(--panel-2); color: var(--text); }\n  .set-nav a.on { background: var(--panel-2); color: var(--text); }\n  .set-nav a .ico { font-family: var(--mono); color: var(--dim); }\n  .set-nav a.on .ico { color: var(--cyan); }\n\n  /* Section card */\n  .sec {\n    background: var(--panel); border: 1px solid var(--line);\n    border-radius: 12px; padding: 0;\n    margin-bottom: 18px;\n  }\n  .sec-head {\n    padding: 18px 22px 14px;\n    border-bottom: 1px solid var(--line);\n  }\n  .sec-head h2 {\n    margin: 0;\n    font-family: var(--display); font-size: 19px; font-weight: 600;\n    display: flex; align-items: center; gap: 10px;\n  }\n  .sec-head h2 .ico {\n    width: 28px; height: 28px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line-2);\n    display: grid; place-items: center;\n    font-family: var(--mono); font-size: 13px; color: var(--cyan);\n  }\n  .sec-head .sub {\n    font-size: 13px; color: var(--muted); margin-top: 4px;\n  }\n\n  .field {\n    padding: 16px 22px;\n    border-bottom: 1px solid var(--line);\n    display: grid; grid-template-columns: 1fr 280px;\n    gap: 24px; align-items: center;\n  }\n  .field:last-child { border-bottom: 0; }\n  .field .label {\n    font-weight: 500; font-size: 14px; color: var(--text);\n  }\n  .field .label small {\n    display: block; font-weight: 400; font-size: 12px;\n    color: var(--muted); margin-top: 3px; line-height: 1.5;\n  }\n  .field .ctrl { display: flex; justify-content: flex-end; align-items: center; gap: 8px; }\n  .field .warn-note {\n    margin-top: 8px;\n    font-family: var(--mono); font-size: 11px;\n    color: var(--amber);\n    display: flex; gap: 6px; align-items: center;\n  }\n\n  /* Toggle */\n  .toggle {\n    width: 44px; height: 24px; border-radius: 999px;\n    background: var(--panel-3); border: 1px solid var(--line-2);\n    position: relative; cursor: pointer; flex: none;\n    transition: background .15s;\n  }\n  .toggle::after {\n    content: \"\"; position: absolute; top: 2px; left: 2px;\n    width: 18px; height: 18px; border-radius: 50%;\n    background: var(--text); transition: transform .15s;\n  }\n  .toggle.on { background: var(--mint); border-color: var(--mint); }\n  .toggle.on::after { transform: translateX(20px); background: #07120c; }\n\n  /* Segmented control */\n  .seg {\n    display: inline-flex; background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 7px; padding: 2px;\n  }\n  .seg button {\n    padding: 6px 12px; border-radius: 5px;\n    background: transparent; border: 0;\n    color: var(--muted); font-family: var(--mono); font-size: 11px; font-weight: 500;\n  }\n  .seg button.on { background: var(--text); color: var(--bg); }\n\n  /* Slider */\n  .slider {\n    display: grid; grid-template-columns: 1fr 44px; gap: 12px;\n    align-items: center; width: 240px;\n  }\n  .slider .track {\n    height: 4px; background: var(--line); border-radius: 2px;\n    position: relative;\n  }\n  .slider .track i {\n    position: absolute; left: 0; top: 0; bottom: 0;\n    background: var(--cyan); border-radius: 2px;\n  }\n  .slider .track i::after {\n    content: \"\"; position: absolute; right: -7px; top: 50%; transform: translateY(-50%);\n    width: 14px; height: 14px; border-radius: 50%; background: var(--text);\n    border: 2px solid var(--bg); box-shadow: 0 0 0 1px var(--cyan);\n  }\n  .slider .num {\n    font-family: var(--mono); font-size: 12px; font-weight: 700; text-align: right;\n  }\n\n  /* Select */\n  .select {\n    padding: 8px 12px; border-radius: 7px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    color: var(--text); font-family: var(--mono); font-size: 12px;\n    min-width: 180px; cursor: pointer;\n    background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%), linear-gradient(135deg, var(--muted) 50%, transparent 50%);\n    background-position: calc(100% - 13px) 14px, calc(100% - 9px) 14px;\n    background-size: 4px 4px, 4px 4px;\n    background-repeat: no-repeat;\n    appearance: none;\n  }\n\n  /* Color swatch row */\n  .swatches { display: flex; gap: 6px; }\n  .swatch {\n    width: 26px; height: 26px; border-radius: 7px;\n    border: 2px solid transparent;\n    cursor: pointer;\n  }\n  .swatch.on { border-color: var(--text); box-shadow: 0 0 0 1px var(--bg) inset; }\n\n  /* Profile head */\n  .profile-head {\n    padding: 22px;\n    display: grid; grid-template-columns: 72px 1fr auto;\n    gap: 18px; align-items: center;\n  }\n  .profile-head .av {\n    width: 72px; height: 72px; border-radius: 18px;\n    background: linear-gradient(135deg, var(--indigo), #4f46e5);\n    display: grid; place-items: center;\n    font-family: var(--display); font-size: 30px; font-weight: 700; color: #fff;\n    position: relative;\n  }\n  .profile-head .av .edit {\n    position: absolute; bottom: -4px; right: -4px;\n    width: 24px; height: 24px; border-radius: 50%;\n    background: var(--bg); border: 2px solid var(--line-2);\n    display: grid; place-items: center;\n    font-size: 11px; color: var(--text);\n  }\n  .profile-head h3 {\n    margin: 0; font-family: var(--display); font-size: 22px; font-weight: 600;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .profile-head .handle {\n    font-family: var(--mono); font-size: 12px; color: var(--dim);\n    margin-top: 4px;\n  }\n  .profile-head .meta {\n    margin-top: 8px;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    display: flex; gap: 14px;\n  }\n  .profile-head .meta b { color: var(--text); }\n  .profile-head .actions { display: flex; gap: 8px; }\n\n  /* Save bar */\n  .save-bar {\n    position: sticky; bottom: 0;\n    background: rgba(13,17,28,.92); backdrop-filter: blur(8px);\n    border-top: 1px solid var(--line-2);\n    padding: 14px 22px;\n    margin: 0 -28px -16px;\n    display: flex; align-items: center; gap: 14px;\n    z-index: 5;\n  }\n  .save-bar .status {\n    font-family: var(--mono); font-size: 12px; color: var(--mint);\n    display: flex; align-items: center; gap: 8px;\n  }\n  .save-bar .status i { width: 8px; height: 8px; border-radius: 50%; background: var(--mint); box-shadow: 0 0 6px var(--mint); }\n  .save-bar .right { margin-left: auto; display: flex; gap: 8px; }\n\n  /* Danger zone */\n  .danger {\n    border-color: rgba(244,63,94,.3) !important;\n    background: linear-gradient(180deg, rgba(244,63,94,.04), var(--panel));\n  }\n  .danger .sec-head h2 .ico { color: var(--pink); background: rgba(244,63,94,.1); border-color: rgba(244,63,94,.3); }\n\n  @media (max-width: 980px) {\n    .layout { grid-template-columns: 1fr; }\n    .field { grid-template-columns: 1fr; gap: 12px; }\n    .field .ctrl { justify-content: flex-start; }\n  }\n";
const pageHtml = "\n<div class=\"app\">\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscaler</a>\n    <div class=\"company-card\">\n      <div class=\"row\"><div class=\"crest\">SN</div><div><div class=\"name\">SyncNode <span class=\"edit\">✎</span></div><div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div></div></div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> Dashboard</a>\n      <a class=\"nav-item\" href=\"/play/servers\"><span class=\"ico\">▤</span> Servers <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> Customers <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> Tickets <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> Finance</a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Grow</div>\n      <a class=\"nav-item\" href=\"/play/research\"><span class=\"ico\">⚙</span> Research <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> Marketplace</a>\n      <a class=\"nav-item locked\" href=\"/play/staff\"><span class=\"ico\">☰</span> Staff <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item locked\" href=\"/play/network\"><span class=\"ico\">◴</span> Network <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> Leaderboard</a>\n      <a class=\"nav-item\" href=\"/play/devlog\"><span class=\"ico\">▶</span> Devlog</a>\n      <a class=\"nav-item active\"><span class=\"ico\">⚒</span> Settings</a>\n    </div>\n    <div class=\"side-foot\"><div>v0.7.2 · build 18,402</div><a href=\"#\">⌨ Shortcuts ⌘K</a><div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div></div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Meta</span><span class=\"sep\">›</span><b>Settings</b><span class=\"sep\">›</span><span>Profile, gameplay, AI, audio, data</span></div>\n      <div class=\"clock\"><div class=\"day\">Day 12<small> / 365</small></div><div class=\"time\">03:42 AM</div><div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div></div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Settings <span class=\"count\">Auto-saved 2s ago</span></h1>\n          <div class=\"sub\">Tune your save, your face, your AI advisor, and your pager.</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">Reset to defaults</button>\n          <button class=\"btn primary\">Export save (.json)</button>\n        </div>\n      </div>\n\n      <div class=\"layout\">\n\n        <!-- Settings sub-nav -->\n        <nav class=\"set-nav\">\n          <a class=\"on\"><span class=\"ico\">◉</span>Profile</a>\n          <a><span class=\"ico\">▶</span>Gameplay</a>\n          <a><span class=\"ico\">⚙</span>AI advisor</a>\n          <a><span class=\"ico\">✉</span>Notifications</a>\n          <a><span class=\"ico\">♪</span>Audio</a>\n          <a><span class=\"ico\">▣</span>Display &amp; UI</a>\n          <a><span class=\"ico\">⌨</span>Controls</a>\n          <a><span class=\"ico\">⌖</span>Multiplayer</a>\n          <a><span class=\"ico\">💾</span>Save &amp; data</a>\n          <a><span class=\"ico\">⚠</span>Danger zone</a>\n        </nav>\n\n        <!-- Right column -->\n        <div>\n\n          <!-- Profile -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">◉</span> Profile</h2>\n              <div class=\"sub\">How you show up on leaderboards and other players' reputation pages.</div>\n            </div>\n            <div class=\"profile-head\">\n              <div class=\"av\">P<span class=\"edit\">✎</span></div>\n              <div>\n                <h3>promnet <span style=\"font-family:var(--mono);font-size:11px;color:var(--mint);padding:3px 8px;border-radius:999px;background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;\">VERIFIED</span></h3>\n                <div class=\"handle\">@syncnode · joined Season 1 · 142 hours played</div>\n                <div class=\"meta\">\n                  <span>Rank <b>#147</b></span>\n                  <span>Best <b>$1,402</b></span>\n                  <span>Saves <b>3</b></span>\n                  <span>Friends <b>8</b></span>\n                </div>\n              </div>\n              <div class=\"actions\">\n                <button class=\"btn sm\">Share /rep page</button>\n                <button class=\"btn sm\">Edit avatar</button>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Display name<small>Shown on leaderboards and in customer tickets.</small></div>\n              <div class=\"ctrl\">\n                <input class=\"select\" value=\"promnet\" style=\"font-family: var(--mono);\" />\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Company name<small>Your in-game brand. Customers see this on invoices.</small></div>\n              <div class=\"ctrl\">\n                <input class=\"select\" value=\"SyncNode\" style=\"font-family: var(--mono);\" />\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Public reputation page<small>Lets others link to your stats. Disable to stay anonymous.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Show on global leaderboard<small>Your rank and score still update — just hidden from the public ladder.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n          </section>\n\n          <!-- Gameplay -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">▶</span> Gameplay</h2>\n              <div class=\"sub\">Tune difficulty, pacing, and how forgiving the sim is.</div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Difficulty<small>Adjusts customer churn rates, P1 spawn frequency, and starting cash.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"seg\">\n                  <button>Casual</button>\n                  <button class=\"on\">Standard</button>\n                  <button>Hard</button>\n                  <button>Karen mode</button>\n                </div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Game speed multiplier<small>1 in-game day = N seconds of real time. The pause button still works.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"slider\"><div class=\"track\"><i style=\"width:60%;\"></i></div><span class=\"num\">1.5×</span></div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Auto-pause on P1 ticket<small>Stop the sim when a fire starts so you can read before you panic.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Show tutorial hints<small>Era 1 only. New mechanics get a popup the first time they appear.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Permadeath mode<small>If you go bankrupt, the save is sealed. No rewinds. Leaderboard flair.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"toggle\"></div>\n              </div>\n            </div>\n          </section>\n\n          <!-- AI advisor -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">⚙</span> AI advisor</h2>\n              <div class=\"sub\">\"Lin-1\" reads your sim and surfaces what's about to break. Configure how loud she gets.</div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Advisor model<small>Controls quality of suggestions. Premium runs your own API key — slower but smarter.</small></div>\n              <div class=\"ctrl\">\n                <select class=\"select\">\n                  <option>Built-in (free)</option>\n                  <option>Claude Haiku · default</option>\n                  <option>Claude Sonnet · premium</option>\n                  <option>BYO API key</option>\n                </select>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Suggestion frequency<small>How often Lin-1 pops up with proactive advice.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"seg\"><button>Off</button><button>Low</button><button class=\"on\">Med</button><button>High</button></div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Auto-action threshold<small>If confidence is above this, Lin acts without asking (e.g. auto-refund a $19 ticket).</small></div>\n              <div class=\"ctrl\">\n                <div class=\"slider\"><div class=\"track\"><i style=\"width:85%;\"></i></div><span class=\"num\">95%</span></div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Personality<small>How Lin-1 talks to you. Affects copy in advisor banner.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"seg\"><button>Dry</button><button class=\"on\">Direct</button><button>Warm</button><button>Snarky</button></div>\n              </div>\n            </div>\n          </section>\n\n          <!-- Notifications -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">✉</span> Notifications &amp; pager</h2>\n              <div class=\"sub\">When and how the game interrupts you. Yes, this is the famous \"pager\" panel.</div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">In-game pager — P1 tickets<small>Sound + screen flash when a P1 fires.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Desktop notifications<small>Push notifications when you alt-tab away from the game.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">\"Quiet hours\"<small>Pages defer to a daily summary. Honored by P1+. Configure schedule below.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Quiet hours window<small>Real clock time. Game still runs; you just sleep.</small></div>\n              <div class=\"ctrl\">\n                <select class=\"select\" style=\"min-width:130px;\">\n                  <option>11 PM → 7 AM</option>\n                </select>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Email digest<small>Daily summary of overnight events.</small></div>\n              <div class=\"ctrl\">\n                <select class=\"select\"><option>Daily 9 AM</option></select>\n              </div>\n            </div>\n          </section>\n\n          <!-- Audio + UI -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">♪</span> Audio &amp; UI</h2>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Master volume</div>\n              <div class=\"ctrl\"><div class=\"slider\"><div class=\"track\"><i style=\"width:70%;\"></i></div><span class=\"num\">70</span></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Pager / alert sounds<small>The 3 AM noise. Tunable.</small></div>\n              <div class=\"ctrl\"><div class=\"slider\"><div class=\"track\"><i style=\"width:45%;\"></i></div><span class=\"num\">45</span></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Ambient datacenter hum<small>Fans, HVAC, distant beeping.</small></div>\n              <div class=\"ctrl\"><div class=\"slider\"><div class=\"track\"><i style=\"width:30%;\"></i></div><span class=\"num\">30</span></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">UI theme<small>Dark \"rack room\" is canon.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"seg\"><button class=\"on\">Dark</button><button>Amber CRT</button><button>High contrast</button></div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Accent color</div>\n              <div class=\"ctrl\">\n                <div class=\"swatches\">\n                  <div class=\"swatch on\" style=\"background:#22d3ee;\"></div>\n                  <div class=\"swatch\" style=\"background:#6366f1;\"></div>\n                  <div class=\"swatch\" style=\"background:#34d399;\"></div>\n                  <div class=\"swatch\" style=\"background:#f59e0b;\"></div>\n                  <div class=\"swatch\" style=\"background:#f43f5e;\"></div>\n                  <div class=\"swatch\" style=\"background:#a78bfa;\"></div>\n                </div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">UI density<small>Cozy = more whitespace. Compact = more data per screen.</small></div>\n              <div class=\"ctrl\">\n                <div class=\"seg\"><button>Cozy</button><button class=\"on\">Normal</button><button>Compact</button></div>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Reduce motion<small>Disables clock ticking animations and event-feed slide-ins.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle\"></div></div>\n            </div>\n          </section>\n\n          <!-- Save & data -->\n          <section class=\"sec\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">💾</span> Save &amp; data</h2>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Cloud sync<small>3 saves synced across devices. Conflict resolution by last-write.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Auto-save interval<small>Real-time minutes between snapshots.</small></div>\n              <div class=\"ctrl\">\n                <select class=\"select\"><option>Every 2 minutes</option></select>\n              </div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Anonymous gameplay telemetry<small>Helps us tune difficulty. No content, no chat.</small></div>\n              <div class=\"ctrl\"><div class=\"toggle on\"></div></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Active save · \"SyncNode\"<small>3 saves · last opened Day 12 · 142 hours total</small></div>\n              <div class=\"ctrl\">\n                <button class=\"btn sm\">Manage saves →</button>\n              </div>\n            </div>\n          </section>\n\n          <!-- Danger zone -->\n          <section class=\"sec danger\">\n            <div class=\"sec-head\">\n              <h2><span class=\"ico\">⚠</span> Danger zone</h2>\n              <div class=\"sub\">Permanent. Cannot be undone. Read twice.</div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Reset current save<small>Wipes Day 12 progress. Keeps your profile, leaderboard history, badges.</small></div>\n              <div class=\"ctrl\"><button class=\"btn sm\" style=\"border-color: rgba(244,63,94,.3); color: var(--pink);\">Reset save</button></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Forfeit season<small>Removes you from Season 3 ladder. You can rejoin next season.</small></div>\n              <div class=\"ctrl\"><button class=\"btn sm\" style=\"border-color: rgba(244,63,94,.3); color: var(--pink);\">Forfeit</button></div>\n            </div>\n            <div class=\"field\">\n              <div class=\"label\">Delete account<small>Removes profile, saves, friends, achievements, /rep page. Permanent.</small></div>\n              <div class=\"ctrl\"><button class=\"btn sm\" style=\"background: var(--pink); border-color: var(--pink); color: #fff;\">Delete account</button></div>\n            </div>\n          </section>\n\n          <!-- Sticky save bar -->\n          <div class=\"save-bar\">\n            <div class=\"status\"><i></i>All changes saved · 2s ago</div>\n            <div class=\"right\">\n              <button class=\"btn\">Discard</button>\n              <button class=\"btn primary\">Apply &amp; resume sim</button>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Settings</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);
    // Sidebar company-card
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    // Topbar stats
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    // Sidebar "me" footer (avatar letter + handle)
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      // last text node is the handle
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }
    // Profile section: displayName input + company input
    const fields = document.querySelectorAll('.field');
    fields.forEach(f => {
      const lbl = f.querySelector('.label');
      const inp = f.querySelector('input.select');
      if (!lbl || !inp) return;
      const lblText = (lbl.firstChild && lbl.firstChild.textContent || '').trim();
      if (lblText.startsWith('Display name')) inp.value = s.displayName;
      if (lblText.startsWith('Company name')) inp.value = s.company;
    });
    // Profile head: handle / meta / h3
    const ph = document.querySelector('.profile-head');
    if (ph) {
      const h3 = ph.querySelector('h3');
      if (h3 && h3.firstChild) h3.firstChild.textContent = s.displayName + ' ';
      // Verified-pill stays static if Pro; replace with FREE/PRO
      const verPill = h3 ? h3.querySelector('span') : null;
      if (verPill) verPill.textContent = s.isPro ? 'PRO' : 'FREE';
      const handle = ph.querySelector('.handle');
      if (handle) {
        handle.textContent = '@' + s.company.toLowerCase().replace(/\s+/g, '') +
          ' · ' + s.email + (s.city && s.city !== '—' ? ' · ' + s.city : '');
      }
      // Meta row: Rank / Best / Saves / Friends - repurpose to game data
      const metaEl = ph.querySelector('.meta');
      if (metaEl) {
        const spans = metaEl.querySelectorAll('span b');
        if (spans[0]) spans[0].textContent = '$' + s.cashUsd;       // Cash
        if (spans[1]) spans[1].textContent = '$' + s.mrrUsd;        // MRR
        if (spans[2]) spans[2].textContent = String(s.rep);         // Rep
        if (spans[3]) spans[3].textContent = String(s.day);         // Day
        // Replace labels via parent textContent (preserves <b>)
        const items = metaEl.querySelectorAll('span');
        if (items[0] && items[0].firstChild && items[0].firstChild.nodeType === 3) items[0].firstChild.textContent = 'Cash ';
        if (items[1] && items[1].firstChild && items[1].firstChild.nodeType === 3) items[1].firstChild.textContent = 'MRR ';
        if (items[2] && items[2].firstChild && items[2].firstChild.nodeType === 3) items[2].firstChild.textContent = 'Rep ';
        if (items[3] && items[3].firstChild && items[3].firstChild.nodeType === 3) items[3].firstChild.textContent = 'Day ';
      }
    }
    // Add a real-data callout into the Profile section (replace template's stats with LLM cap / Pro status).
    // Find "Active save" field (Save & data section) and replace its label/sub.
    fields.forEach(f => {
      const lbl = f.querySelector('.label');
      if (!lbl) return;
      const labelText = (lbl.firstChild && lbl.firstChild.textContent || '').trim();
      if (labelText.startsWith('Active save')) {
        if (lbl.firstChild) lbl.firstChild.textContent = 'Active company · "' + s.company + '"';
        const small = lbl.querySelector('small');
        if (small) {
          small.textContent = 'Era ' + s.era + ' · Day ' + s.day + ' · ' + s.shiftsToday + ' shifts today';
        }
      }
      // Repurpose "Advisor model" small-line as LLM-cap status
      if (labelText.startsWith('Advisor model')) {
        const small = lbl.querySelector('small');
        if (small) {
          small.textContent = 'LLM cap today: ' + s.llmUsed + ' / ' + s.llmCap +
            (s.isPro ? ' (Pro)' : ' (Free)');
        }
      }
      // Repurpose Difficulty small as Pro-status
      if (labelText.startsWith('Difficulty')) {
        const small = lbl.querySelector('small');
        if (small) {
          small.textContent = s.isPro
            ? 'Pro active' + (s.proUntil ? ' until ' + s.proUntil + ' (' + s.proDaysLeft + 'd left)' : '')
            : 'Free tier — upgrade to Pro for 50 LLM calls/day';
        }
      }
    });
  } catch (e) { console.error('hydrate', e); }
</script>
<div id="settings-edit-wrap" style="max-width: 600px; margin: 24px auto; padding: 24px; background: var(--panel); border: 1px solid var(--line); border-radius: 12px;">
  <h3 style="font-family: var(--display); margin: 0 0 16px;">Edit profile</h3>
  <label style="display:block;font-size:12px;color:var(--dim);margin-bottom:4px;">Company name</label>
  <input id="set-company-name" type="text" value={player.company_name}
         maxlength="60" required minlength="2"
         style="width:100%;padding:10px;background:var(--panel-2);border:1px solid var(--line);border-radius:8px;color:var(--text);margin-bottom:14px;" />
  <label style="display:block;font-size:12px;color:var(--dim);margin-bottom:4px;">City</label>
  <input id="set-city" type="text" value={player.city ?? ''}
         maxlength="60"
         style="width:100%;padding:10px;background:var(--panel-2);border:1px solid var(--line);border-radius:8px;color:var(--text);margin-bottom:14px;" />
  <button id="set-save"
          style="padding:10px 20px;background:var(--indigo);color:#fff;border:0;border-radius:8px;font-weight:600;cursor:pointer;">Save changes</button>
  <p id="set-status" style="margin-top:10px;font-size:12px;color:var(--dim);"></p>

  <div style="margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--line);">
    <h3 style="font-family: var(--display); margin: 0 0 8px; font-size: 16px;">Subscription</h3>
    {isPro ? (
      <div>
        <p style="margin: 0 0 12px; font-size: 13px; color: var(--mint);">
          ✓ Pro active{proUntilStr ? ` until ${proUntilStr}` : ''}
        </p>
        <p style="margin: 0 0 12px; font-size: 12px; color: var(--muted);">
          Pro grants 5 shifts/day, 50 LLM calls/day, <b style="color:var(--text)">2× customer-acquisition</b>, and
          <b style="color:var(--text)">0.5× churn</b> on idle tickets. Synced from your PromNET subscription.
        </p>
        <a href="https://promnet.hu/app/szamlazas" target="_blank" rel="noopener"
           style="display:inline-block;padding:8px 16px;background:var(--panel-2);color:var(--text);border:1px solid var(--line);border-radius:8px;font-size:13px;text-decoration:none;">
          Manage subscription on PromNET →
        </a>
      </div>
    ) : (
      <div>
        <p style="margin: 0 0 13px; font-size: 13px; color: var(--muted);">
          You're on the Free tier: 1 shift/day, 5 LLM calls/day. Upgrade to Pro on PromNET to unlock
          <b style="color:var(--text)">5× shifts</b>,
          <b style="color:var(--text)">10× AI budget</b>,
          <b style="color:var(--mint)">2× customer-acquisition</b>, and
          <b style="color:var(--mint)">half-rate churn</b>.
        </p>
        <a href="https://promnet.hu/app/szamlazas" target="_blank" rel="noopener"
           style="display:inline-block;padding:10px 20px;background:linear-gradient(135deg, var(--indigo), #4f46e5);color:#fff;border:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;">
          Upgrade to Pro →
        </a>
        <p style="margin: 10px 0 0; font-size: 11px; color: var(--dim); font-family: var(--mono);">
          Active PromNET sub → Pro grant on next page-load.
        </p>
      </div>
    )}
  </div>
</div>
<script is:inline>
  (function () {
    var btn = document.getElementById('set-save');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      var cn = document.getElementById('set-company-name').value.trim();
      var city = document.getElementById('set-city').value.trim();
      var status = document.getElementById('set-status');
      if (cn.length < 2) {
        status.textContent = 'Company name min 2 chars';
        status.style.color = 'var(--pink)';
        return;
      }
      status.textContent = 'Saving...';
      status.style.color = 'var(--dim)';
      try {
        var r = await fetch('/api/game/settings', {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ company_name: cn, city: city || null }),
        });
        var j = await r.json();
        if (!j.ok) {
          status.textContent = 'Error: ' + (j.error || 'unknown');
          status.style.color = 'var(--pink)';
          return;
        }
        status.textContent = '✓ Saved. Reloading...';
        status.style.color = 'var(--mint)';
        setTimeout(function () { location.reload(); }, 800);
      } catch (e) {
        status.textContent = 'Network error';
        status.style.color = 'var(--pink)';
      }
    });
  })();
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
</body>
</html>
