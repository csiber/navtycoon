---
// /play/staff -- backend wiring complete (placeholder; hire feature ships post Plan 3).
import { getCurrentUser, getDB } from '../../lib/auth';
import { getPlayer } from '../../lib/game/db';
import I18nDashboard from '../../components/I18nDashboard.astro';
import DashboardAnims from '../../components/DashboardAnims.astro';

type AnyCtx = Parameters<typeof getCurrentUser>[0];
const ctx = Astro as unknown as AnyCtx;

const user = await getCurrentUser(ctx);
if (!user) return Astro.redirect('/login?next=/play/staff');
const db = getDB(ctx);
if (!db) return new Response('No DB', { status: 500 });
const player = await getPlayer(db, user.id);
if (!player) return Astro.redirect('/signup');

const customerCount = (await db.prepare(
  'SELECT COUNT(*) AS n FROM customers WHERE player_id = ? AND is_active = 1',
).bind(user.id).first<{ n: number }>())?.n ?? 0;

const companyName = player.company_name;
const cashUsd = (player.cash_usd_cents / 100).toFixed(0);
const mrrUsd = (player.mrr_usd_cents / 100).toFixed(0);
const founded = new Date(player.founded_at * 1000).getFullYear();
const dayNum = Math.max(1, Math.floor((Date.now() / 1000 - player.founded_at) / 86400) + 1);
const initials = companyName.split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase() || 'HY';
const displayName = user.display_name ?? user.email.split('@')[0] ?? 'player';

const stateObj = {
  company: companyName,
  initials,
  cashUsd,
  mrrUsd,
  rep: player.reputation,
  era: player.current_era,
  founded,
  day: dayNum,
  displayName,
  customerCount,
  mrrCents: player.mrr_usd_cents,
};
const pageCss = "\n  .lockwrap { grid-column: span 12; position: relative; }\n  .blur { filter: blur(3px) saturate(0.6); opacity: 0.45; pointer-events: none; user-select: none; }\n  .lock-overlay {\n    position: absolute; inset: 0;\n    display: grid; place-items: center;\n    background:\n      radial-gradient(ellipse at center, rgba(10,13,24,.7) 30%, rgba(10,13,24,.95) 80%);\n    z-index: 10;\n  }\n  .lock-card {\n    width: min(560px, 90%);\n    background: var(--panel);\n    border: 1px solid var(--line-2);\n    border-radius: 16px;\n    padding: 32px;\n    text-align: center;\n    box-shadow: 0 20px 60px rgba(0,0,0,.5), 0 0 0 1px var(--line);\n    position: relative;\n  }\n  .lock-card .badge {\n    display: inline-block;\n    font-family: var(--mono); font-size: 11px;\n    padding: 5px 12px; border-radius: 999px;\n    background: rgba(245,158,11,.12); color: var(--amber);\n    border: 1px solid rgba(245,158,11,.3);\n    text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700;\n    margin-bottom: 16px;\n  }\n  .lock-card h1 {\n    margin: 0 0 8px;\n    font-family: var(--display); font-size: 32px; font-weight: 700;\n    background: linear-gradient(135deg, var(--text), var(--amber));\n    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;\n  }\n  .lock-card .sub {\n    font-size: 15px; color: var(--muted); line-height: 1.55;\n    max-width: 420px; margin: 0 auto 24px;\n  }\n  .lock-card .requirements {\n    text-align: left;\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 10px; padding: 14px 16px;\n    margin-bottom: 20px;\n  }\n  .lock-card .req {\n    display: grid; grid-template-columns: 24px 1fr auto;\n    align-items: center; gap: 10px;\n    padding: 8px 0;\n    font-size: 13px;\n  }\n  .lock-card .req + .req { border-top: 1px dashed var(--line); }\n  .lock-card .req .ck {\n    width: 18px; height: 18px; border-radius: 50%;\n    border: 1.5px solid var(--line-2);\n    display: grid; place-items: center;\n    font-size: 11px; color: transparent;\n  }\n  .lock-card .req.done .ck { background: var(--mint); border-color: var(--mint); color: #07120c; }\n  .lock-card .req .lbl { color: var(--text); }\n  .lock-card .req.done .lbl { color: var(--dim); text-decoration: line-through; }\n  .lock-card .req .progress {\n    font-family: var(--mono); font-size: 11px; color: var(--amber); font-weight: 700;\n  }\n  .lock-card .req.done .progress { color: var(--mint); }\n  .lock-card .cta-row {\n    display: flex; gap: 10px; justify-content: center;\n  }\n  .lock-card .preview-note {\n    margin-top: 18px;\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n  }\n\n  /* Sneak-peek roster */\n  .roster-head {\n    padding: 16px 22px;\n    border-bottom: 1px solid var(--line);\n    display: flex; align-items: baseline; gap: 12px;\n  }\n  .roster-head h3 { margin: 0; font-family: var(--display); font-size: 18px; font-weight: 600; }\n  .roster-grid {\n    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;\n  }\n  .hire-card {\n    padding: 18px 20px;\n    border-right: 1px solid var(--line);\n    border-bottom: 1px solid var(--line);\n  }\n  .hire-card:last-child { border-right: 0; }\n  .hire-card .row1 { display: flex; align-items: center; gap: 12px; }\n  .hire-card .av {\n    width: 48px; height: 48px; border-radius: 12px;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-weight: 700; font-size: 18px; color: #fff;\n  }\n  .hire-card .name { font-family: var(--display); font-size: 16px; font-weight: 600; }\n  .hire-card .role {\n    font-family: var(--mono); font-size: 10px; color: var(--cyan);\n    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px;\n  }\n  .hire-card .salary { margin-left: auto; font-family: var(--mono); font-weight: 700; color: var(--amber); }\n  .hire-card .salary small { color: var(--dim); font-weight: 400; }\n  .hire-card .blurb { margin-top: 10px; font-size: 13px; color: var(--muted); line-height: 1.5; }\n  .hire-card .stats { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }\n  .hire-card .stat {\n    font-family: var(--mono); font-size: 10px;\n    padding: 3px 8px; border-radius: 5px;\n    background: var(--panel-2); border: 1px solid var(--line);\n    color: var(--muted);\n  }\n  .hire-card .stat b { color: var(--text); }\n  .hire-card .quirk {\n    margin-top: 10px;\n    font-family: var(--mono); font-size: 11px; color: var(--amber);\n    padding: 6px 10px; border-radius: 6px;\n    background: rgba(245,158,11,.06); border: 1px dashed rgba(245,158,11,.25);\n  }\n  .hire-card .quirk b { color: var(--text); }\n\n  @media (max-width: 1100px) {\n    .roster-grid { grid-template-columns: 1fr; }\n  }\n";
const pageHtml = "\n<div class=\"app\">\n  <aside>\n    <a class=\"brand\" href=\"/play\"><div class=\"brand-mark\"></div>Hyperscales</a>\n    <div class=\"company-card\">\n      <div class=\"row\"><div class=\"crest\">SN</div><div><div class=\"name\">SyncNode <span class=\"edit\">✎</span></div><div class=\"sub\">EST 2026 · ERA 1 · DAY 12</div></div></div>\n      <div class=\"runway\"><span>Runway</span><b>26 days</b></div>\n      <div class=\"bar\"><i></i></div>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.operate\">Operate</div>\n      <a class=\"nav-item\" href=\"/play\"><span class=\"ico\">▣</span> <span data-i18n=\"dash.nav.dashboard\">Dashboard</span></a>\n      <a class=\"nav-item\" href=\"/play/servers\"><span class=\"ico\">▤</span> <span data-i18n=\"dash.nav.servers\">Servers</span> <span class=\"badge muted\">2</span></a>\n      <a class=\"nav-item\" href=\"/play/customers\"><span class=\"ico\">◉</span> <span data-i18n=\"dash.nav.customers\">Customers</span> <span class=\"badge new\">+1</span></a>\n      <a class=\"nav-item\" href=\"/play/tickets\"><span class=\"ico\">✉</span> <span data-i18n=\"dash.nav.tickets\">Tickets</span> <span class=\"badge\">3</span></a>\n      <a class=\"nav-item\" href=\"/play/finance\"><span class=\"ico\">$</span> <span data-i18n=\"dash.nav.finance\">Finance</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.grow\">Grow</div>\n      <a class=\"nav-item\" href=\"/play/research\"><span class=\"ico\">⚙</span> <span data-i18n=\"dash.nav.research\">Research</span> <span class=\"badge muted\">0/12</span></a>\n      <a class=\"nav-item\" href=\"/play/marketplace\"><span class=\"ico\">◈</span> <span data-i18n=\"dash.nav.marketplace\">Marketplace</span></a>\n      <a class=\"nav-item active locked\"><span class=\"ico\">☰</span> <span data-i18n=\"dash.nav.staff\">Staff</span> <span class=\"lock\">🔒 Era 2</span></a>\n      <a class=\"nav-item locked\" href=\"/play/network\"><span class=\"ico\">◴</span> <span data-i18n=\"dash.nav.network\">Network</span> <span class=\"lock\">🔒 Era 2</span></a>\n    </div>\n    <div class=\"nav-section\">\n      <div class=\"nav-head\" data-i18n=\"dash.nav.meta\">Meta</div>\n      <a class=\"nav-item\" href=\"/play/leaderboard\"><span class=\"ico\">⌖</span> <span data-i18n=\"dash.nav.leaderboard\">Leaderboard</span></a>\n      <a class=\"nav-item\" href=\"/play/devlog\"><span class=\"ico\">▶</span> <span data-i18n=\"dash.nav.devlog\">Devlog</span></a>\n      <a class=\"nav-item\" href=\"/play/settings\"><span class=\"ico\">⚒</span> <span data-i18n=\"dash.nav.settings\">Settings</span></a>\n    </div>\n    <div class=\"side-foot\"><div>v0.7.2 · build 18,402</div><a href=\"#\">⌨ Shortcuts ⌘K</a><div class=\"me\"><span class=\"ava\">P</span>promnet · log out</div></div>\n  </aside>\n\n  <main>\n    <header class=\"topbar\">\n      <div class=\"crumbs\"><span>Play</span><span class=\"sep\">›</span><b>Staff</b><span class=\"sep\">›</span><span style=\"color:var(--amber)\">🔒 Era 2 required</span></div>\n      <div class=\"clock\"><div class=\"day\">Day 12<small> / 365</small></div><div class=\"time\">03:42 AM</div><div class=\"ctrls\"><button>‖</button><button class=\"on\">▶</button><button>▶▶</button></div></div>\n      <div class=\"topbar-stats\">\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.cash\">Cash</span><span class=\"v\">$390<small>+$45/d</small></span></div>\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.mrr\">MRR</span><span class=\"v\">$15<small>+$0</small></span></div>\n        <div class=\"tstat\"><span class=\"k\" data-i18n=\"dash.topbar.rep\">Rep</span><span class=\"v\">50<small class=\"dn\">−2</small></span></div>\n      </div>\n      <div class=\"topbar-actions\"><button class=\"bell\" data-count=\"4\">🔔</button></div>\n    </header>\n\n    <div class=\"content\">\n      <div class=\"pagehead\">\n        <div class=\"h-left\">\n          <h1>Staff <span class=\"count\">🔒 unlocks in Era 2 — Colocation</span></h1>\n          <div class=\"sub\">Hire LLM engineers, ops folks, and a community manager. They argue.</div>\n        </div>\n        <div class=\"h-right\">\n          <button class=\"btn\">Read about staff →</button>\n        </div>\n      </div>\n\n      <div class=\"lockwrap\">\n\n        <!-- Lock overlay -->\n        <div class=\"lock-overlay\">\n          <div class=\"lock-card\">\n            <div class=\"badge\">🔒 Era 2 — Colocation</div>\n            <h1>Hire your first employee</h1>\n            <p class=\"sub\">In Era 2 you stop being a solo founder. NPCs you hire are LLM agents — they have opinions, weekend plans, and will quit if you ignore their 1:1s.</p>\n\n            <div class=\"requirements\">\n              <div class=\"req done\">\n                <div class=\"ck\">✓</div>\n                <div class=\"lbl\">Reach $100 MRR</div>\n                <div class=\"progress\">$48 / $100</div>\n              </div>\n              <div class=\"req\">\n                <div class=\"ck\"></div>\n                <div class=\"lbl\">Lease a colo cabinet (any city)</div>\n                <div class=\"progress\">0 / 1</div>\n              </div>\n              <div class=\"req\">\n                <div class=\"ck\"></div>\n                <div class=\"lbl\">Survive 30 consecutive days</div>\n                <div class=\"progress\">12 / 30</div>\n              </div>\n              <div class=\"req\">\n                <div class=\"ck\"></div>\n                <div class=\"lbl\">Reputation ≥ 65</div>\n                <div class=\"progress\">50 / 65</div>\n              </div>\n            </div>\n\n            <div class=\"cta-row\">\n              <a class=\"btn\" href=\"/play/research\">View Era 2 tech →</a>\n              <a class=\"btn primary\" href=\"/play\">Back to dashboard</a>\n            </div>\n            <div class=\"preview-note\">↓ sneak peek of what's waiting</div>\n          </div>\n        </div>\n\n        <!-- Blurred preview content -->\n        <div class=\"blur\">\n          <section class=\"panel\" style=\"margin-bottom: 18px;\">\n            <div class=\"roster-head\">\n              <h3>Recruiting board</h3>\n              <span style=\"font-family: var(--mono); font-size: 11px; color: var(--dim);\">// 6 candidates · refresh in 04:18</span>\n              <div style=\"margin-left:auto; display:flex; gap:8px;\">\n                <button class=\"btn sm\">Filters</button>\n                <button class=\"btn sm\">Refresh board $25</button>\n              </div>\n            </div>\n            <div class=\"roster-grid\">\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#a78bfa;\">L</div>\n                  <div>\n                    <div class=\"name\">Leah Voss</div>\n                    <div class=\"role\">Junior SRE · contract → FT</div>\n                  </div>\n                  <div class=\"salary\">$1.4k<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Self-taught. Strong on Linux, weak on social. Will fix things at 4 AM but expects to never be on Slack during weekends.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">Linux <b>★★★★</b></span>\n                  <span class=\"stat\">Net <b>★★</b></span>\n                  <span class=\"stat\">Comms <b>★</b></span>\n                  <span class=\"stat\">On-call OK</span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>Refuses to use anything with a GUI.</b></div>\n              </div>\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#22d3ee;color:#063045;\">B</div>\n                  <div>\n                    <div class=\"name\">Benji Park</div>\n                    <div class=\"role\">Generalist · ex-Reddit ops</div>\n                  </div>\n                  <div class=\"salary\">$2.1k<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Ex-Reddit ops, burned out. Wants chill. Excellent at writing customer-facing replies that don't sound passive-aggressive.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">Comms <b>★★★★★</b></span>\n                  <span class=\"stat\">Net <b>★★★</b></span>\n                  <span class=\"stat\">Linux <b>★★</b></span>\n                  <span class=\"stat\">No on-call</span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>Wants Fridays off. Non-negotiable.</b></div>\n              </div>\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#34d399;color:#07120c;\">M</div>\n                  <div>\n                    <div class=\"name\">Mohamed Idris</div>\n                    <div class=\"role\">Network engineer · ★★★★☆</div>\n                  </div>\n                  <div class=\"salary\">$3.0k<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Real-deal BGP wrangler. Has done peering deals you've only read about. Will roll eyes at your single-homed garage rack.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">Net <b>★★★★★</b></span>\n                  <span class=\"stat\">Linux <b>★★★</b></span>\n                  <span class=\"stat\">Comms <b>★★</b></span>\n                  <span class=\"stat\">Eats budget</span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>Will quit if MTTR &gt; 1h three months in a row.</b></div>\n              </div>\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#f59e0b;color:#1c1300;\">R</div>\n                  <div>\n                    <div class=\"name\">Reka Toth</div>\n                    <div class=\"role\">Community / DevRel</div>\n                  </div>\n                  <div class=\"salary\">$1.8k<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Already mods two self-hosting Discords. Will get you 12 signups in week one or die trying. Posts memes about your competitors.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">Comms <b>★★★★</b></span>\n                  <span class=\"stat\">Marketing <b>★★★★</b></span>\n                  <span class=\"stat\">Eng <b>★</b></span>\n                  <span class=\"stat\">+rep multiplier</span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>Will tweet from your account if undersupervised.</b></div>\n              </div>\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#f43f5e;\">D</div>\n                  <div>\n                    <div class=\"name\">Diego Reyes</div>\n                    <div class=\"role\">Senior SRE · ex-AWS</div>\n                  </div>\n                  <div class=\"salary\">$4.8k<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Knows where the bodies are buried in S3. Will overspec everything to enterprise standards. You can't afford him yet.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">Linux <b>★★★★★</b></span>\n                  <span class=\"stat\">Net <b>★★★★</b></span>\n                  <span class=\"stat\">Comms <b>★★★</b></span>\n                  <span class=\"stat\">Spendy</span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>\"We need a status page\" · says it weekly.</b></div>\n              </div>\n\n              <div class=\"hire-card\">\n                <div class=\"row1\">\n                  <div class=\"av\" style=\"background:#6366f1;\">?</div>\n                  <div>\n                    <div class=\"name\">\"Sleepy\"</div>\n                    <div class=\"role\">Anonymous applicant</div>\n                  </div>\n                  <div class=\"salary\">$900<small>/mo</small></div>\n                </div>\n                <div class=\"blurb\">Won't reveal real name. Resume is suspiciously good. Wants payment in crypto. There's a chance this is great. There's a chance.</div>\n                <div class=\"stats\">\n                  <span class=\"stat\">??? <b>★★★★?</b></span>\n                  <span class=\"stat\">Risk <b>HIGH</b></span>\n                </div>\n                <div class=\"quirk\">⌖ Quirk: <b>Will absolutely betray you. Or save the company. 50/50.</b></div>\n              </div>\n\n            </div>\n          </section>\n\n          <section class=\"panel\">\n            <div class=\"ph\"><h3>Your team · 0 hired</h3><span class=\"ph-sub\">// hire someone</span></div>\n            <div style=\"padding: 60px 24px; text-align: center; color: var(--dim);\">\n              You. Just you. And the pager.\n            </div>\n          </section>\n        </div>\n      </div>\n\n    </div>\n  </main>\n</div>\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscales — Staff</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/template.css" />
<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />
<script type="application/json" id="state" set:html={JSON.stringify(stateObj)}></script>
<script is:inline>
  try {
    const s = JSON.parse(document.getElementById('state').textContent);

    // Common: sidebar / topbar
    const crest = document.querySelector('.company-card .crest');
    if (crest) crest.textContent = s.initials;
    const cname = document.querySelector('.company-card .name');
    if (cname && cname.firstChild) cname.firstChild.textContent = s.company + ' ';
    const csub = document.querySelector('.company-card .sub');
    if (csub) csub.textContent = 'EST ' + s.founded + ' · ERA ' + s.era + ' · DAY ' + s.day;
    const ts = document.querySelectorAll('.topbar-stats .tstat .v');
    if (ts[0] && ts[0].firstChild) ts[0].firstChild.textContent = '$' + s.cashUsd;
    if (ts[1] && ts[1].firstChild) ts[1].firstChild.textContent = '$' + s.mrrUsd;
    if (ts[2] && ts[2].firstChild) ts[2].firstChild.textContent = String(s.rep);
    const me = document.querySelector('.side-foot .me');
    if (me) {
      const ava = me.querySelector('.ava');
      if (ava) ava.textContent = (s.displayName[0] || 'P').toUpperCase();
      const txt = me.childNodes[me.childNodes.length - 1];
      if (txt && txt.nodeType === 3) txt.textContent = s.displayName + ' · log out';
    }

    // Lock-card sub: real "team manages X customers" stat
    const lockSub = document.querySelector('.lock-card .sub');
    if (lockSub) {
      lockSub.textContent = 'Right now it is just you. You manage ' + s.customerCount +
        ' customer' + (s.customerCount === 1 ? '' : 's') +
        ' at MRR $' + s.mrrUsd + '. The hire-feature ships after Phase 1 — for now, no NPC teammates.';
    }

    // Requirements row: surface real MRR / customer progress
    const reqs = document.querySelectorAll('.lock-card .req');
    if (reqs[0]) {
      const lbl = reqs[0].querySelector('.lbl');
      const prog = reqs[0].querySelector('.progress');
      const mrrUsdN = s.mrrCents / 100;
      if (lbl) lbl.textContent = 'Reach $100 MRR';
      if (prog) prog.textContent = '$' + mrrUsdN.toFixed(0) + ' / $100';
      if (mrrUsdN >= 100) reqs[0].classList.add('done');
    }
    if (reqs[2]) {
      const lbl = reqs[2].querySelector('.lbl');
      const prog = reqs[2].querySelector('.progress');
      if (lbl) lbl.textContent = 'Survive 30 consecutive days';
      if (prog) prog.textContent = s.day + ' / 30';
      if (s.day >= 30) reqs[2].classList.add('done');
    }
    if (reqs[3]) {
      const lbl = reqs[3].querySelector('.lbl');
      const prog = reqs[3].querySelector('.progress');
      if (lbl) lbl.textContent = 'Reputation ≥ 65';
      if (prog) prog.textContent = s.rep + ' / 65';
      if (s.rep >= 65) reqs[3].classList.add('done');
    }

    // "You. Just you. And the pager." → personalize
    const tail = document.querySelector('.panel:last-of-type [style*="padding: 60px 24px"]');
    if (tail) {
      tail.textContent = s.displayName + '. Just you. And the pager.';
    }

    // "Your team · 0 hired"
    const teamHead = document.querySelector('.panel:last-of-type .ph h3');
    if (teamHead) teamHead.textContent = 'Your team · 0 hired';
    const teamSub = document.querySelector('.panel:last-of-type .ph .ph-sub');
    if (teamSub) teamSub.textContent = '// solo founder mode · Era ' + s.era;
  } catch (e) { console.error('hydrate', e); }
</script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
<I18nDashboard />
<DashboardAnims />
</body>
</html>
