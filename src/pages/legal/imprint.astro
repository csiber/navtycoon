---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { company } from '../../data/company';

const ALTS = { en: '/legal/imprint', hu: '/hu/impresszum', de: '/de/impressum' };
---
<LegalLayout
  title="Imprint"
  description="Mandatory operator details for Hyperscales (Polyák Csaba e.v.) under Hungarian and EU law."
  lang="en"
  alternates={ALTS}
  updated="2026-05-14"
>
  <h1>Imprint</h1>
  <p class="lead">
    Mandatory operator details. (German "Impressum" / Hungarian "Impresszum" equivalent.)
  </p>
  <div class="lang-row">
    <span class="active">English</span>
    <a href="/hu/impresszum">Magyar</a>
    <a href="/de/impressum">Deutsch</a>
  </div>

  <h2>Operator</h2>
  <ul>
    <li><strong>Legal name:</strong> {company.name}</li>
    <li><strong>Brand:</strong> {company.brand}</li>
    <li><strong>Address:</strong> {company.address.full}</li>
    <li><strong>Country:</strong> {company.address.country}</li>
    <li><strong>Tax number:</strong> <code>{company.taxNumber}</code></li>
    <li><strong>Registry number:</strong> <code>{company.registryNumber}</code></li>
    <li><strong>Email:</strong> <a href={`mailto:${company.email}`}>{company.email}</a></li>
    <li><strong>Phone:</strong> <a href={`tel:${company.phoneRaw}`}>{company.phone}</a></li>
  </ul>

  <h2>Hosting provider</h2>
  <p>
    The site and the game are served by <strong>Cloudflare, Inc.</strong> (101 Townsend St,
    San Francisco, CA 94107, USA — <a href="https://www.cloudflare.com" target="_blank" rel="noopener">cloudflare.com</a>).
    Data is pinned to EU regions where supported.
  </p>

  <h2>Supervisory authority</h2>
  <p>
    The sole-proprietor activity is registered with the Hungarian National Tax and Customs
    Administration (NAV — <a href="https://nav.gov.hu" target="_blank" rel="noopener">nav.gov.hu</a>).
    Consumer complaints may be addressed to the locally competent district office or the
    Conciliation Body (Békéltető Testület).
  </p>

  <h2>Data protection authority</h2>
  <p>
    Hungarian National Authority for Data Protection and Freedom of Information (NAIH) —
    <a href="https://naih.hu" target="_blank" rel="noopener">naih.hu</a>,
    1055 Budapest, Falk Miksa u. 9–11.
  </p>

  <h2>Liability</h2>
  <p>
    Hyperscales is a fictional simulation game. NPC dialogue, customer names and other in-game
    content are generated by language models and do not represent real people, companies or
    events. References to real companies are coincidental or used in clearly fictional context.
  </p>

  <h2>Family of products</h2>
  <p>
    Hyperscales is part of the {company.parent} ecosystem
    (<a href={company.parentUrl}>{company.parentUrl}</a>). Cross-brand single sign-on is
    available — same account, separate user data scopes per brand.
  </p>
</LegalLayout>
