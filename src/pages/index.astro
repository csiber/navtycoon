---
// /  -- public marketing page. No auth, static content.
import { TRANSLATIONS } from '../lib/i18n';
const pageCss = "\n  :root {\n    --bg: #07090f;\n    --bg-1: #0b0e17;\n    --bg-2: #11141f;\n    --panel: #121626;\n    --panel-2: #161a2c;\n    --line: #1e2338;\n    --line-2: #262c46;\n    --text: #e9ecf5;\n    --muted: #8b92ad;\n    --dim: #5d6483;\n    --indigo: #6366f1;\n    --indigo-2: #818cf8;\n    --amber: #f59e0b;\n    --mint: #34d399;\n    --pink: #f43f5e;\n    --cyan: #22d3ee;\n    --display: \"Space Grotesk\", \"Inter\", system-ui, sans-serif;\n    --body: \"Inter\", system-ui, sans-serif;\n    --mono: \"JetBrains Mono\", ui-monospace, monospace;\n  }\n  * { box-sizing: border-box; }\n  html, body { margin: 0; padding: 0; }\n  body {\n    background: var(--bg);\n    color: var(--text);\n    font-family: var(--body);\n    font-size: 15px;\n    line-height: 1.55;\n    -webkit-font-smoothing: antialiased;\n    overflow-x: hidden;\n  }\n  a { color: inherit; text-decoration: none; }\n  button { font-family: inherit; cursor: pointer; }\n\n  /* Background grid */\n  body::before {\n    content: \"\";\n    position: fixed; inset: 0;\n    background-image:\n      linear-gradient(rgba(99,102,241,.045) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(99,102,241,.045) 1px, transparent 1px);\n    background-size: 56px 56px;\n    mask-image: radial-gradient(ellipse at 50% 0%, #000 30%, transparent 75%);\n    pointer-events: none;\n    z-index: 0;\n  }\n  body::after {\n    content: \"\";\n    position: fixed; inset: 0;\n    background:\n      radial-gradient(900px 500px at 12% -10%, rgba(99,102,241,.18), transparent 60%),\n      radial-gradient(700px 500px at 95% 5%, rgba(244,63,94,.10), transparent 60%);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 1; }\n\n  /* ───── Nav ───── */\n  nav.top {\n    position: sticky; top: 0; z-index: 50;\n    backdrop-filter: blur(14px);\n    background: rgba(7,9,15,.7);\n    border-bottom: 1px solid var(--line);\n  }\n  .nav-inner {\n    display: flex; align-items: center; justify-content: space-between;\n    height: 64px;\n  }\n  .brand {\n    display: flex; align-items: center; gap: 10px;\n    font-family: var(--display);\n    font-weight: 700; font-size: 19px; letter-spacing: -0.01em;\n  }\n  .brand-mark {\n    width: 28px; height: 28px; border-radius: 7px;\n    background: linear-gradient(135deg, var(--indigo) 0%, #4f46e5 100%);\n    display: grid; place-items: center;\n    box-shadow: 0 0 0 1px rgba(255,255,255,.08) inset, 0 8px 24px -8px rgba(99,102,241,.7);\n    position: relative;\n  }\n  .brand-mark::before {\n    content: \"\"; width: 12px; height: 12px;\n    background: #fff;\n    clip-path: polygon(55% 0, 0 60%, 45% 60%, 30% 100%, 100% 35%, 55% 35%);\n  }\n  .nav-links { display: flex; gap: 28px; align-items: center; font-size: 14px; color: var(--muted); font-weight: 500; }\n  .nav-links a:hover { color: var(--text); }\n  .nav-links .badge {\n    margin-left: 6px;\n    font-family: var(--mono); font-size: 10px;\n    padding: 2px 6px; border-radius: 4px;\n    background: rgba(52,211,153,.12); color: var(--mint);\n    border: 1px solid rgba(52,211,153,.25);\n    text-transform: uppercase; letter-spacing: 0.06em;\n  }\n  .nav-cta {\n    display: inline-flex; align-items: center; gap: 8px;\n    padding: 9px 14px; border-radius: 8px;\n    background: var(--text); color: var(--bg);\n    font-weight: 600; font-size: 13px;\n  }\n\n  /* ───── Hero ───── */\n  .hero {\n    padding: 72px 0 56px;\n    position: relative;\n  }\n  .pre-tag {\n    display: inline-flex; align-items: center; gap: 10px;\n    padding: 6px 12px 6px 8px;\n    background: var(--panel);\n    border: 1px solid var(--line-2);\n    border-radius: 999px;\n    font-family: var(--mono); font-size: 12px; color: var(--muted);\n  }\n  .pre-tag .pulse {\n    width: 7px; height: 7px; border-radius: 50%; background: var(--mint);\n    box-shadow: 0 0 0 0 rgba(52,211,153,.6);\n    animation: pulse 2s infinite;\n  }\n  @keyframes pulse {\n    0% { box-shadow: 0 0 0 0 rgba(52,211,153,.6); }\n    70% { box-shadow: 0 0 0 8px rgba(52,211,153,0); }\n    100% { box-shadow: 0 0 0 0 rgba(52,211,153,0); }\n  }\n  .hero-grid {\n    display: grid;\n    grid-template-columns: 1.05fr 1fr;\n    gap: 56px;\n    align-items: center;\n    margin-top: 28px;\n  }\n  h1.hero-title {\n    font-family: var(--display);\n    font-weight: 700;\n    font-size: clamp(40px, 5.6vw, 72px);\n    line-height: 1.02;\n    letter-spacing: -0.025em;\n    margin: 0 0 22px;\n  }\n  h1.hero-title .accent {\n    background: linear-gradient(105deg, var(--indigo-2) 0%, #c4b5fd 40%, var(--amber) 95%);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .hero-sub {\n    font-size: 18px; color: var(--muted); max-width: 540px;\n    margin: 0 0 32px;\n  }\n  .hero-sub b { color: var(--text); font-weight: 600; }\n  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }\n  .btn-primary {\n    display: inline-flex; align-items: center; gap: 10px;\n    padding: 14px 22px; border-radius: 10px; border: 0;\n    background: linear-gradient(180deg, var(--indigo-2), var(--indigo));\n    color: #fff; font-weight: 600; font-size: 15px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.18) inset, 0 12px 32px -10px rgba(99,102,241,.7);\n    transition: transform .12s ease;\n  }\n  .btn-primary:hover { transform: translateY(-1px); }\n  .btn-ghost {\n    display: inline-flex; align-items: center; gap: 10px;\n    padding: 14px 18px; border-radius: 10px;\n    background: var(--panel); color: var(--text);\n    border: 1px solid var(--line-2);\n    font-weight: 600; font-size: 15px;\n  }\n  .btn-ghost:hover { background: var(--panel-2); }\n  .meta-row {\n    display: flex; flex-wrap: wrap; gap: 22px 26px;\n    margin-top: 32px; padding-top: 24px;\n    border-top: 1px dashed var(--line);\n    font-family: var(--mono); font-size: 12px; color: var(--dim);\n  }\n  .meta-row b { color: var(--text); font-weight: 600; }\n  .meta-row .dot { color: var(--dim); margin: 0 4px; }\n\n  /* ───── Game UI Mockup (right hero) ───── */\n  .game-card {\n    background: linear-gradient(180deg, rgba(22,26,44,.95), rgba(11,14,23,.95));\n    border: 1px solid var(--line-2);\n    border-radius: 16px;\n    box-shadow: 0 30px 80px -20px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.02) inset;\n    overflow: hidden;\n    transform: perspective(1400px) rotateY(-3deg) rotateX(2deg);\n  }\n  .game-bar {\n    display: flex; align-items: center; gap: 10px;\n    padding: 11px 14px;\n    border-bottom: 1px solid var(--line);\n    background: rgba(11,14,23,.6);\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n  }\n  .game-bar .dots { display: flex; gap: 5px; margin-right: 6px; }\n  .game-bar .dots i { width: 9px; height: 9px; border-radius: 50%; display: block; background: var(--line-2); }\n  .game-bar .dots i:nth-child(1) { background: #ef4444; }\n  .game-bar .dots i:nth-child(2) { background: var(--amber); }\n  .game-bar .dots i:nth-child(3) { background: var(--mint); }\n  .game-bar .url { color: var(--dim); flex: 1; text-align: center; }\n  .game-bar .clock { color: var(--mint); }\n\n  .game-body {\n    display: grid; grid-template-columns: 1.1fr 1fr;\n    min-height: 420px;\n  }\n  /* Rack column */\n  .rack {\n    padding: 18px 16px;\n    border-right: 1px solid var(--line);\n    background:\n      radial-gradient(80% 60% at 50% 0%, rgba(99,102,241,.07), transparent 70%),\n      linear-gradient(180deg, rgba(7,9,15,.6), rgba(11,14,23,.6));\n  }\n  .rack-head {\n    display: flex; justify-content: space-between; align-items: baseline;\n    font-family: var(--mono); font-size: 11px;\n    color: var(--muted); margin-bottom: 12px;\n  }\n  .rack-head .loc { color: var(--text); font-weight: 600; }\n  .rack-stack { display: flex; flex-direction: column; gap: 5px; }\n  .u {\n    height: 18px; border-radius: 3px;\n    background: linear-gradient(90deg, #1a1f33, #232a45 70%, #1a1f33);\n    border: 1px solid #232a45;\n    display: grid; grid-template-columns: 36px 1fr 60px;\n    align-items: center;\n    padding: 0 8px; gap: 8px;\n    font-family: var(--mono); font-size: 9px; color: var(--dim);\n  }\n  .u .lbl { color: var(--muted); }\n  .u .leds { display: flex; gap: 3px; justify-content: flex-start; }\n  .u .leds i { width: 5px; height: 5px; border-radius: 50%; display: block; background: #2a3050; }\n  .u .leds i.g { background: var(--mint); box-shadow: 0 0 6px var(--mint); }\n  .u .leds i.a { background: var(--amber); box-shadow: 0 0 6px var(--amber); }\n  .u .leds i.r { background: var(--pink); box-shadow: 0 0 6px var(--pink); }\n  .u .util { font-family: var(--mono); font-size: 9px; color: var(--mint); text-align: right; }\n  .u.hot { background: linear-gradient(90deg, #2a1a1f, #3b2230 70%, #2a1a1f); border-color: #4a2535; }\n  .u.hot .util { color: var(--pink); }\n  .u.warn .util { color: var(--amber); }\n  .u.empty { background: repeating-linear-gradient(45deg, #10131f 0 5px, #131726 5px 10px); }\n  .u.empty .util { color: var(--dim); }\n\n  .rack-foot {\n    margin-top: 16px;\n    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;\n    font-family: var(--mono); font-size: 10px;\n  }\n  .stat-pill {\n    background: var(--panel-2); border: 1px solid var(--line);\n    border-radius: 6px; padding: 8px 9px;\n  }\n  .stat-pill .k { color: var(--dim); text-transform: uppercase; letter-spacing: 0.06em; font-size: 9px; }\n  .stat-pill .v { font-size: 15px; font-weight: 700; color: var(--text); margin-top: 2px; font-family: var(--display); }\n  .stat-pill .v.warn { color: var(--amber); }\n  .stat-pill .v.good { color: var(--mint); }\n\n  /* Tickets column */\n  .tickets-col {\n    padding: 14px 16px;\n    display: flex; flex-direction: column; gap: 10px;\n    background: rgba(11,14,23,.4);\n  }\n  .tickets-head {\n    display: flex; justify-content: space-between; align-items: center;\n    font-family: var(--mono); font-size: 11px;\n    color: var(--muted);\n  }\n  .tickets-head .count {\n    background: rgba(244,63,94,.15); color: var(--pink);\n    padding: 2px 7px; border-radius: 999px; font-weight: 600;\n    border: 1px solid rgba(244,63,94,.3);\n  }\n  .ticket {\n    background: var(--panel-2);\n    border: 1px solid var(--line);\n    border-radius: 9px;\n    padding: 11px 12px;\n    display: grid; grid-template-columns: 28px 1fr auto; gap: 10px;\n    align-items: start;\n  }\n  .ticket .av {\n    width: 28px; height: 28px; border-radius: 50%;\n    display: grid; place-items: center;\n    font-family: var(--mono); font-size: 10px; font-weight: 700;\n    color: #fff;\n  }\n  .av-1 { background: linear-gradient(135deg, #f97316, #ea580c); }\n  .av-2 { background: linear-gradient(135deg, #22d3ee, #0891b2); }\n  .av-3 { background: linear-gradient(135deg, #a78bfa, #7c3aed); }\n  .av-4 { background: linear-gradient(135deg, #f43f5e, #e11d48); }\n  .ticket .who {\n    font-size: 12px; font-weight: 600; color: var(--text);\n  }\n  .ticket .who .org { color: var(--dim); font-weight: 400; font-family: var(--mono); font-size: 10px; }\n  .ticket .msg { font-size: 12px; color: var(--muted); margin-top: 2px; line-height: 1.4; }\n  .ticket .sev {\n    font-family: var(--mono); font-size: 9px; padding: 2px 6px; border-radius: 4px;\n    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;\n  }\n  .sev.p1 { background: rgba(244,63,94,.16); color: var(--pink); border: 1px solid rgba(244,63,94,.3); }\n  .sev.p2 { background: rgba(245,158,11,.16); color: var(--amber); border: 1px solid rgba(245,158,11,.3); }\n  .sev.p3 { background: rgba(52,211,153,.12); color: var(--mint); border: 1px solid rgba(52,211,153,.25); }\n\n  /* Floating widget */\n  .float-widget {\n    position: absolute; right: -28px; top: -22px;\n    background: var(--panel); border: 1px solid var(--line-2);\n    border-radius: 10px; padding: 10px 14px;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    box-shadow: 0 10px 30px -8px rgba(0,0,0,.6);\n    transform: rotate(2deg);\n  }\n  .float-widget b { color: var(--mint); font-size: 13px; display: block; }\n  .float-widget-2 {\n    position: absolute; left: -36px; bottom: 60px;\n    background: var(--panel); border: 1px solid var(--line-2);\n    border-radius: 10px; padding: 12px 14px;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    box-shadow: 0 10px 30px -8px rgba(0,0,0,.6);\n    transform: rotate(-3deg);\n    max-width: 200px;\n  }\n  .float-widget-2 .lh { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; color: var(--text); }\n  .float-widget-2 .lh i { width: 6px; height: 6px; border-radius: 50%; background: var(--pink); animation: pulse 1.6s infinite; }\n\n  .hero-right-wrap { position: relative; }\n\n  /* ───── Ticker ───── */\n  .ticker {\n    border-top: 1px solid var(--line);\n    border-bottom: 1px solid var(--line);\n    background: var(--bg-1);\n    overflow: hidden;\n    position: relative;\n    margin-top: 32px;\n  }\n  .ticker-track {\n    display: flex; gap: 48px;\n    padding: 14px 0;\n    animation: scroll 60s linear infinite;\n    white-space: nowrap;\n    font-family: var(--mono); font-size: 12px; color: var(--muted);\n    width: max-content;\n  }\n  .ticker-item { display: inline-flex; align-items: center; gap: 10px; }\n  .ticker-item .who { color: var(--text); }\n  .ticker-item .sev-mini {\n    font-size: 9px; padding: 1px 5px; border-radius: 3px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700;\n  }\n  .ticker-item .sev-mini.p1 { background: rgba(244,63,94,.15); color: var(--pink); }\n  .ticker-item .sev-mini.p2 { background: rgba(245,158,11,.15); color: var(--amber); }\n  .ticker-item .sev-mini.p3 { background: rgba(52,211,153,.12); color: var(--mint); }\n  @keyframes scroll {\n    from { transform: translateX(0); }\n    to { transform: translateX(-50%); }\n  }\n\n  /* ───── Section heading ───── */\n  section.section { padding: 96px 0; position: relative; }\n  .sec-label {\n    font-family: var(--mono); font-size: 11px;\n    text-transform: uppercase; letter-spacing: 0.16em;\n    color: var(--indigo-2);\n    margin-bottom: 14px;\n  }\n  .sec-label::before { content: \"// \"; opacity: .5; }\n  h2 {\n    font-family: var(--display); font-weight: 700;\n    font-size: clamp(30px, 3.6vw, 46px);\n    letter-spacing: -0.02em; line-height: 1.05;\n    margin: 0 0 14px;\n  }\n  .sec-sub { color: var(--muted); font-size: 17px; max-width: 640px; margin: 0; }\n\n  /* ───── Personas ───── */\n  .personas {\n    display: grid; grid-template-columns: repeat(4, 1fr);\n    gap: 16px; margin-top: 44px;\n  }\n  .persona {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 22px 20px;\n    display: flex; flex-direction: column;\n    transition: transform .15s ease, border-color .15s ease;\n  }\n  .persona:hover { transform: translateY(-3px); border-color: var(--line-2); }\n  .persona .avatar {\n    width: 72px; height: 72px; border-radius: 14px;\n    display: grid; place-items: center;\n    margin-bottom: 16px; position: relative;\n    font-family: var(--mono); font-weight: 700; font-size: 28px; color: #fff;\n    box-shadow: 0 8px 24px -6px rgba(0,0,0,.5);\n    background-size: cover; background-position: center;\n    overflow: hidden;\n  }\n  .persona .avatar.has-img > span { display: none; }\n  .persona .avatar::after {\n    content: \"\"; position: absolute; bottom: -2px; right: -2px;\n    width: 14px; height: 14px; border-radius: 50%;\n    background: var(--mint); border: 3px solid var(--panel);\n  }\n  .persona.angry .avatar::after { background: var(--pink); }\n  .persona.weird .avatar::after { background: var(--amber); }\n  .persona-name { font-family: var(--display); font-weight: 600; font-size: 18px; }\n  .persona-role { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; }\n  .persona-quote {\n    margin-top: 14px; padding: 12px 14px;\n    background: rgba(7,9,15,.7); border: 1px solid var(--line);\n    border-radius: 10px;\n    font-size: 13px; color: var(--muted); line-height: 1.5;\n    position: relative;\n  }\n  .persona-quote::before {\n    content: \"\"; position: absolute; left: 18px; top: -6px;\n    width: 10px; height: 10px;\n    background: rgba(7,9,15,.7);\n    border-left: 1px solid var(--line); border-top: 1px solid var(--line);\n    transform: rotate(45deg);\n  }\n  .persona-stats {\n    margin-top: auto; padding-top: 14px;\n    display: flex; gap: 12px;\n    font-family: var(--mono); font-size: 10px; color: var(--dim);\n  }\n  .persona-stats span b { color: var(--text); font-size: 11px; }\n\n  /* ───── Timeline ───── */\n  .timeline {\n    margin-top: 48px;\n    position: relative;\n    padding: 0 20px;\n  }\n  .timeline-line {\n    position: absolute; left: 20px; right: 20px; top: 38px;\n    height: 2px; background: var(--line);\n  }\n  .timeline-line::after {\n    content: \"\"; position: absolute; left: 0; top: 0; height: 100%;\n    width: 70%;\n    background: linear-gradient(90deg, var(--indigo), var(--amber));\n  }\n  .timeline-grid {\n    display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px;\n    position: relative;\n  }\n  .era {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 0 0 18px;\n    position: relative;\n    text-align: left;\n    overflow: hidden;\n  }\n  .era .era-img {\n    height: 96px;\n    background-size: cover;\n    background-position: center;\n    border-bottom: 1px solid var(--line);\n    position: relative;\n  }\n  .era .era-img::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(180deg, rgba(7,9,15,0) 40%, var(--panel) 100%);\n  }\n  .era .year, .era .name, .era .blurb { padding-left: 16px; padding-right: 16px; }\n  .era .year { margin-top: 14px; }\n  .era::before {\n    content: \"\";\n    position: absolute; left: 14px; top: 8px;\n    width: 16px; height: 16px; border-radius: 50%;\n    background: var(--bg);\n    border: 3px solid var(--indigo);\n    z-index: 3;\n    box-shadow: 0 0 0 3px rgba(7,9,15,.7);\n  }\n  .era.active::before { background: var(--indigo); box-shadow: 0 0 0 4px rgba(99,102,241,.2); }\n  .era.future::before { border-color: var(--line-2); }\n  .era .year {\n    font-family: var(--mono); font-size: 11px;\n    color: var(--muted); letter-spacing: 0.06em;\n  }\n  .era .name {\n    font-family: var(--display); font-weight: 600; font-size: 16px;\n    margin-top: 4px;\n  }\n  .era .blurb { font-size: 12px; color: var(--dim); margin-top: 8px; line-height: 1.5; }\n  .era.active .name { color: var(--amber); }\n\n  /* ───── Screenshot showcase ───── */\n  .shots {\n    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 18px;\n    margin-top: 44px;\n  }\n  .shot {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    overflow: hidden;\n    position: relative;\n  }\n  .shot-img {\n    aspect-ratio: 16/10;\n    background:\n      repeating-linear-gradient(135deg, rgba(99,102,241,.06) 0 12px, transparent 12px 24px),\n      linear-gradient(180deg, #161a2c, #0d1020);\n    display: grid; place-items: center;\n    position: relative;\n    border-bottom: 1px solid var(--line);\n  }\n  .shot.tall .shot-img { aspect-ratio: 4/5; }\n  .shot-img .ph {\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n    text-align: center;\n    padding: 16px 20px;\n    border: 1px dashed var(--line-2);\n    border-radius: 8px;\n    background: rgba(7,9,15,.4);\n    max-width: 80%;\n  }\n  .shot-img .ph b { color: var(--text); font-size: 13px; display: block; margin-bottom: 4px; }\n  .shot-cap {\n    padding: 16px 18px;\n  }\n  .shot-cap h4 {\n    font-family: var(--display); font-weight: 600; font-size: 16px;\n    margin: 0 0 4px;\n  }\n  .shot-cap p {\n    font-size: 13px; color: var(--muted); margin: 0;\n  }\n  .shot-tag {\n    position: absolute; top: 14px; left: 14px;\n    font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 4px 8px; border-radius: 4px;\n    background: rgba(7,9,15,.7); border: 1px solid var(--line-2);\n    color: var(--muted);\n  }\n\n  /* Big game preview */\n  .preview-wide {\n    margin-top: 64px;\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    overflow: hidden;\n    position: relative;\n  }\n  .preview-wide .pw-bar {\n    padding: 12px 18px;\n    border-bottom: 1px solid var(--line);\n    display: flex; gap: 14px; align-items: center;\n    font-family: var(--mono); font-size: 11px; color: var(--muted);\n    background: rgba(7,9,15,.4);\n  }\n  .preview-wide .pw-bar .tab {\n    padding: 4px 10px; border-radius: 5px;\n    background: var(--panel-2); border: 1px solid var(--line);\n  }\n  .preview-wide .pw-bar .tab.on { color: var(--text); background: rgba(99,102,241,.15); border-color: rgba(99,102,241,.4); }\n  .preview-wide .pw-body {\n    aspect-ratio: 21/9;\n    background:\n      linear-gradient(180deg, rgba(7,9,15,.3) 0%, rgba(7,9,15,.85) 100%),\n      url(/img/hero-ops-floor.webp);\n    background-size: cover;\n    background-position: center;\n    display: grid; place-items: center;\n    position: relative;\n  }\n  .preview-wide .pw-body .ph-lg {\n    font-family: var(--mono); font-size: 13px;\n    color: var(--muted); text-align: center;\n    padding: 32px 40px;\n    border: 1px dashed var(--line-2);\n    border-radius: 12px;\n    background: rgba(7,9,15,.5);\n  }\n  .preview-wide .pw-body .ph-lg b {\n    display: block; color: var(--text); font-family: var(--display); font-size: 20px; margin-bottom: 8px;\n  }\n\n  /* Float chip on preview */\n  .chip-float {\n    position: absolute;\n    font-family: var(--mono); font-size: 11px;\n    background: rgba(7,9,15,.85); border: 1px solid var(--line-2);\n    border-radius: 8px; padding: 8px 12px;\n    color: var(--muted);\n    backdrop-filter: blur(8px);\n  }\n  .chip-float b { color: var(--text); }\n  .chip-float .dot-g { width: 6px; height: 6px; background: var(--mint); border-radius: 50%; display: inline-block; margin-right: 6px; vertical-align: 1px; }\n  .chip-float .dot-r { width: 6px; height: 6px; background: var(--pink); border-radius: 50%; display: inline-block; margin-right: 6px; vertical-align: 1px; }\n\n  /* ───── Features grid ───── */\n  .features {\n    display: grid; grid-template-columns: repeat(3, 1fr);\n    gap: 18px; margin-top: 44px;\n  }\n  .feature {\n    background: var(--panel);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 0 0 22px;\n    position: relative;\n    overflow: hidden;\n  }\n  .feature .feat-img {\n    height: 120px;\n    background-size: cover;\n    background-position: center;\n    border-bottom: 1px solid var(--line);\n    position: relative;\n  }\n  .feature .feat-img::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(180deg, rgba(7,9,15,0) 50%, var(--panel) 100%);\n  }\n  .feature h3, .feature p, .feature .feature-tag, .feature .feature-ico { margin-left: 22px; margin-right: 22px; }\n  .feature .feature-ico { margin-top: 18px; }\n  .feature-ico {\n    width: 40px; height: 40px; border-radius: 9px;\n    background: rgba(99,102,241,.1); border: 1px solid rgba(99,102,241,.3);\n    display: grid; place-items: center;\n    margin-bottom: 16px;\n    color: var(--indigo-2);\n    font-family: var(--mono); font-weight: 700;\n  }\n  .feature.amber .feature-ico { background: rgba(245,158,11,.1); border-color: rgba(245,158,11,.3); color: var(--amber); }\n  .feature.mint  .feature-ico { background: rgba(52,211,153,.1); border-color: rgba(52,211,153,.3); color: var(--mint); }\n  .feature.pink  .feature-ico { background: rgba(244,63,94,.1); border-color: rgba(244,63,94,.3); color: var(--pink); }\n  .feature.cyan  .feature-