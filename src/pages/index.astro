gn-items: center;\n    font-family: var(--mono); font-size: 11px; color: var(--dim);\n  }\n\n  /* ───── Responsive ───── */\n  @media (max-width: 1100px) {\n    .hero-grid { grid-template-columns: 1fr; }\n    .game-card { transform: none; }\n    .float-widget, .float-widget-2 { display: none; }\n    .personas { grid-template-columns: repeat(2, 1fr); }\n    .timeline-grid { grid-template-columns: repeat(3, 1fr); }\n    .shots { grid-template-columns: 1fr 1fr; }\n    .features { grid-template-columns: 1fr 1fr; }\n    .cta-final { grid-template-columns: 1fr; padding: 40px; }\n    .foot { grid-template-columns: 1fr 1fr; }\n  }\n  @media (max-width: 640px) {\n    .wrap { padding: 0 16px; }\n    /* Hide section-nav links but KEEP the language switcher reachable */\n    .nav-links a { display: none; }\n    .nav-links { gap: 0; }\n    #lang-switch { display: inline-flex !important; margin-left: 0; }\n    .nav-inner { height: 56px; }\n    .nav-cta { padding: 8px 12px; font-size: 12px; }\n    .brand { font-size: 17px; }\n    .hero { padding: 36px 0 40px; }\n    h1.hero-title { font-size: clamp(32px, 9vw, 44px); line-height: 1.08; }\n    .hero-sub { font-size: 15px; line-height: 1.5; margin-bottom: 24px; }\n    .pre-tag { font-size: 11px; padding: 5px 10px 5px 7px; }\n    .cta-row { gap: 8px; }\n    .btn-primary, .btn-ghost { padding: 12px 18px; font-size: 14px; width: 100%; justify-content: center; }\n    .meta-row { margin-top: 24px; padding-top: 18px; gap: 10px; flex-direction: column; align-items: flex-start; }\n    .game-card { margin: 0 -4px; }\n    .game-bar .url { display: none; }\n    .game-bar .clock { font-size: 10px; }\n    section.section { padding: 48px 0; }\n    h2 { font-size: clamp(24px, 7vw, 32px); }\n    .sec-sub { font-size: 14px; line-height: 1.55; }\n    .personas { grid-template-columns: 1fr; gap: 12px; margin-top: 28px; }\n    .persona { padding: 18px 16px; }\n    .persona .avatar { width: 56px; height: 56px; }\n    .timeline { padding: 0; }\n    .timeline-line { display: none; }\n    .timeline-grid { grid-template-columns: 1fr; gap: 10px; }\n    .era { padding-bottom: 14px; }\n    .era .era-img { height: 140px; }\n    .era::before { left: 12px; top: 12px; }\n    .shots { grid-template-columns: 1fr; gap: 12px; margin-top: 28px; }\n    .shot.tall .shot-img { aspect-ratio: 16/10; }\n    .features { grid-template-columns: 1fr; gap: 12px; margin-top: 28px; }\n    .feature { padding: 22px 18px; }\n    .game-body { grid-template-columns: 1fr; min-height: auto; }\n    .rack { border-right: 0; border-bottom: 1px solid var(--line); }\n    .preview-wide .pw-bar { overflow-x: auto; flex-wrap: nowrap; padding: 10px 14px; gap: 8px; }\n    .preview-wide .pw-bar > span { white-space: nowrap; }\n    .preview-wide .pw-body { aspect-ratio: 4/3; }\n    .preview-wide .pw-body .ph-lg { padding: 20px; font-size: 12px; }\n    .chip-float { font-size: 10px; padding: 6px 9px; }\n    .forum-list { grid-template-columns: 1fr; }\n    .post { border-right: 0; padding: 16px; }\n    .cta-final { padding: 32px 22px; }\n    .cta-final h2 { font-size: 28px; }\n    .foot { grid-template-columns: 1fr 1fr; gap: 28px; }\n    .foot-bottom { flex-direction: column; gap: 8px; align-items: flex-start; }\n  }\n  @media (max-width: 380px) {\n    .nav-cta { display: none; }\n    h1.hero-title { font-size: 30px; }\n    .meta-row { font-size: 11px; }\n  }\n";
const pageHtml = "\n\n<!-- ───── Nav ───── -->\n<nav class=\"top\">\n  <div class=\"wrap nav-inner\">\n    <div class=\"brand\">\n      <div class=\"brand-mark\"></div>\n      Hyperscaler\n    </div>\n    <div class=\"nav-links\">\n      <a href=\"#game\" data-i18n=\"nav.game\">The Game</a>\n      <a href=\"#customers\" data-i18n=\"nav.customers\">AI Customers</a>\n      <a href=\"#timeline\" data-i18n=\"nav.eras\">Eras</a>\n      <a href=\"#features\" data-i18n=\"nav.features\">Features</a>\n      <a href=\"#community\" data-i18n=\"nav.community\">Community</a>\n      <span id=\"lang-switch\" style=\"display:inline-flex;gap:2px;margin-left:6px;font-family:var(--mono);font-size:10px;border:1px solid var(--line);border-radius:6px;padding:2px;\">\n        <button data-lang=\"en\" class=\"lang-btn\" style=\"background:transparent;border:0;color:var(--muted);padding:3px 7px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:inherit;text-transform:uppercase;\">EN</button>\n        <button data-lang=\"hu\" class=\"lang-btn\" style=\"background:transparent;border:0;color:var(--muted);padding:3px 7px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:inherit;text-transform:uppercase;\">HU</button>\n        <button data-lang=\"de\" class=\"lang-btn\" style=\"background:transparent;border:0;color:var(--muted);padding:3px 7px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:inherit;text-transform:uppercase;\">DE</button>\n      </span>\n    </div>\n    <a class=\"nav-cta\" href=\"#play\" data-i18n=\"nav.cta\">Launch beta →</a>\n  </div>\n</nav>\n\n<!-- ───── Hero ───── -->\n<header class=\"hero\">\n  <div class=\"wrap\">\n    <div class=\"hero-grid\">\n      <div>\n        <span class=\"pre-tag\"><span class=\"pulse\"></span><span data-i18n=\"hero.pretag\">OPEN BETA · v0.7.2 \"Cold Start\"</span></span>\n        <h1 class=\"hero-title\">\n          <span data-i18n=\"hero.title1\">Run a hosting empire.</span><br>\n          <span class=\"accent\" data-i18n=\"hero.title2\">Your customers are AI.</span>\n        </h1>\n        <p class=\"hero-sub\" data-i18n=\"hero.sub\">\n          A browser-based tycoon where every angry customer, every weird ticket, every late-night\n          panic is generated by a real LLM that remembers your past mistakes. Start with one\n          beige tower in a garage in 2002. End up running edge nodes in seventeen cities — or\n          bankrupt at 4 AM debugging a Karen.\n        </p>\n        <div class=\"cta-row\">\n          <button class=\"btn-primary\" data-i18n=\"hero.cta_primary\">▶ Start playing free</button>\n          <a class=\"btn-ghost\" href=\"#trailer\" data-i18n=\"hero.cta_ghost\">Watch 90-sec trailer</a>\n        </div>\n        <div class=\"meta-row\">\n          <span><b data-i18n=\"hero.meta_free\">Free</b> <span data-i18n=\"hero.meta_free_suffix\">to play</span> <span class=\"dot\">·</span> <span data-i18n=\"hero.meta_free_note\">no signup to try</span></span>\n          <span><b data-i18n=\"hero.meta_saves\">Saves locally</b> <span class=\"dot\">·</span> <span data-i18n=\"hero.meta_saves_note\">bring your own LLM key</span></span>\n          <span><b data-i18n=\"hero.meta_shift\">~30 min</b> <span data-i18n=\"hero.meta_shift_note\">per shift</span></span>\n          <span id=\"live-stats\" style=\"opacity:0;transition:opacity .4s ease;\"><b id=\"live-stats-n\">·</b> founders running <span class=\"dot\">·</span> $<b id=\"live-stats-mrr\">·</b> MRR <span class=\"dot\">·</span> <b id=\"live-stats-resolved\">·</b> tickets resolved</span>\n        </div>\n      </div>\n\n      <div class=\"hero-right-wrap\">\n        <div class=\"float-widget\">\n          UPTIME (30d)<br>\n          <b>99.61%</b>\n        </div>\n        <div class=\"float-widget-2\">\n          <div class=\"lh\"><i></i><b>NEW TICKET</b></div>\n          <a href=\"/cdn-cgi/l/email-protection\" class=\"__cf_email__\" data-cfemail=\"1b707a697e755b756e6f697278747a7873357274\">[email&#160;protected]</a>: \"this is the THIRD time\"\n        </div>\n\n        <div class=\"game-card\">\n          <div class=\"game-bar\">\n            <div class=\"dots\"><i></i><i></i><i></i></div>\n            <span class=\"url\">hyperscaler.game / ops / rack-01</span>\n            <span class=\"clock\">● 03:42 AM · DAY 184</span>\n          </div>\n          <div class=\"game-body\">\n            <!-- Rack -->\n            <div class=\"rack\">\n              <div class=\"rack-head\">\n                <span class=\"loc\">RACK-01 · BUDAPEST</span>\n                <span>24U · 70% util</span>\n              </div>\n              <div class=\"rack-stack\">\n                <div class=\"u\"><span class=\"lbl\">U24</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i></i></span><span class=\"util\">42%</span></div>\n                <div class=\"u\"><span class=\"lbl\">U23</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i class=\"g\"></i></span><span class=\"util\">61%</span></div>\n                <div class=\"u warn\"><span class=\"lbl\">U22</span><span class=\"leds\"><i class=\"a\"></i><i class=\"g\"></i><i class=\"g\"></i></span><span class=\"util\">88%</span></div>\n                <div class=\"u hot\"><span class=\"lbl\">U21</span><span class=\"leds\"><i class=\"r\"></i><i class=\"r\"></i><i class=\"a\"></i></span><span class=\"util\">97%</span></div>\n                <div class=\"u\"><span class=\"lbl\">U20</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i class=\"g\"></i></span><span class=\"util\">55%</span></div>\n                <div class=\"u\"><span class=\"lbl\">U19</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i></i></span><span class=\"util\">38%</span></div>\n                <div class=\"u empty\"><span class=\"lbl\">U18</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n                <div class=\"u\"><span class=\"lbl\">U17</span><span class=\"leds\"><i class=\"g\"></i><i class=\"g\"></i><i class=\"g\"></i></span><span class=\"util\">71%</span></div>\n                <div class=\"u warn\"><span class=\"lbl\">U16</span><span class=\"leds\"><i class=\"a\"></i><i class=\"a\"></i><i class=\"g\"></i></span><span class=\"util\">82%</span></div>\n                <div class=\"u empty\"><span class=\"lbl\">U15</span><span class=\"leds\"><i></i><i></i><i></i></span><span class=\"util\">—</span></div>\n              </div>\n              <div class=\"rack-foot\">\n                <div class=\"stat-pill\"><div class=\"k\">MRR</div><div class=\"v\">$8,420</div></div>\n                <div class=\"stat-pill\"><div class=\"k\">SLA</div><div class=\"v good\">99.6%</div></div>\n                <div class=\"stat-pill\"><div class=\"k\">TEMP</div><div class=\"v warn\">28°C</div></div>\n              </div>\n            </div>\n\n            <!-- Tickets -->\n            <div class=\"tickets-col\">\n              <div class=\"tickets-head\">\n                <span>INBOX · LIVE</span>\n                <span class=\"count\">7 open</span>\n              </div>\n              <div class=\"ticket\">\n                <div class=\"av av-1\">K</div>\n                <div>\n                  <div class=\"who\">Karen Holloway <span class=\"org\">@ nutricoach.io</span></div>\n                  <div class=\"msg\">\"This is the THIRD time my checkout has 500'd this week. I have receipts.\"</div>\n                </div>\n                <span class=\"sev p1\">P1</span>\n              </div>\n              <div class=\"ticket\">\n                <div class=\"av av-2\">D</div>\n                <div>\n                  <div class=\"who\">Devon Park <span class=\"org\">@ pixelbrew</span></div>\n                  <div class=\"msg\">\"Migration finished but my DB is in Frankfurt now? It was in Warsaw.\"</div>\n                </div>\n                <span class=\"sev p2\">P2</span>\n              </div>\n              <div class=\"ticket\">\n                <div class=\"av av-3\">A</div>\n                <div>\n                  <div class=\"who\">Anonymous <span class=\"org\">@ ?? · burner</span></div>\n                  <div class=\"msg\">\"hi do you host shady stuff. asking for a friend.\"</div>\n                </div>\n                <span class=\"sev p3\">P3</span>\n              </div>\n              <div class=\"ticket\">\n                <div class=\"av av-4\">M</div>\n                <div>\n                  <div class=\"who\">Mira Sato <span class=\"org\">@ glassmap</span></div>\n                  <div class=\"msg\">\"Need GPU pod in Tokyo by Monday or we churn. Sorry, love your support btw.\"</div>\n                </div>\n                <span class=\"sev p2\">P2</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Ticker -->\n    <div class=\"ticker\">\n      <div class=\"ticker-track\" id=\"ticker\">\n        <!-- duplicated in JS -->\n      </div>\n    </div>\n  </div>\n</header>\n\n<!-- ───── AI Customers ───── -->\n<section class=\"section\" id=\"customers\">\n  <div class=\"wrap\">\n    <div class=\"sec-label\" data-i18n=\"sec.customers.label\">The catch</div>\n    <h2><span data-i18n=\"sec.customers.title1\">Your customers are not scripts.</span><br><span data-i18n=\"sec.customers.title2\">They are language models with grudges.</span></h2>\n    <p class=\"sec-sub\" data-i18n=\"sec.customers.sub\">\n      Every account you sign is a persistent LLM agent with memory, mood, a billing history and\n      friends on the forum. They'll praise you on Day 12 and leak your downtime on Day 47.\n    </p>\n\n    <div class=\"personas\">\n      <article class=\"persona angry\">\n        <div class=\"avatar av-1 has-img\" style=\"background-image:url(/img/persona-karen.webp);\"><span>K</span></div>\n        <div class=\"persona-name\">Karen Holloway</div>\n        <div class=\"persona-role\">Solo founder · 3rd complaint</div>\n        <div class=\"persona-quote\">\"I pay $19 a month. NINETEEN. I should not be the one telling YOU that europe-west-2 is on fire.\"</div>\n        <div class=\"persona-stats\">\n          <span>MRR <b>$19</b></span>\n          <span>Mood <b style=\"color:var(--pink)\">−42</b></span>\n          <span>Churn risk <b style=\"color:var(--pink)\">81%</b></span>\n        </div>\n      </article>\n      <article class=\"persona\">\n        <div class=\"avatar av-2 has-img\" style=\"background-image:url(/img/persona-devon.webp);\"><span>D</span></div>\n        <div class=\"persona-name\">Devon Park</div>\n        <div class=\"persona-role\">CTO · loyal since '24</div>\n        <div class=\"persona-quote\">\"Hey — the new staging region is chef's kiss. Can you also do Singapore? I'll prepay 6 months.\"</div>\n        <div class=\"persona-stats\">\n          <span>MRR <b>$1.2k</b></span>\n          <span>Mood <b style=\"color:var(--mint)\">+88</b></span>\n          <span>Refers <b>4</b></span>\n        </div>\n      </article>\n      <article class=\"persona weird\">\n        <div class=\"avatar av-3 has-img\" style=\"background-image:url(/img/persona-anon.webp);\"><span>A</span></div>\n        <div class=\"persona-name\">\"Anon\"</div>\n        <div class=\"persona-role\">Burner · vibes off</div>\n        <div class=\"persona-quote\">\"do you do egress without logs. paying in crypto. say no and I delete this account.\"</div>\n        <div class=\"persona-stats\">\n          <span>MRR <b>$840</b></span>\n          <span>Risk <b style=\"color:var(--amber)\">HIGH</b></span>\n          <span>Pays <b>on time</b></span>\n        </div>\n      </article>\n      <article class=\"persona\">\n        <div class=\"avatar av-4 has-img\" style=\"background-image:url(/img/persona-mira.webp);\"><span>M</span></div>\n        <div class=\"persona-name\">Mira Sato</div>\n        <div class=\"persona-role\">Eng lead · enterprise</div>\n        <div class=\"persona-quote\">\"Procurement will need SOC 2 by Q3. If you can ship audit logs, I can sell you internally.\"</div>\n        <div class=\"persona-stats\">\n          <span>MRR <b>$14k</b></span>\n          <span>Mood <b style=\"color:var(--mint)\">+22</b></span>\n          <span>Expansion <b style=\"color:var(--mint)\">3×</b></span>\n        </div>\n      </article>\n    </div>\n  </div>\n</section>\n\n<!-- ───── Timeline ───── -->\n<section class=\"section\" id=\"timeline\" style=\"padding-top: 0;\">\n  <div class=\"wrap\">\n    <div class=\"sec-label\" data-i18n=\"sec.timeline.label\">2002 → 2026</div>\n    <h2><span data-i18n=\"sec.timeline.title1\">From beige tower in your</span><br><span data-i18n=\"sec.timeline.title2\">cousin's garage to global edge.</span></h2>\n    <p class=\"sec-sub\" data-i18n=\"sec.timeline.sub\">\n      The tech tree is the real one. The hardware costs real money (well, fake money). Every era\n      unlocks new servers, new customers, new ways to fail.\n    </p>\n\n    <div class=\"timeline\">\n      <div class=\"timeline-line\"></div>\n      <div class=\"timeline-grid\">\n        <div class=\"era\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-1-garage.webp);\"></div>\n          <div class=\"year\">2002</div>\n          <div class=\"name\">Garage Era</div>\n          <div class=\"blurb\">1U Pentium 4. Your roommate is the cooling system.</div>\n        </div>\n        <div class=\"era\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-2-colo.webp);\"></div>\n          <div class=\"year\">2006</div>\n          <div class=\"name\">Colo</div>\n          <div class=\"blurb\">Rent a half-rack. Learn what BGP costs.</div>\n        </div>\n        <div class=\"era\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-3-vps.webp);\"></div>\n          <div class=\"year\">2012</div>\n          <div class=\"name\">VPS Boom</div>\n          <div class=\"blurb\">Sell slices of metal. Pray no one mines.</div>\n        </div>\n        <div class=\"era\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-4-containers.webp);\"></div>\n          <div class=\"year\">2018</div>\n          <div class=\"name\">Containers</div>\n          <div class=\"blurb\">k8s, Stripe webhooks, your first SOC 2.</div>\n        </div>\n        <div class=\"era active\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-5-gpu.webp);\"></div>\n          <div class=\"year\">2024</div>\n          <div class=\"name\">GPU Gold Rush</div>\n          <div class=\"blurb\">Llamas. Lots of llamas. Watts cost more than rent.</div>\n        </div>\n        <div class=\"era future\">\n          <div class=\"era-img\" style=\"background-image:url(/img/era-6-edge.webp);\"></div>\n          <div class=\"year\">2026</div>\n          <div class=\"name\">Global Edge</div>\n          <div class=\"blurb\">17 cities. Sub-30ms anywhere. One bad cert away from ruin.</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ───── Wide game preview ───── -->\n<section class=\"section\" id=\"game\" style=\"padding-top: 0;\">\n  <div class=\"wrap\">\n    <div class=\"sec-label\" data-i18n=\"sec.game.label\">Inside the game</div>\n    <h2><span data-i18n=\"sec.game.title1\">A real ops console.</span><br><span data-i18n=\"sec.game.title2\">Pretending to be a game.</span></h2>\n    <p class=\"sec-sub\" data-i18n=\"sec.game.sub\">\n      You don't click a \"happy customer\" button. You triage tickets, route traffic, scale fleets,\n      decide who to refund and who to fire. Every decision has a paper trail the LLM reads back to\n      you later.\n    </p>\n\n    <div class=\"preview-wide\">\n      <div class=\"pw-bar\">\n        <div class=\"dots\" style=\"display:flex;gap:5px;\"><i style=\"width:9px;height:9px;border-radius:50%;background:#ef4444;display:block;\"></i><i style=\"width:9px;height:9px;border-radius:50%;background:var(--amber);display:block;\"></i><i style=\"width:9px;height:9px;border-radius:50%;background:var(--mint);display:block;\"></i></div>\n        <span class=\"tab on\">Ops</span>\n        <span class=\"tab\">Fleet</span>\n        <span class=\"tab\">Customers</span>\n        <span class=\"tab\">Finance</span>\n        <span class=\"tab\">Tickets <span style=\"color:var(--pink)\">·7</span></span>\n        <span style=\"margin-left:auto;color:var(--mint);\">● LIVE · Day 184 · $8,420 MRR</span>\n      </div>\n      <div class=\"pw-body\">\n        <a href=\"/play\" class=\"ph-lg\" style=\"text-decoration:none;color:inherit;\">\n          <b style=\"display:block;color:var(--text);font-family:var(--display);font-size:20px;margin-bottom:8px;\">▶ Live ops dashboard</b>\n          The real thing: ticket inbox, rack inventory, marketing-mix sliders, async multiplayer leaderboard.<br/><span style=\"color:var(--indigo-2);font-size:12px;\">→ open /play</span>\n        </a>\n        <div class=\"chip-float\" style=\"top:24px; left:32px;\"><span class=\"dot-g\"></span>frankfurt · <b>12ms</b></div>\n        <div class=\"chip-float\" style=\"top:80px; right:60px;\"><span class=\"dot-r\"></span>singapore · <b>473ms</b></div>\n        <div class=\"chip-float\" style=\"bottom:36px; left:80px;\"><span class=\"dot-g\"></span>budapest · <b>4ms</b> · home</div>\n        <div class=\"chip-float\" style=\"bottom:80px; right:40px;\"><span class=\"dot-g\"></span>são paulo · <b>89ms</b></div>\n      </div>\n    </div>\n\n    <div class=\"shots\">\n      <div class=\"shot tall\">\n        <span class=\"shot-tag\">Ticket queue</span>\n        <div class=\"shot-img\">\n          <a href=\"/play/tickets\" class=\"ph\" style=\"text-decoration:none;color:inherit;display:block;\">\n            <b>Ticket triage panel</b>\n            LLM-generated complaints · persona-tagged · open backlog with age-decay\n          </a>\n        </div>\n        <div class=\"shot-cap\">\n          <h4>Triage at 3 AM</h4>\n          <p>Every ticket is a fresh LLM completion that knows your past 90 days.</p>\n        </div>\n      </div>\n      <div class=\"shot\">\n        <span class=\"shot-tag\">Finance</span>\n        <div class=\"shot-img\">\n          <a href=\"/play/finance\" class=\"ph\" style=\"text-decoration:none;color:inherit;display:block;\">\n            <b>Finance dashboard</b>\n            Burn vs revenue · MRR trend · transaction log from real shifts\n          </a>\n        </div>\n        <div class=\"shot-cap\">\n          <h4>Watch the burn</h4>\n          <p>Power bills, payroll, GPU rentals — all real-time.</p>\n        </div>\n      </div>\n      <div class=\"shot\">\n        <span class=\"shot-tag\">Hiring</span>\n        <div class=\"shot-img\">\n          <a href=\"/play/staff\" class=\"ph\" style=\"text-decoration:none;color:inherit;display:block;\">\n            <b>Hire screen <span style=\"color:var(--amber);font-size:10px;\">🔒 Era 2</span></b>\n            NPC engineers with stats, quirks, and quitting thresholds. Hire-anxiety: included.\n          </a>\n        </div>\n        <div class=\"shot-cap\">\n          <h4>Hire (and lose) staff</h4>\n          <p>Your SRE quits if you keep paging her at 4 AM. Fair.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ───── Features ───── -->\n<section class=\"section\" id=\"features\" style=\"padding-top: 0;\">\n  <div class=\"wrap\">\n    <div class=\"sec-label\" data-i18n=\"sec.features.label\">What makes it different</div>\n    <h2 data-i18n=\"sec.features.title\">Six things no other tycoon does.</h2>\n\n    <div class=\"features\">\n      <article class=\"feature\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-llm-npc.webp);\"></div>\n        <div class=\"feature-ico\">01</div>\n        <h3>LLM-native NPCs</h3>\n        <p>Customers, staff and competitors are language model agents with persistent memory. No scripted trees.</p>\n        <span class=\"feature-tag\">// Llama 3.1 70B · Claude · GPT-4o</span>\n      </article>\n      <article class=\"feature amber\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-tech-tree.webp);\"></div>\n        <div class=\"feature-ico\">02</div>\n        <h3>Real tech tree</h3>\n        <p>From IDE racks and tape backups to liquid-cooled GPU pods. Every node has a cost, a watt draw, a MTBF.</p>\n        <span class=\"feature-tag\">// 280+ unlockables</span>\n      </article>\n      <article class=\"feature mint\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-shifts.webp);\"></div>\n        <div class=\"feature-ico\">03</div>\n        <h3>Support shifts</h3>\n        <p>Sit down for a 30-minute live shift. Triage 10 angry tickets. Get scored on first-touch and refund cost.</p>\n        <span class=\"feature-tag\">// Run anywhere · 1 tab</span>\n      </article>\n      <article class=\"feature pink\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-reputation.webp);\"></div>\n        <div class=\"feature-ico\">04</div>\n        <h3>Public reputation</h3>\n        <p>The in-game Hacker News equivalent will absolutely roast you if you have a bad outage. Search \"hyperscaler down\".</p>\n        <span class=\"feature-tag\">// Karma matters</span>\n      </article>\n      <article class=\"feature cyan\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-byok.webp);\"></div>\n        <div class=\"feature-ico\">05</div>\n        <h3>Bring your own model</h3>\n        <p>Paste an API key and your customers run on the LLM of your choice. Or use the free hosted model with caps.</p>\n        <span class=\"feature-tag\">// Local Ollama supported</span>\n      </article>\n      <article class=\"feature\">\n        <div class=\"feat-img\" style=\"background-image:url(/img/feat-multiplayer.webp);\"></div>\n        <div class=\"feature-ico\">06</div>\n        <h3>Async multiplayer</h3>\n        <p>Compete on the global leaderboard. Acquire rival providers. Get acquired. Sleep, your fleet runs.</p>\n        <span class=\"feature-tag\">// Cross-shard auctions</span>\n      </article>\n    </div>\n  </div>\n</section>\n\n<!-- ───── Community ───── -->\n<section class=\"section\" id=\"community\" style=\"padding-top: 0;\">\n  <div class=\"wrap\">\n    <div class=\"sec-label\" data-i18n=\"sec.community.label\">Players say</div>\n    <h2><span data-i18n=\"sec.community.title1\">Early reviews from the closed beta.</span><br><span data-i18n=\"sec.community.title2\">It's brutal, in the good way.</span></h2>\n\n    <div class=\"forum\">\n      <div class=\"forum-head\">\n        <span><b>/r/hyperscaler</b> · selected posts</span>\n        <span>● closed-beta forum</span>\n      </div>\n      <div class=\"forum-list\">\n        <div class=\"post\">\n          <div class=\"pav av-1\">jp</div>\n          <div>\n            <div class=\"pmeta\"><b>jpetersen</b> · 2d · \"I lost a customer to lore\"</div>\n            <div class=\"pmsg\">A customer left because his agent \"remembered\" I bumped his price two quarters ago. The LLM literally cited the chat. I forgot. I lost $400 MRR to my own paper trail. 10/10.</div>\n            <div class=\"pstars\">★★★★★</div>\n          </div>\n        </div>\n        <div class=\"post\">\n          <div class=\"pav av-2\">ms</div>\n          <div>\n            <div class=\"pmeta\"><b>mira_s</b> · 4d · \"Game makes me a better PM\"</div>\n            <div class=\"pmsg\">I now write status pages at my real job the way the game scolds me to. My boss thinks I went to a conference. I just played Hyperscaler for a weekend.</div>\n            <div class=\"pstars\">★★★★★</div>\n          </div>\n        </div>\n        <div class=\"post\">\n          <div class=\"pav av-3\">dv</div>\n          <div>\n            <div class=\"pmeta\"><b>devops_dad</b> · 5d · \"Pricing rant\"</div>\n            <div class=\"pmsg\">Why does running my own Llama key cost 3× more than the in-game power bill. Felt very meta. Wife checked on me at 3am.</div>\n            <div class=\"pstars\">★★★★☆</div>\n          </div>\n        </div>\n        <div class=\"post\">\n          <div class=\"pav av-4\">ka</div>\n          <div>\n            <div class=\"pmeta\"><b>karen_irl</b> · 6d · \"I am Karen Holloway\"</div>\n            <div class=\"pmsg\">My name is Karen. The NPC named Karen yelled at me. Closed the tab. Opened it again. Refunded her. 1/10 emotional damage, would play forever.</div>\n            <div class=\"pstars\">★★★★★</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ───── CTA ───── -->\n<section class=\"section\" id=\"play\" style=\"padding-top: 0;\">\n  <div class=\"wrap\">\n    <div class=\"cta-final\">\n      <div>\n        <h2><span data-i18n=\"cta_final.title1\">Your first rack</span><br><span data-i18n=\"cta_final.title2\">is waiting.</span></h2>\n        <p data-i18n=\"cta_final.sub\">No signup. Saves locally. You can paste your own LLM key if you want bigger customers. Closed beta is open.</p>\n        <div class=\"cta-row\">\n          <button class=\"btn-primary\" data-i18n=\"cta_final.primary\">▶ Boot first server</button>\n          <a class=\"btn-ghost\" href=\"#\" data-i18n=\"cta_final.ghost\">Join the Discord →</a>\n        </div>\n      </div>\n      <div class=\"cta-side\">\n        <div class=\"row\"><span>Price</span><b class=\"y\">Free during beta</b></div>\n        <div class=\"row\"><span>Signup required</span><b class=\"n\">No</b></div>\n        <div class=\"row\"><span>Saves</span><b>Local + cloud sync</b></div>\n        <div class=\"row\"><span>LLM</span><b>Hosted · BYO key</b></div>\n        <div class=\"row\"><span>Platforms</span><b>Any modern browser</b></div>\n        <div class=\"row\"><span>Shift length</span><b>~30 min</b></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ───── Footer ───── -->\n<footer>\n  <div class=\"wrap\">\n    <div class=\"foot\">\n      <div>\n        <div class=\"brand\"><div class=\"brand-mark\"></div>Hyperscaler</div>\n        <p style=\"margin-top:12px;max-width:280px;\">A browser tycoon by two grumpy ex-SREs. Made between on-call rotations.</p>\n      </div>\n      <div>\n        <h5>Game</h5>\n        <ul>\n          <li><a href=\"#\">Play beta</a></li>\n          <li><a href=\"#\">Roadmap</a></li>\n          <li><a href=\"#\">Changelog</a></li>\n          <li><a href=\"#\">Mods</a></li>\n        </ul>\n      </div>\n      <div>\n        <h5>Community</h5>\n        <ul>\n          <li><a href=\"#\">Discord</a></li>\n          <li><a href=\"#\">Forum</a></li>\n          <li><a href=\"#\">Leaderboard</a></li>\n          <li><a href=\"#\">Bug tracker</a></li>\n        </ul>\n      </div>\n      <div>\n        <h5>About</h5>\n        <ul>\n          <li><a href=\"#\">Devlog</a></li>\n          <li><a href=\"#\">Press kit</a></li>\n          <li><a href=\"#\">Privacy</a></li>\n          <li><a href=\"#\">Contact</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"foot-bottom\">\n      <span>© 2026 Hyperscaler · Built on Cloudflare · No real customers were harmed</span>\n      <span>v0.7.2 \"Cold Start\" · build 18,402</span>\n    </div>\n  </div>\n</footer>\n\n\n\n";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hyperscaler — Run a hosting empire where every customer is AI</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

<style is:global set:html={pageCss}></style>
<style is:inline>
  body { transition: opacity 200ms ease-out; }
  body.preload { opacity: 0; }
</style>
</head>
<body class="preload">
<Fragment set:html={pageHtml} />

<script>
  // Build infinite ticker
  const items = [
    {who: "karen@nutricoach.io", msg: "I want a refund. Again.", sev: "p1"},
    {who: "devon@pixelbrew", msg: "Frankfurt feels slow today?", sev: "p2"},
    {who: "ops-bot", msg: "U21 hitting 97% CPU", sev: "p1"},
    {who: "anon@burner", msg: "do you log egress.", sev: "p3"},
    {who: "mira@glassmap", msg: "Need GPU pod by Monday", sev: "p2"},
    {who: "billing", msg: "Stripe webhook 502 ×4", sev: "p2"},
    {who: "hn:user1842", msg: "is hyperscaler down again?", sev: "p1"},
    {who: "sre:lin", msg: "PTO request — declined, you're on call", sev: "p3"},
    {who: "narek@vault", msg: "SOC 2 evidence by EOQ pls", sev: "p2"},
    {who: "rita@finchat", msg: "love the new dashboard btw", sev: "p3"},
    {who: "ops-bot", msg: "RACK-03 fan failure · BUDAPEST", sev: "p1"},
    {who: "leo@toolset", msg: "thinking of churning, sorry", sev: "p2"},
  ];
  const track = document.getElementById("ticker");
  function renderTicker(arr) {
    // XSS-safe: build DOM nodes with textContent only — no innerHTML.
    track.replaceChildren();
    const renderOnce = () => {
      for (const i of arr) {
        const wrap = document.createElement('span');
        wrap.className = 'ticker-item';
        const sev = document.createElement('span');
        sev.className = 'sev-mini ' + (i.sev === 'p1' ? 'p1' : i.sev === 'p2' ? 'p2' : 'p3');
        sev.textContent = i.sev;
        const who = document.createElement('span');
        who.className = 'who';
        who.textContent = i.who;
        const sep = document.createElement('span');
        sep.style.color = 'var(--dim)';
        sep.textContent = '›';
        const msg = document.createTextNode(' ' + i.msg);
        wrap.append(sev, ' ', who, ' ', sep, ' ', msg);
        track.appendChild(wrap);
      }
    };
    renderOnce();
    renderOnce(); // duplicate for seamless loop
  }
  renderTicker(items); // fallback paint immediately

  // Hydrate with real activity from /api/public/stats (if any).
  (async function () {
    try {
      const r = await fetch('/api/public/stats', { cache: 'no-cache' });
      if (!r.ok) return;
      const s = await r.json();
      const acts = Array.isArray(s.recent_activity) ? s.recent_activity : [];
      if (acts.length < 4) return; // keep mock if too sparse
      function ago(sec) {
        if (sec < 60) return sec + 's ago';
        if (sec < 3600) return Math.floor(sec / 60) + 'm ago';
        if (sec < 86400) return Math.floor(sec / 3600) + 'h ago';
        return Math.floor(sec / 86400) + 'd ago';
      }
      const realItems = acts.map(a => ({
        who: String(a.who || '?'),
        msg: String(a.msg || '') + ' · ' + ago(Number(a.time_ago_sec) || 0),
        sev: a.kind === 'ticket_resolved' ? 'p3' : 'p2',
      }));
      renderTicker(realItems);
    } catch { /* silent */ }
  })();

  // Subtle: animate a random rack LED every couple seconds
  const leds = document.querySelectorAll(".u .leds i");
  setInterval(() => {
    const idx = Math.floor(Math.random() * leds.length);
    const led = leds[idx];
    if (!led.dataset.orig) led.dataset.orig = led.className;
    led.className = "a";
    setTimeout(() => { led.className = led.dataset.orig; }, 350);
  }, 1800);
</script>
<script is:inline define:vars={{ TRANSLATIONS_INLINE: TRANSLATIONS }}>
    // Locale resolution: ?lang=… → localStorage → navigator.language → 'en'.
    // Applied client-side; server-rendered text is the EN fallback (good for
    // SEO + crawler-safe no-JS rendering).
    (function () {
      const SUPPORTED = ['en', 'hu', 'de'];
      function resolveLocale() {
        const url = new URL(window.location.href);
        const q = url.searchParams.get('lang');
        if (q && SUPPORTED.includes(q)) return q;
        try {
          const saved = localStorage.getItem('hs_lang');
          if (saved && SUPPORTED.includes(saved)) return saved;
        } catch { /* sandboxed */ }
        const nav = (navigator.language || 'en').slice(0, 2).toLowerCase();
        if (SUPPORTED.includes(nav)) return nav;
        return 'en';
      }
      function applyI18n(locale) {
        const dict = TRANSLATIONS_INLINE[locale] || TRANSLATIONS_INLINE.en;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (!key) return;
          const val = dict[key] || TRANSLATIONS_INLINE.en[key];
          if (typeof val === 'string') el.textContent = val;
        });
        document.documentElement.setAttribute('lang', locale);
        document.querySelectorAll('.lang-btn').forEach((b) => {
          const active = b.getAttribute('data-lang') === locale;
          b.style.background = active ? 'rgba(99,102,241,.15)' : 'transparent';
          b.style.color = active ? 'var(--text)' : 'var(--muted)';
        });
        try { localStorage.setItem('hs_lang', locale); } catch { /* sandboxed */ }
      }
      const initial = resolveLocale();
      applyI18n(initial);
      document.querySelectorAll('.lang-btn').forEach((b) => {
        b.addEventListener('click', () => {
          const lang = b.getAttribute('data-lang');
          if (lang) applyI18n(lang);
        });
      });
    })();

    // Wire the template's primary CTAs to real routes.
    document.querySelectorAll('.btn-primary').forEach(b => {
      b.addEventListener('click', () => { window.location.href = '/signup'; });
    });
    document.querySelectorAll('.nav-cta').forEach(b => {
      b.addEventListener('click', (e) => { e.preventDefault(); window.location.href = '/signup'; });
    });

    // Live stats: fetch /api/public/stats, populate the .meta-row span.
    // Best-effort: silent failure leaves the span at opacity:0.
    (async function () {
      try {
        const r = await fetch('/api/public/stats', { cache: 'no-cache' });
        if (!r.ok) return;
        const s = await r.json();
        const n = document.getElementById('live-stats-n');
        const mrr = document.getElementById('live-stats-mrr');
        const resolved = document.getElementById('live-stats-resolved');
        const wrap = document.getElementById('live-stats');
        if (n) n.textContent = String(s.players || 0);
        if (mrr) mrr.textContent = String(Math.round((s.total_mrr_cents || 0) / 100));
        if (resolved) resolved.textContent = String(s.tickets_resolved || 0);
        if (wrap) wrap.style.opacity = '1';
      } catch { /* silent */ }
    })();
  </script>
<script is:inline>
  // Hide mock-data flash: remove preload-class once hydrators have run.
  window.addEventListener('load', function () {
    setTimeout(function () { document.body.classList.remove('preload'); }, 30);
  });
</script>
</body>
</html>
